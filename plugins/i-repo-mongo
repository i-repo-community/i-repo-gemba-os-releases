// dest 記述子: ホストは --uri から userinfo を除去して採る（§4.4）。生資格情報を出さない。
//   host あり → mongodb:<host>/<db>.<collection> / host 無し → mongodb:<db>.<collection>
function uriHost(u) {
  if (!u) return "";
  try {
    // mongodb:// と mongodb+srv:// は WHATWG URL がそのままは解さないので scheme を差し替えて host を取り出す
    const swapped = String(u).replace(/^mongodb(\+srv)?:\/\//i, "http://");
    const url = new URL(swapped);
    return url.host; // userinfo は host に含まれない。複数ホスト指定時は最初の host:port
  } catch {
    const m = String(u).match(/^mongodb(?:\+srv)?:\/\/(?:[^@/]*@)?([^/?,]+)/i);
    return m ? m[1] : "";
  }
}

// mongosh をスクリプト経由で実行。read-only に find / countDocuments のみ呼ぶ（書込メソッドは一切呼ばない）。
function runMongoshQuery(uri, scriptBody) {
  return runMongoshScript(uri, scriptBody);
}

// mongosh の出力から「JSON 1行ずつ」を安定 parse する。print(JSON.stringify(...)) で各行を出す前提。
// 接続診断やヘルパ行（"OK" 等）以外の JSON 行のみ拾う。
function parseNdjsonLines(stdout) {
  const out = [];
  for (const line of String(stdout || "").split("\n")) {
    let s = line.trim();
    if (!s) continue;
    // mongosh 2.x は --nodb --quiet でも stdin スクリプト実行時に REPL プロンプト（"> " や接続後の
    // "<db>> "）を stdout に前置する。この前置があると最初の print 行が "test> {...}" となり、素朴に
    // s[0] を見ると JSON 行を取りこぼす（count 0・先頭行欠落）。JSON 開始文字までを捨ててから parse
    // する（プロンプト混入耐性・EJSON/JSON.stringify 出力は必ず { か [ で始まる1行）。
    if (s[0] !== "{" && s[0] !== "[") {
      const i = s.search(/[{[]/);
      if (i < 0) continue;
      s = s.slice(i);
    }
    try { out.push(JSON.parse(s)); } catch { /* 非 JSON 行は無視 */ }
  }
  return out;
}

// mongosh の stderr/stdout から接続不能を判定（E_CONNECT 振り分け用）。
function looksLikeConnError(text) {
  return /MongoNetworkError|ECONNREFUSED|ENOTFOUND|ETIMEDOUT|ServerSelection|connect failed|getaddrinfo|Authentication failed|MongoServerSelectionError|topology was destroyed|connection .*closed/i
    .test(String(text || ""));
}

function runQuery(qargs, G) {
  const { queryEnd, emitRow, queryError } = G.createReadKit(PLUGIN);
  const opts = G.parseQueryArgs(qargs, { "--uri": "uri", "--db": "db", "--collection": "collection" }, queryError,
    { "--native": { key: "native" }, "--native-timeout-ms": { key: "nativeTimeoutMs" } });
  if (!opts.collection) opts.collection = "reports";

  // dest はエラー時にも添えるため、引数検証より先に（生資格情報を含めずに）組む。
  const host = uriHost(opts.uri);
  const dest = host
    ? `mongodb:${host}/${opts.db}.${opts.collection}`
    : `mongodb:${opts.db}.${opts.collection}`;

  if (!opts.uri) queryError("E_ARGS", "--uri <connection-string> is required", "読み取り対象の MongoDB 接続文字列", 2, dest);
  if (!opts.db) queryError("E_ARGS", "--db <name> is required", "読み取り対象のデータベース", 2, dest);

  // ネイティブクエリ（capability: native-query / 仕様 §9・T2）。find filter / aggregation pipeline を素通し。
  if (opts.native != null) {
    runNativeMongo(opts, dest, G, { queryEnd, emitRow, queryError });
    return;
  }

  // ── フィルタ構築（§3.5）。時刻境界は lib が格納形式へ正規化済み（gte/lt → $gte/$lt） ──
  //   loaded → _loadedAt(ISO 文字列) / updated → values.updateTime(slash) / registered → values.registTime(slash)
  const timeField = opts.timeField === "updated" ? "values.updateTime"
    : opts.timeField === "registered" ? "values.registTime" : "_loadedAt";
  const filter = {};
  const bounds = G.timeBounds(opts, timeField === "_loadedAt" ? "iso" : "slash", queryError, dest);
  if (bounds) {
    const range = {};
    if (bounds.gte != null) range.$gte = bounds.gte;
    if (bounds.lt != null) range.$lt = bounds.lt;   // 半開区間 [since, until)
    filter[timeField] = range;
  }
  if (opts.deleted != null) filter.deleted = opts.deleted;
  if (opts.ids && opts.ids.length) filter._id = { $in: opts.ids };
  if (opts.itemIds.length) filter.itemId = { $in: opts.itemIds };
  // テナント厳格フィルタ（gemba-adc/1.1 §3.9）: _endpointFp に完全一致。フィールドを持たない
  // 旧ドキュメント（未タグ）は等値に当たらず自動除外＝厳格。--endpoint-fp 未指定なら絞らない。
  if (opts.endpointFp) filter._endpointFp = opts.endpointFp;

  const timeFilter = G.buildTimeFilter(opts);

  if (opts.countOnly) {
    const script =
      `const coll=db.getSiblingDB(${JSON.stringify(opts.db)}).getCollection(${JSON.stringify(opts.collection)});` +
      `print(JSON.stringify({total: coll.countDocuments(${JSON.stringify(filter)})}));`;
    const r = runMongoshQuery(opts.uri, script);
    if (r.status !== 0) {
      const text = (r.stderr || r.stdout || "").trim();
      if (looksLikeConnError(text)) queryError("E_CONNECT", `mongosh: ${scrub(firstLine(text)) || "connection failed"}`, "--uri を確認。mongod が起動しているか確認", 1, dest);
      queryError("E_INTERNAL", scrub(firstLine(text)) || "mongosh count failed", null, 1, dest);
    }
    const parsed = parseNdjsonLines(r.stdout);
    const total = parsed.length && typeof parsed[parsed.length - 1].total === "number"
      ? parsed[parsed.length - 1].total : 0;
    const end = { count: 0, complete: true, total, nextCursor: null, dest, dedupeApplied: false };
    if (timeFilter) end.timeFilter = timeFilter;
    queryEnd(end);
    process.exit(0);
  }

  // ── keyset ページング（_id 昇順・決定的）。cursor は base64 で不透明化（sqlite 同方式） ──
  const pageFilter = { ...filter };
  if (opts.cursor != null) {
    const last = G.decodeCursor(opts.cursor);
    if (last == null) queryError("E_CURSOR", "カーソルが不正です", "前回の query-end.nextCursor をそのまま渡してください", 2, dest);
    // 既存 _id フィルタ（--ids 由来）と両立させるため $and で合成する。
    pageFilter.$and = [...(pageFilter.$and || []), { _id: { $gt: last } }];
  }

  // find は read-only。sort {_id:1}・limit 件。各ドキュメントを EJSON で1行ずつ出す。
  const findScript =
    `const coll=db.getSiblingDB(${JSON.stringify(opts.db)}).getCollection(${JSON.stringify(opts.collection)});` +
    `const cur=coll.find(${JSON.stringify(pageFilter)}).sort({_id:1}).limit(${opts.limit});` +
    `cur.forEach(function(d){ print(EJSON.stringify(d)); });`;
  const r = runMongoshQuery(opts.uri, findScript);
  if (r.status !== 0) {
    const text = (r.stderr || r.stdout || "").trim();
    if (looksLikeConnError(text)) queryError("E_CONNECT", `mongosh: ${scrub(firstLine(text)) || "connection failed"}`, "--uri を確認。mongod が起動しているか確認", 1, dest);
    queryError("E_INTERNAL", scrub(firstLine(text)) || "mongosh find failed", null, 1, dest);
  }

  const rows = parseNdjsonLines(r.stdout);
  let lastKey = null;
  for (const doc of rows) {
    const key = doc._id;
    lastKey = key;
    const loadedAt = doc._loadedAt ?? null;
    // record 復元: 内部フィールド（_id / _loadedAt / _endpointFp）を剥がしたものが元 envelope（§3.3）。
    const record = {};
    for (const k of Object.keys(doc)) {
      if (k === "_id" || k === "_loadedAt" || k === "_endpointFp") continue;
      record[k] = doc[k];
    }
    let out = record;
    if (!opts.raw && opts.fields) out = G.pickFields(record, opts.fields);
    emitRow(key, loadedAt, opts.raw ? doc : out, opts.raw);
  }
  const complete = rows.length < opts.limit;
  const end = {
    count: rows.length, complete,
    nextCursor: complete ? null : G.encodeCursor(lastKey),
    dest, dedupeApplied: false,
  };
  if (timeFilter) end.timeFilter = timeFilter;
  queryEnd(end);
  process.exit(0);
}

// ── aggregate（gemba-adc/1.2・構造化集計）─ aggregation pipeline の $group へ写像 ──────
// group_by → $group._id の各キー（field=直参照／date_bucket=substrBytes による壁時計 prefix。
// sqlite/elastic と同じセマンティクス・変換はしない）。measure → $sum(1) / $addToSet+$size /
// $sum($convert) / $avg($convert)。フィルタ（$match）・未宣言/PII 次元ゲート・テナント厳格絞りは
// query と同一の砦。order_by は取得後に client 側で sort（pipeline 内では並びを固定しない）。
function runAggregate(aargs, G) {
  const { queryEnd, emitAggRow, queryError } = G.createReadKit(PLUGIN);
  const opts = G.parseAggregateArgs(aargs, { "--uri": "uri", "--db": "db", "--collection": "collection" }, queryError);
  if (!opts.collection) opts.collection = "reports";

  // dest はエラー時にも添えるため、引数検証より先に（生資格情報を含めずに）組む（query と同方針）。
  const host = uriHost(opts.uri);
  const dest = host
    ? `mongodb:${host}/${opts.db}.${opts.collection}`
    : `mongodb:${opts.db}.${opts.collection}`;

  if (!opts.uri) queryError("E_ARGS", "--uri <connection-string> is required", "集計対象の MongoDB 接続文字列", 2, dest);
  if (!opts.db) queryError("E_ARGS", "--db <name> is required", "集計対象のデータベース", 2, dest);

  // ── $match（フィルタ構築は query と同一・§3.5/§3.9）──
  const timeField = opts.timeField === "updated" ? "values.updateTime"
    : opts.timeField === "registered" ? "values.registTime" : "_loadedAt";
  const filter = {};
  const bounds = G.timeBounds(opts, timeField === "_loadedAt" ? "iso" : "slash", queryError, dest);
  if (bounds) {
    const range = {};
    if (bounds.gte != null) range.$gte = bounds.gte;
    if (bounds.lt != null) range.$lt = bounds.lt;   // 半開区間 [since, until)
    filter[timeField] = range;
  }
  if (opts.deleted != null) filter.deleted = opts.deleted;
  if (opts.ids && opts.ids.length) filter._id = { $in: opts.ids };
  if (opts.itemIds.length) filter.itemId = { $in: opts.itemIds };
  // テナント厳格フィルタ（gemba-adc/1.1 §3.9）: _endpointFp に完全一致。フィールドを持たない
  // 旧ドキュメント（未タグ）は等値に当たらず自動除外＝厳格（fail-closed）。未指定なら絞らない。
  if (opts.endpointFp) filter._endpointFp = opts.endpointFp;

  // ── 次元（group_by）→ $group._id の各キー式（未宣言/PII は多層の砦で拒否）──
  const dimIdExpr = {}, dimKeys = [];
  for (const g of opts.groupBy) {
    const meta = FIELD_META[g.field];
    if (!meta) queryError("E_ARGS", `未宣言のフィールドは次元にできません: ${g.field}`, "schema.fields の正準名のみ", 2, dest);
    if (opts.noPiiDimensions && meta.pii) queryError("E_ARGS", `PII 宣言フィールドは次元(group_by)に使えません（テナント分離セッション）: ${g.field}`, "集計でも値集合が露出するため", 2, dest);
    if (g.kind === "field") {
      dimKeys.push(g.field);
      dimIdExpr[g.field] = `$${meta.path}`;
    } else { // date_bucket
      if (!meta.datetime) queryError("E_ARGS", `date_bucket は datetime フィールドのみ: ${g.field}`, null, 2, dest);
      const tz = G.resolveBucketTz(g.tz, meta.timezone, queryError, dest);
      // MVP は「変換なしで扱える組合せ」のみ: 局所壁時計(local)は tz を解釈ゾーンとみなし substr、
      // UTC 格納は UTC バケットのみ substr。UTC×非-UTC バケットは DST 変換が要り zero-dep で不可＝未対応。
      if (meta.timezone === "utc" && tz !== "UTC") {
        queryError("E_UNSUPPORTED", `UTC 格納フィールド(${g.field})の非-UTC(${tz})バケットは未対応（MVP）`, "tz=UTC にするか局所時刻フィールドを使う", 2, dest);
      }
      const len = G.bucketSubstrLen(g.granularity);
      const key = `${g.field}_${g.granularity}`;
      dimKeys.push(key);
      const path = `$${meta.path}`;
      // $substrBytes は欠損/null でも例外を投げず ""（空文字）を返してしまう（動作確認済み）ため、
      // $type で明示判定して null にする（sqlite の substr(NULL,...)=NULL と同じ見た目にする）。
      dimIdExpr[key] = { $cond: [{ $in: [{ $type: path }, ["missing", "null"]] }, null, { $substrBytes: [path, 0, len] }] };
    }
  }

  // ── 指標（measure）→ $group の集約式（count/count_distinct/sum/avg・全て数値）──
  const groupMeasures = {}, measKeys = [], distinctAliases = [];
  for (const m of opts.measures) {
    measKeys.push(m.alias);
    if (m.op === "count") { groupMeasures[m.alias] = { $sum: 1 }; continue; }
    const meta = FIELD_META[m.field];
    if (!meta) queryError("E_ARGS", `未宣言のフィールドは指標にできません: ${m.field}`, "schema.fields の正準名のみ", 2, dest);
    const path = `$${meta.path}`;
    if (m.op === "count_distinct") {
      // $group では集合を作るだけ（$size は後段 $addFields）。
      groupMeasures[m.alias] = { $addToSet: path };
      distinctAliases.push(m.alias);
    } else if (m.op === "sum") {
      // $convert(onError/onNull:0) は sqlite の CAST(x AS REAL)（非数値→0）と同じ寛容さで数値化する。
      groupMeasures[m.alias] = { $sum: { $convert: { input: path, to: "double", onError: 0, onNull: 0 } } };
    } else { // avg
      // onNull:null で NULL/欠損を平均の分母から除外する（SQL の AVG(CAST(...)) は NULL を無視する。
      // onNull:0 だと 0 として算入され値がずれる）。非数値は onError:0＝sqlite の CAST(非数値)=0 に合わせる。
      groupMeasures[m.alias] = { $avg: { $convert: { input: path, to: "double", onError: 0, onNull: null } } };
    }
  }

  // 出力キー（次元＋指標 alias）は一意でなければならない。衝突すると同名フィールドの後勝ちで次元/指標が
  // 上書きされる（sqlite の `AS "x" … AS "x"` 事故と同種・P2）。"_id" は $group の予約名と衝突するため別途拒否。
  const allKeys = [...dimKeys, ...measKeys];
  const dupKey = allKeys.find((k, i) => allKeys.indexOf(k) !== i);
  if (dupKey) queryError("E_ARGS", `出力キーが重複しています: ${dupKey}`, "group_by 次元と measure alias は一意にする（measure に別名 as を付ける）", 2, dest);
  if (allKeys.includes("_id")) queryError("E_ARGS", `出力キーに "_id" は使えません（$group の予約名と衝突します）`, "measure に別名 alias を付ける", 2, dest);

  // order_by（measure alias か次元キー）を先に検証し、pipeline 内 $sort→$limit で **真の top-N** を取る
  // （$limit を先にすると任意のグループが選ばれ整列が部分集合に閉じる＝top-N が壊れるため）。
  // 未指定なら次元昇順で安定・再現的（sqlite の既定 ORDER BY に合わせる）。
  const sortStage = {};
  if (opts.orderBy && opts.orderBy.by) {
    const by = opts.orderBy.by;
    if (![...measKeys, ...dimKeys].includes(by)) queryError("E_ARGS", `--order-by の対象が不明: ${by}`, "measure alias か group_by 次元名", 2, dest);
    sortStage[measKeys.includes(by) ? `measures.${by}` : `dimensions.${by}`] = opts.orderBy.dir === "asc" ? 1 : -1;
  } else {
    for (const k of dimKeys) sortStage[`dimensions.${k}`] = 1;
  }

  // ── pipeline 組み立て。$sort の後に $limit(opts.limit+1) で超過分を検出→切り捨て（§limit 決定性）。──
  const pipeline = [{ $match: filter }, { $group: { _id: dimIdExpr, ...groupMeasures } }];
  if (distinctAliases.length) {
    const addFields = {};
    for (const a of distinctAliases) addFields[a] = { $size: `$${a}` };
    pipeline.push({ $addFields: addFields });
  }
  const projDims = {}, projMeas = {};
  for (const k of dimKeys) projDims[k] = `$_id.${k}`;
  for (const k of measKeys) projMeas[k] = `$${k}`;
  pipeline.push({ $project: { _id: 0, dimensions: projDims, measures: projMeas } });
  if (Object.keys(sortStage).length) pipeline.push({ $sort: sortStage });
  pipeline.push({ $limit: opts.limit + 1 });

  // maxTimeMS（server側）＋ client timeout+SIGKILL backstop（既存 native 経路と同水準・§9.6 相当）。
  const timeoutMs = 10000;
  const script =
    `const coll=db.getSiblingDB(${JSON.stringify(opts.db)}).getCollection(${JSON.stringify(opts.collection)});` +
    `const cur=coll.aggregate(${JSON.stringify(pipeline)},{maxTimeMS:${timeoutMs},allowDiskUse:true});` +
    `cur.forEach(function(d){ print(JSON.stringify(d)); });`;
  const r = runMongoshScript(opts.uri, script, { timeout: timeoutMs + 2000, killSignal: "SIGKILL", maxBuffer: 64 * 1024 * 1024 });

  if (r.signal === "SIGKILL" || (r.error && r.error.code === "ETIMEDOUT")) {
    queryError("E_TIMEOUT", `aggregate exceeded ${timeoutMs}ms`, "より絞り込んだ集計にしてください", 1, dest);
  }
  if (r.status !== 0) {
    const text = (r.stderr || r.stdout || "").trim();
    if (looksLikeConnError(text)) queryError("E_CONNECT", `mongosh: ${scrub(firstLine(text)) || "connection failed"}`, "--uri を確認。mongod が起動しているか確認", 1, dest);
    queryError("E_INTERNAL", scrub(firstLine(text)) || "mongosh aggregate failed", null, 1, dest);
  }

  // print(JSON.stringify(...)) の1行1オブジェクト出力を parseNdjsonLines で解析（mongosh 2.x の
  // REPL プロンプト前置に耐える・query と同じ経路）。
  // 並びは pipeline 内 $sort で確定済み（top-N も正確）。ここでは取得と truncated 判定のみ。
  let rows = parseNdjsonLines(r.stdout);
  const truncated = rows.length > opts.limit;
  if (truncated) rows = rows.slice(0, opts.limit);

  for (const row of rows) {
    const dimensions = {}, measures = {};
    for (const k of dimKeys) dimensions[k] = dimVal(row.dimensions ? row.dimensions[k] : null);
    for (const k of measKeys) measures[k] = measVal(row.measures ? row.measures[k] : null);
    emitAggRow(dimensions, measures);
  }
  queryEnd({ count: rows.length, complete: !truncated, truncated, nextCursor: null, dest,
    aggregate: true, groupBy: dimKeys, measures: measKeys });
  process.exit(0);
}

// ── ネイティブクエリ read-only バリデータ（mongo・T2 / 仕様 §9）─────────────
// find filter（object）または aggregation pipeline（array）を受ける。書込/JS実行を再帰拒否し、
// pipeline は read-only stage の whitelist のみ許可（default-deny）。
function validateReadOnlyMongo(raw, { scoped = false } = {}) {
  // pipeline で許可する read-only ステージ（default-deny・§9.3）。非掲載は拒否＝$lookup/$unionWith/
  // $graphLookup/$documents（クロスコレクション）・$out/$merge（書込）・$collStats/$currentOp 等を弾く。
  const ALLOWED_STAGES = new Set([
    "$match", "$project", "$group", "$sort", "$limit", "$skip", "$count",
    "$facet", "$bucket", "$bucketAuto", "$unwind", "$addFields", "$set", "$unset",
    "$sortByCount", "$replaceRoot", "$replaceWith", "$sample",
  ]);
  // scoped 時に再帰拒否するクロスコレクション・コレクション非依存ステージ（$facet 内も含む・§3.11 S4/S5）。
  // 非 scoped でも top-level は ALLOWED_STAGES で弾かれるが、$facet 配下は従来スキャン漏れがあり得るため
  // scoped では明示的に再帰検査する（構造的に境界を破る経路を閉じる）。
  const SCOPED_CROSS = new Set(["$lookup", "$unionWith", "$graphLookup", "$documents", "$collStats"]);
  let v;
  try { v = JSON.parse(String(raw)); }
  catch (e) { return { ok: false, reason: `JSON parse 失敗: ${e.message}` }; }
  // 書込（$out/$merge）・JS実行（$where/$function/$accumulator）・運用系を再帰拒否。
  const FORBIDDEN = new Set(["$out", "$merge", "$function", "$where", "$accumulator", "$listSessions", "$currentOp", "$planCacheStats"]);
  let bad = null;
  const scan = (o) => {
    if (bad || !o || typeof o !== "object") return;
    if (Array.isArray(o)) { for (const x of o) scan(x); return; }
    for (const k of Object.keys(o)) {
      if (FORBIDDEN.has(k)) { bad = k; return; }
      if (scoped && SCOPED_CROSS.has(k)) { bad = k; return; }
      scan(o[k]);
    }
  };
  scan(v);
  if (bad) {
    if (FORBIDDEN.has(bad)) return { ok: false, reason: `${bad} は read-only では不可` };
    return { ok: false, reason: `tenant-scoped native では ${bad} は不可（クロスコレクション迂回防止・§3.11）` };
  }
  if (Array.isArray(v)) {
    // pipeline は許可ステージのみ（default-deny・仕様 §9.3）。$lookup/$unionWith/$graphLookup 等の
    // クロスコレクション読み・運用系・書込ステージをまとめて弾く。
    // scoped 時は $facet 内のサブパイプラインも同じ ALLOWED + SCOPED_CROSS で再帰検査する。
    const checkStages = (stages, path) => {
      if (!Array.isArray(stages)) return `pipeline at ${path} は配列である必要があります`;
      for (let i = 0; i < stages.length; i++) {
        const stage = stages[i];
        if (!stage || typeof stage !== "object" || Array.isArray(stage)) {
          return `各ステージはオブジェクトである必要があります（${path}[${i}]）`;
        }
        for (const k of Object.keys(stage)) {
          if (!ALLOWED_STAGES.has(k)) {
            return `ステージ ${k} は許可されていません（read-only の許可ステージのみ・§9.3）`;
          }
          if (scoped && k === "$facet") {
            const facets = stage[k];
            if (!facets || typeof facets !== "object" || Array.isArray(facets)) {
              return "$facet の値はオブジェクトである必要があります";
            }
            for (const [name, sub] of Object.entries(facets)) {
              const err = checkStages(sub, `${path}[$facet].${name}`);
              if (err) return err;
            }
          }
        }
      }
      return null;
    };
    const stageErr = checkStages(v, "$");
    if (stageErr) return { ok: false, reason: stageErr };
    return { ok: true, kind: "pipeline", pipeline: v };
  }
  if (v && typeof v === "object") return { ok: true, kind: "find", filter: v };
  return { ok: false, reason: "配列(aggregation pipeline) か オブジェクト(find filter) が必要" };
}

function runNativeMongo(opts, dest, G, kit) {
  const { queryEnd, emitRow, queryError } = kit;
  // tenant-scoped native（gemba-adc §3.11）: --endpoint-fp 併用時はプラグインが境界を機械強制。
  const scoped = !!opts.endpointFp;
  let fp = null;
  if (scoped) {
    fp = opts.endpointFp;
    if (!/^[a-f0-9]{64}$/.test(fp)) {
      queryError("E_ARGS", "invalid --endpoint-fp format for tenant-scoped native query",
        "endpointFp は SHA-256 hex 小文字64桁です。テナント境界が必要な読み返しは構造化 query / aggregate をご利用ください", 2, dest);
    }
  }
  const v = validateReadOnlyMongo(opts.native, { scoped });
  if (!v.ok) {
    const hint = scoped
      ? "テナント閉じ込め下では $lookup/$unionWith/$graphLookup/$documents/$collStats 等は使えません。構造化 query / aggregate をご利用ください"
      : "read-only の find filter / aggregation pipeline のみ（$out/$merge/$where/$function 不可・仕様 §9）";
    queryError("E_ARGS", `native query rejected: ${v.reason}`, hint, 2, dest);
  }
  // 主防御: find は {$and:[userFilter,{_endpointFp:fp}]}、pipeline は先頭に {$match:{_endpointFp:fp}} を強制付与。
  let filter = v.kind === "find" ? v.filter : null;
  let pipeline = v.kind === "pipeline" ? v.pipeline : null;
  if (scoped) {
    if (v.kind === "find") filter = { $and: [filter, { _endpointFp: fp }] };
    else pipeline = [{ $match: { _endpointFp: fp } }, ...pipeline];
  }
  let timeoutMs = parseInt(opts.nativeTimeoutMs ?? "", 10); // 実行タイムアウト（§9.6）
  if (!Number.isFinite(timeoutMs) || timeoutMs < 1) timeoutMs = 10000;
  if (timeoutMs > 60000) timeoutMs = 60000;
  const cap = opts.limit, byteCap = 1_000_000; // 行数・出力サイズ上限（§9.6）
  const collExpr = `db.getSiblingDB(${JSON.stringify(opts.db)}).getCollection(${JSON.stringify(opts.collection)})`;

  // mongosh スクリプト。maxTimeMS で server 側もタイムアウト。pipeline には $limit cap を付ける。
  let script;
  if (opts.countOnly) {
    if (v.kind === "find") {
      script = `const c=${collExpr};print(JSON.stringify({total:c.countDocuments(${JSON.stringify(filter)},{maxTimeMS:${timeoutMs}})}));`;
    } else {
      const p = [...pipeline, { $count: "total" }];
      script = `const c=${collExpr};const a=c.aggregate(${JSON.stringify(p)},{maxTimeMS:${timeoutMs}}).toArray();print(JSON.stringify({total:a.length?a[0].total:0}));`;
    }
  } else {
    // 行数(cap)＋出力サイズ(byteCap)を mongosh スクリプト内で打ち切る（親が 64MB buffer する前に止め、
    // 巨大 $facet/幅広ドキュメントでの ENOBUFS を防ぐ・Codex #38 P2）。超過時は __TRUNCATED__ を出す。
    const cursorExpr = v.kind === "find"
      ? `c.find(${JSON.stringify(filter)}).limit(${cap}).maxTimeMS(${timeoutMs})`
      : `c.aggregate(${JSON.stringify([...pipeline, { $limit: cap }])},{maxTimeMS:${timeoutMs}})`;
    script = `const c=${collExpr};const cur=${cursorExpr};let b=0;`
      + `while(cur.hasNext()){const d=cur.next();const s=EJSON.stringify(d);`
      + `if(b+s.length>${byteCap}){print("__TRUNCATED__");break;}print(s);b+=s.length;}`;
  }

  // 別プロセス mongosh を timeout+SIGKILL で確実に打ち切る（client 側 backstop）。server maxTimeMS の少し後に。
  // mongosh が実 .exe なら直接 spawn のため timeout が mongosh 本体に効く。.cmd の場合は cmd.exe しか
  // kill されないが、スクリプトの maxTimeMS がサーバ側の実バウンドとして DB 作業を止める。
  const r = runMongoshScript(opts.uri, script,
    { timeout: timeoutMs + 2000, killSignal: "SIGKILL", maxBuffer: 64 * 1024 * 1024 });
  if (r.signal === "SIGKILL" || (r.error && r.error.code === "ETIMEDOUT")) {
    queryError("E_TIMEOUT", `native query exceeded ${timeoutMs}ms`, "より絞り込んだクエリにしてください（§9.6 リソースガード）", 1, dest);
  }
  // ENOBUFS（万一スクリプト内 cap をすり抜けて 64MB buffer 超）は E_INTERNAL にせず truncation として扱う。
  const enobufs = r.error && r.error.code === "ENOBUFS";
  if (!enobufs && r.status !== 0) {
    const text = (r.stderr || r.stdout || "").trim();
    if (looksLikeConnError(text)) queryError("E_CONNECT", `mongosh: ${scrub(firstLine(text)) || "connection failed"}`, "--uri を確認。mongod が起動しているか確認", 1, dest);
    queryError("E_INTERNAL", `native exec failed: ${scrub(firstLine(text))}`, "find filter / pipeline と項目名を確認", 1, dest);
  }

  if (opts.countOnly) {
    const parsed = parseNdjsonLines(r.stdout);
    const total = parsed.length && typeof parsed[parsed.length - 1].total === "number" ? parsed[parsed.length - 1].total : 0;
    queryEnd({ count: 0, complete: true, total, nextCursor: null, dest, dedupeApplied: false, native: true,
      ...(scoped ? { tenantScoped: true } : {}) });
    process.exit(0);
  }
  // 出力サイズはスクリプト内 byteCap で抑え済み。__TRUNCATED__ マーカー or ENOBUFS で打ち切りを判定。
  let truncated = enobufs || String(r.stdout).includes("__TRUNCATED__");
  const parsed = parseNdjsonLines(r.stdout); // マーカー("__TRUNCATED__")は非JSONなので除外される
  let n = 0;
  for (const doc of parsed) {
    const key = doc._id != null ? String(doc._id) : `native:${n}`;
    emitRow(key, doc._loadedAt ?? null, doc, true); // 任意形は raw で
    n++;
  }
  if (!truncated && n >= cap) truncated = true; // $limit cap に達した＝まだあるかも
  queryEnd({ count: n, complete: !truncated, truncated, nextCursor: null, dest, dedupeApplied: false, native: true,
    ...(scoped ? { tenantScoped: true } : {}) });
  process.exit(0);
}

function firstLine(s) { return String(s || "").split("\n").map((l) => l.trim()).filter(Boolean)[0] || ""; }
// mongosh のエラー文に接続文字列が混ざることがある。userinfo をマスクしてから error に載せる（ADC-1 §6.2）。
function scrub(s) { return String(s || "").replace(/(mongodb(\+srv)?:\/\/)[^@\s/]*@/gi, "$1****@"); }

// ── 引数 ─────────────────────────────────────────────────────────────
let uri = "", db = "", collection = "reports", dryRun = false, endpointFpFlag = "";
for (let i = 0; i < argv.length; i++) {
  switch (argv[i]) {
    case "--uri":        uri = argv[++i] ?? ""; break;
    case "--db":         db = argv[++i] ?? ""; break;
    case "--collection": collection = argv[++i] ?? "reports"; break;
    case "--dry-run":    dryRun = true; break;
    // 配信元テナント指紋のフォールバック刻印値（gemba-adc/1.1）。各レコードが provenance を
    // 持たないときの保険。通常はレコードの provenance.endpointFingerprint を優先。
    case "--endpoint-fp": endpointFpFlag = (argv[++i] ?? "").trim(); break;
    default: console.error(`unknown option: ${argv[i]}`); process.exit(2);
  }
}
// dry-run は接続情報なしでも入力検証だけ行える（plugin verify が使う経路）
if (!dryRun && (!uri || !db)) {
  console.error("--uri and --db are required");
  process.exit(2);
}

const jobId = `mongo-${new Date().toISOString().replace(/[-:T]/g, "").slice(0, 15)}-${process.pid}`;
const dest = uri ? `mongodb:${db}.${collection}` : `mongodb:${collection}`;

const receipt = (phase, count, failedCount, verified, extra = {}) => {
  process.stdout.write(JSON.stringify({
    schemaVersion: "1.0", recordType: "receipt", plugin: PLUGIN,
    producedBy: { plugin: PLUGIN, version: VERSION },
    phase, jobId, count, failedCount, verified, dest,
    ...(dryRun ? { dryRun: true } : {}),
    ...extra,
  }) + "\n");
};

async function readStdin() {
  const chunks = [];
  for await (const c of process.stdin) chunks.push(c);
  return Buffer.concat(chunks).toString("utf8");
}

// mongosh をスクリプト経由で実行（配信書き込み）。stdin 渡しなので ARG_MAX 制約は無いが、
// 1スクリプトの規模を抑えるため呼び出し側で従来どおりチャンク分割する。
function runMongosh(scriptBody) {
  return runMongoshScript(uri, scriptBody);
}

const CHUNK = 500; // 1回のスクリプト（stdin 渡し）に載せる最大ドキュメント数
function chunked(arr, n) {
  const out = [];
  for (let i = 0; i < arr.length; i += n) out.push(arr.slice(i, i + n));
  return out;
}

(async () => {
  const text = await readStdin();
  const lines = text.split("\n").map((l) => l.trim()).filter(Boolean);

  const docs = [];
  let trailer = null, envelopes = 0;
  for (const line of lines) {
    let obj;
    try { obj = JSON.parse(line); } catch { docs.push({ _raw: line }); continue; }
    if (obj && obj.schemaVersion) envelopes++;
    if (obj && obj.recordType === "stream-end") { trailer = obj; continue; }
    docs.push(obj);
  }

  // stream-end 照合（§2.6）
  if (trailer) {
    if (typeof trailer.count !== "number" || trailer.count !== docs.length) {
      console.error(`❌ incomplete stream: trailer count=${trailer.count ?? "unreadable"} but received ${docs.length}`);
      receipt("write", docs.length, docs.length, false);
      process.exit(1);
    }
  } else if (envelopes > 0) {
    console.error("❌ truncated stream: envelope records present but no stream-end trailer");
    receipt("write", docs.length, docs.length, false);
    process.exit(1);
  }

  // 各ドキュメントに _id（帳票IDキー）と取込時刻を付与
  const now = new Date().toISOString();
  const prepared = docs.map((d, i) => {
    const key = d.idempotencyKey
      ?? (d.itemId != null ? `report:${d.itemId}:rev${d.revNo ?? "?"}` : `${jobId}:${i}`);
    // テナント指紋: レコードの provenance（マニフェスト由来・SSOT）を最優先。無ければ load フラグで補完。
    // どちらも無ければフィールド自体を付けない（＝厳格 query の等値が当たらず除外・gemba-adc/1.1）。
    const efp = d.provenance?.endpointFingerprint || endpointFpFlag || "";
    const doc = { ...d, _id: key, _loadedAt: now };
    if (efp) doc._endpointFp = efp;
    return doc;
  });

  if (dryRun) {
    receipt("write", prepared.length, 0, false);
    console.error(`(dry-run) would upsert ${prepared.length} document(s) → ${db || "?"}.${collection}`);
    process.exit(0);
  }

  // ── write 相: _id で upsert（bulkWrite replaceOne upsert:true）。500件ずつ ──
  for (const batch of chunked(prepared, CHUNK)) {
    const writeScript =
      `const docs=${JSON.stringify(batch)};` +
      `const coll=db.getSiblingDB(${JSON.stringify(db)}).getCollection(${JSON.stringify(collection)});` +
      `const ops=docs.map(d=>({replaceOne:{filter:{_id:d._id},replacement:d,upsert:true}}));` +
      `coll.bulkWrite(ops,{ordered:false});print("OK");`;
    const w = runMongosh(writeScript);
    if (w.status !== 0) {
      console.error(scrub((w.stderr || w.stdout || "mongosh write failed").trim()));
      receipt("write", prepared.length, prepared.length, false);
      process.exit(1);
    }
  }
  receipt("write", prepared.length, 0, false);

  // ── verify 相: 取込キーが全件存在するか読み戻す（500件ずつ照合） ──────
  const ids = prepared.map((d) => d._id);
  let found = 0, verifyErr = false;
  for (const batch of chunked(ids, CHUNK)) {
    const verifyScript =
      `const ids=${JSON.stringify(batch)};` +
      `const coll=db.getSiblingDB(${JSON.stringify(db)}).getCollection(${JSON.stringify(collection)});` +
      `print(JSON.stringify({found: coll.countDocuments({_id:{$in:ids}})}));`;
    const v = runMongosh(verifyScript);
    if (v.status !== 0) { verifyErr = true; break; }
    // parseNdjsonLines を通す（mongosh 2.x の REPL プロンプト前置に耐える・query 経路と同じ）。
    const parsed = parseNdjsonLines(v.stdout);
    const last = parsed.length ? parsed[parsed.length - 1] : null;
    if (last && typeof last.found === "number") found += last.found; else verifyErr = true;
  }
  const verified = !verifyErr && found === ids.length;
  receipt("verify", prepared.length, verified ? 0 : prepared.length - found, verified, { verifiedDocs: found });
  process.exit(verified ? 0 : 1);
})().catch((e) => {
  console.error(`${PLUGIN}: ${scrub(e.message)}`);
  receipt("write", 0, 0, false);
  process.exit(1);
});
