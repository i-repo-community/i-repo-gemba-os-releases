#!/usr/bin/env node
/**
 * i-repo-mongo — sink plugin: upsert i-repo NDJSON records into MongoDB.
 *
 * 構想「i-Repo DataPipe for NoSQL」の Data Storage Manager 相当。
 * 帳票の XML→JSON 化されたネスト構造を、帳票ID をキーに NoSQL ドキュメントとして
 * そのまま保持する（RDB の列展開が難しい「横に広がる」構造を自然に表現）。
 * MotionBoard 等は CData 経由でこの MongoDB を参照できる。
 *
 * 設計: mongosh を呼ぶ薄いアダプタ（i-repo-s3 が aws を呼ぶのと同じ流儀）。
 *   npm 依存ゼロ。顧客が mongosh を持っていればそのまま動く。
 *   install: copy to ~/.i-repo/plugins/i-repo-mongo && chmod +x
 *   Windows: also copy i-repo-mongo.cmd shim
 *
 * Usage:
 *   i-repo rep list --format ndjson | i-repo mongo --uri mongodb://localhost:27017 --db irepo --collection reports
 *
 * Contract (PLUGINS.md / SCHEMA.md):
 *   - 予約フラグ --plugin-schema / --plugin-healthcheck
 *   - IREPO_PLUGIN_API 不一致は exit 11
 *   - stream-end トレーラ照合 (§2.6)
 *   - receipt: write → verify。verify は読み戻して件数照合し、verified:true は
 *     そのときだけ立てる（cleanup の前提にできるのは verified:true のみ）
 *   - 冪等: idempotencyKey（無ければ itemId:revNo）で upsert。再実行で重複しない。
 */
"use strict";

const PLUGIN = "i-repo-mongo";
const VERSION = "0.4.0";
const { spawnSync } = require("node:child_process");
const { spawnSyncSpec } = require("./lib/spawn.js");

const argv = process.argv.slice(2);

// 各スクリプトの先頭に差し込む接続プレリュード。mongosh は --nodb で起動し（positional URI を
// 渡さない）、URI は env IREPO_MONGO_URI から受け取って接続する。これで URI を cmd.exe argv に
// 載せずに済む（標準 Atlas URI の `&` や `%40` が spawnSpec のメタ文字拒否に当たる問題を回避＋
// secret をプロセス引数に出さない）。connect() は Database を返し、既存の db.getSiblingDB(...) が
// そのまま動く。
const MONGO_PRELUDE = "const db = connect(process.env.IREPO_MONGO_URI);\n";

// Windows で mongosh が「直接 spawn 可能な実行ファイル(.exe/.com)」として解決できるかを返す。
//   解決できれば cmd.exe を介さず直接 spawn でき、spawnSync の timeout/killSignal が mongosh 本体に
//   効く（cmd.exe ラップだと直下=cmd.exe しか kill されず、ネイティブクエリの client backstop が
//   無効化される — テーマA と同種）。.cmd/.bat（npm 配布 mongosh 等）は cmd.exe ラップが要るため null。
//   POSIX は shell 無しで直接 spawn でき timeout も効くため、そのままコマンド名を返す。
let _directMongosh; // undefined=未解決 / string=直 spawn パス / null=ラップ必要
function directMongosh() {
  if (_directMongosh !== undefined) return _directMongosh;
  if (process.platform !== "win32") { _directMongosh = "mongosh"; return _directMongosh; }
  const r = spawnSync("where", ["mongosh"], { encoding: "utf8" });
  const exe = r.status === 0
    ? r.stdout.split(/\r?\n/).map((s) => s.trim()).filter(Boolean).find((p) => /\.(exe|com)$/i.test(p))
    : null;
  _directMongosh = exe || null;
  return _directMongosh;
}

// mongosh をスクリプト「stdin」経由で実行する共通ヘルパ。
//   - スクリプト本文は stdin（input）で渡す: temp ファイルを作らない（PII をディスクに書かない・
//     権限/後始末不要）し、--file のパス引数が cmd.exe メタ文字（os.tmpdir() がユーザー名等で `()`
//     を含む場合）で spawnSpec に拒否される問題も起きない。mongosh は --nodb 起動でも、パイプされた
//     stdin をスクリプトとして実行して終了する（duckdb/bq と同じ stdin 流儀）。
//   - URI は env で渡す（argv に出さない／上記 MONGO_PRELUDE 参照）。
//   - 実 .exe なら直接 spawn（timeout が効く）、.cmd 等は spawnSyncSpec で cmd.exe ラップ。
//   extraOpts で timeout/killSignal/maxBuffer を上書きできる。戻り値は spawnSync の結果そのまま。
function runMongoshScript(uri, scriptBody, extraOpts = {}) {
  const opts = {
    encoding: "utf8",
    maxBuffer: 256 * 1024 * 1024,
    ...extraOpts,
    input: MONGO_PRELUDE + scriptBody,
    env: { ...process.env, IREPO_MONGO_URI: uri },
  };
  const args = ["--nodb", "--quiet"];
  const direct = directMongosh();
  return direct
    ? spawnSync(direct, args, opts)         // 直接 spawn: timeout/SIGKILL が mongosh 本体に効く
    : spawnSyncSpec("mongosh", args, opts); // .cmd: cmd.exe ラップ（timeout は cmd.exe。server maxTimeMS が実バウンド）
}

