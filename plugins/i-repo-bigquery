#!/usr/bin/env node
/**
 * i-repo-bigquery — sink plugin: write i-repo NDJSON records to Google BigQuery.
 *
 * 帳票データをフラット列でクラウド DWH（BigQuery）へ蓄積し、SQL・BI・ML から直接
 * 読める形にする。i-repo-parquet（Lakehouse）のクラウドマネージド版に相当する。
 *
 * 設計: bq CLI（Google Cloud SDK）を呼ぶ薄いアダプタ（parquet が duckdb を、mongo が
 *   mongosh を呼ぶのと同じ流儀）。npm 依存ゼロ。顧客が gcloud SDK を持ち、認証済み
 *   （`gcloud auth login` / ADC、または --key-file のサービスアカウント）であれば動く。
 *   install: copy to ~/.i-repo/plugins/i-repo-bigquery && chmod +x
 *
 * Usage:
 *   # 配信（テーブルが無ければ load が作成。dataset は自動作成を試みる）
 *   cat manifests/reports.ndjson | i-repo bigquery \
 *     --project my-gcp-proj --dataset irepo --table reports --location asia-northeast1
 *
 *   # サービスアカウント鍵で認証（パスのみ。鍵の中身は子プロセスの環境変数で渡す）
 *   ... | i-repo bigquery --project p --dataset d --table t --key-file ~/sa.json
 *
 * Contract (PLUGINS.md / SCHEMA.md):
 *   - 予約フラグ --plugin-schema / --plugin-healthcheck
 *   - IREPO_PLUGIN_API 不一致は exit 11
 *   - stream-end トレーラ照合 (§2.6)
 *   - receipt: write → verify。verify は書いた先を読み戻して今回 loaded_at の件数を
 *     照合し、verified:true はそのときだけ立てる
 *   - 冪等: BigQuery load は追記（WRITE_APPEND）。再実行は重複しうるため、重複排除は
 *     クエリ側 QUALIFY で冪等キー単位 loaded_at 最新へ畳む（iceberg と同方針）
 */
"use strict";

const PLUGIN = "i-repo-bigquery";
const VERSION = "0.3.0";
const { spawnSyncSpec } = require("./lib/spawn.js");
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");

const argv = process.argv.slice(2);

// ── 構造化集計 aggregate（gemba-adc/1.2）で参照する正準名→列/属性の唯一の宣言源
// （--plugin-schema の dataset.fields と一致）。aggregate の次元/指標はここに在るフィールドのみ
// 参照可（未宣言＝E_ARGS＝越境穴を宣言駆動で封鎖）。dispatch より前に初期化する（TDZ 回避）。
const FIELD_META = {
  idempotencyKey: { col: "idempotency_key" },
  recordType: { col: "record_type" },
  itemId: { col: "item_id" },
  revNo: { col: "rev_no" },
  name: { col: "name", pii: true },
  deleted: { col: "deleted" },
  registTime: { col: "regist_time", datetime: true, timezone: "local" },
  updateTime: { col: "update_time", datetime: true, timezone: "local" },
  loadedAt: { col: "loaded_at", datetime: true, timezone: "utc" },
  endpointFp: { col: "endpoint_fp" },
};
const dimVal = (v) => (typeof v === "bigint" ? Number(v) : v);          // 次元値: string|number|boolean|null
const measVal = (v) => (v == null ? 0 : Number(v));                     // 指標値: 数値（null は 0・bq JSON は文字列で来ることがある）

// ── 予約フラグ ───────────────────────────────────────────────────────
if (argv[0] === "--plugin-schema") {
  process.stdout.write(JSON.stringify({
    pluginApi: ["1"],
    schemaVersions: ["1.0"],
    recordTypes: ["*"],
    name: PLUGIN,
