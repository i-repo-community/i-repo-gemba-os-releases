      ? "テナント閉じ込め下では schema 修飾（main./temp.）・sqlite_master・pragma_/dbstat・ビュー参照は使えません。構造化 query / aggregate をご利用ください"
      : "read-only の単一 SELECT/WITH のみ許可（仕様 §9）";
    queryError("E_ARGS", `native query rejected: ${v.reason}`, hint, 2, dest);
  }

  // R5（早期拒否・多層防御の一枚）: ビュー参照を実行前に fail-closed で拒否する。トークナイザが抽出した
  // テーブル参照名（論理名・二重化エスケープ復元済み・casefold）にビュー名が含まれれば拒否（括弧付き参照も
  // lparen 引き継ぎで tableRefs に載る）。**構造的防御は下記の隔離実行**（child が自テナント分のみを :memory:
  // へコピーして実行）であり、R5 の取りこぼしがあっても越境は起きない。R5 は分かりやすいエラーのための層。
  if (scoped) {
    const { DatabaseSync } = require("node:sqlite");
    let edb;
    try { edb = new DatabaseSync(dbp, { readOnly: true }); }
    catch (e) { queryError("E_CONNECT", `cannot open read-only: ${e.message}`, "WAL の場合は配信中でないか確認", 1, dest); }
    const views = [];
    try {
      // 内部オブジェクトの除外は JS で literal 'sqlite_' 接頭辞判定（大小無視）。SQL の LIKE 'sqlite_%' は
      // _ がワイルドカードで正当なユーザー名 sqliteXreports 等まで巻き込むため使わない（Codex 指摘・バリデータの
      // /^sqlite_/ と同一意味論）。
      for (const o of edb.prepare("SELECT name FROM sqlite_master WHERE type='view'").all()) { if (!/^sqlite_/i.test(o.name)) views.push(o.name); }
    } catch (e) { try { edb.close(); } catch {} queryError("E_INTERNAL", e.message, null, 1, dest); }
    try { edb.close(); } catch {}
    const tableRefs = analyzeScopedSql(v.sql).tableRefs;
    const hitView = views.find((vn) => tableRefs.has(String(vn).toLowerCase()));
    if (hitView) {
      queryError("E_ARGS", `native query rejected: ビュー参照はテナント閉じ込め下で不可（${hitView}）`,
        "ビュー内部の絞りを外側ラップで保証できないため拒否します。構造化 query / aggregate をご利用ください", 2, dest);
