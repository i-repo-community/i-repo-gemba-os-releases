  // worker.terminate() もネイティブ呼び出しで block 中のスレッドを止められない。確実に中断するため
  // 別プロセスで実行し、timeout 超過時に SIGKILL で OS に殺させる（巨大集計・非終端 CTE もこれで止まる・
  // §9.6 リソースガード／Codex P2）。行は cap、出力は byteCap で打ち切り＝CPU/時間/メモリすべて有界。
  //
  // SQL 本文・fp は argv でなく stdin の JSON job で渡す（landmine「SQL/JS 本文は stdin」契約）。
  //
  // ── 構造的防御（主防御）: 隔離実行（gemba-adc §3.11）──────────────────────────
  // scoped 時、childCode は**自テナント分（endpoint_fp = fp）のみ**を新しい :memory: DB へ物理コピーし、
  // ユーザー SQL をそのコピー DB に対してだけ実行する。元ファイルは切り離され到達不能＝他テナント行が物理的に
  // 存在しないので、ビュー・仮想表（dbstat 等）・スキーマ修飾（main.）・括弧・文字列識別子といったあらゆる字句
  // トリックが原理的に無効化される（tokenizer/engine の parity gap に賭けない＝3度の越境の根本対策）。
  // ビューは複製しない＝参照は「no such table」で fail-closed（S3/S4）。endpoint_fp 列なしテーブルは空で複製。
  // 字句バリデータ（validateReadOnlySql の scoped トークナイザ・上の R5）は早期の分かりやすいエラーを出す層として残す。
  //
  // コピー予算（P2・自テナント DoS 対策）: 隔離コピーは自テナント全行が必要（集計の正しさ）ゆえユーザーの
  // --limit を適用できない。代わりに独立のハード上限（行数・累積バイト）を設け、超過したら fail-closed で停止する
  // （越境させず OOM 前に止める）。既定は 50 万行 / 64MB＝出力ガード（1MB・limit 上限1000）より十分広く、かつ
  // timeout の SIGKILL が効く前にメモリを守れる妥当値。巨大テナントは構造化 query/aggregate を使う（hint）。
  // 予算は運用/検証のため env で調整可（下げるほど安全側＝越境を招かないので低リスク）。既定は上記。
  const envBudget = (name, def) => { const v = parseInt(process.env[name] ?? "", 10); return Number.isFinite(v) && v > 0 ? v : def; };
  const COPY_ROW_BUDGET = envBudget("IREPO_NATIVE_COPY_ROW_BUDGET", 500000);
  const COPY_BYTE_BUDGET = envBudget("IREPO_NATIVE_COPY_BYTE_BUDGET", 64 * 1024 * 1024);
  const childCode = `
    const fs = require("node:fs");
    const { DatabaseSync, constants } = require("node:sqlite");
    const job = JSON.parse(fs.readFileSync(0, "utf8"));           // stdin JSON job（fd 0）
    const { dbp, sql, cap, byteCap, scoped, fp, copyRowBudget, copyByteBudget } = job;
    const q = (id) => '"' + String(id).replace(/"/g, '""') + '"';
    let db;
    if (scoped) {
      const src = new DatabaseSync(dbp, { readOnly: true });
      db = new DatabaseSync(":memory:");                          // 隔離先（元ファイルとは別 DB）
      // authorizer は**コピー前**（接続直後）に設置する。コピー段の DDL/DML はスタック実行され得るため、
      // ATTACH/DETACH/load_extension をこの時点から全域で拒否して元ファイル等への横入りを塞ぐ（Codex P1）。
      db.setAuthorizer((action, a1, a2) => {
        if (action === constants.SQLITE_ATTACH || action === constants.SQLITE_DETACH) return constants.SQLITE_DENY;
        if (action === constants.SQLITE_FUNCTION && typeof a2 === "string" && a2.toLowerCase() === "load_extension") return constants.SQLITE_DENY;
        return constants.SQLITE_OK;
      });
      // 列の宣言型 → SQLite 親和性 5 語（INTEGER/TEXT/BLOB/REAL/NUMERIC）または空（無親和）への写像。
      // PRAGMA table_info.type は外部入力なので DDL へ逐語連結しない（スタック DDL 注入＝T5h）。
      // 一方で型なし CREATE だと affinity が落ち、typeof()/比較が非 scoped とずれる（P2）。閉集合語のみ連結する。
      const affinityOf = (decl) => {
        const t = String(decl || "").toUpperCase();
        if (t.includes("INT")) return "INTEGER";
        if (t.includes("CHAR") || t.includes("CLOB") || t.includes("TEXT")) return "TEXT";
        if (t.includes("BLOB")) return "BLOB";
        if (t.includes("REAL") || t.includes("FLOA") || t.includes("DOUB")) return "REAL";
        if (!t) return ""; // 空宣言＝無親和（SQLite の BLOB/NONE 相当）＝型キーワードを付けない
        return "NUMERIC";
      };
      let copied = 0, copiedBytes = 0, over = false;
      for (const t of src.prepare("SELECT name FROM sqlite_master WHERE type='table'").all()) {
        if (/^sqlite_/i.test(t.name)) continue; // 内部表のみ除外（literal 接頭辞・LIKE の _ ワイルドカード誤爆回避・Codex 指摘）
        const cols = src.prepare("PRAGMA table_info(" + q(t.name) + ")").all();
        if (!cols.length) continue;
        const colDefs = cols.map((c) => {
          const aff = affinityOf(c.type);
          return aff ? (q(c.name) + " " + aff) : q(c.name);
        }).join(", ");
        db.exec("CREATE TABLE " + q(t.name) + " (" + colDefs + ")");
        if (!cols.some((c) => c.name === "endpoint_fp")) continue; // endpoint_fp 列なし＝未タグのみ＝空で複製（fail-closed・S3）
        const ins = db.prepare("INSERT INTO " + q(t.name) + " VALUES (" + cols.map(() => "?").join(", ") + ")");
        db.exec("BEGIN");
        for (const row of src.prepare("SELECT * FROM main." + q(t.name) + " WHERE endpoint_fp = ?").iterate(fp)) {
          copied++; copiedBytes += Buffer.byteLength(JSON.stringify(row, (_, v) => typeof v === "bigint" ? Number(v) : v));
          if (copied > copyRowBudget || copiedBytes > copyByteBudget) { over = true; break; } // コピー予算超過＝OOM 前に停止
          // node:sqlite は JS number を REAL でバインドするため、INTEGER 親和列の整数は BigInt で INTEGER を保つ。
          ins.run(...cols.map((c) => {
            const v = row[c.name];
            if (typeof v === "number" && Number.isInteger(v) && affinityOf(c.type) === "INTEGER") return BigInt(v);
            return v;
          }));
        }
        db.exec("COMMIT");
        if (over) break;
      }
      src.close();
      if (over) { process.stdout.write("__COPY_BUDGET_EXCEEDED__\\n"); db.close(); process.exit(0); }
    } else {
      db = new DatabaseSync(dbp, { readOnly: true });              // 非 scoped は従来どおり元 DB を直接（1ビット不変）
    }
    let n = 0, bytes = 0, truncated = false;
    const json = (row) => JSON.stringify(row, (_, v) => typeof v === "bigint" ? Number(v) : v);
    for (const row of db.prepare(sql).iterate()) {
      if (n >= cap) { truncated = true; break; }          // 行数キャップ
      const line = json(row) + "\\n";
      if (bytes + Buffer.byteLength(line) > byteCap) { truncated = true; break; } // 結果サイズキャップ（巨大行は出さない）
      process.stdout.write(line); bytes += Buffer.byteLength(line); n++;
    }
    if (truncated) process.stdout.write("__TRUNCATED__\\n");
    db.close();
  `;
  const { spawnSync } = require("node:child_process");
  const job = { dbp, sql: v.sql, cap, byteCap, scoped, fp, copyRowBudget: COPY_ROW_BUDGET, copyByteBudget: COPY_BYTE_BUDGET };
  const r = spawnSync(process.execPath, ["-e", childCode],
    { input: JSON.stringify(job), encoding: "utf8", timeout: timeoutMs, killSignal: "SIGKILL", maxBuffer: 64 * 1024 * 1024 });

  if (r.signal === "SIGKILL" || (r.error && r.error.code === "ETIMEDOUT")) {
