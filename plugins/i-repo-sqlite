  }
  if (r.error || r.status !== 0) {
    const detail = r.error ? r.error.message : (r.stderr || "").trim().slice(0, 200);
    queryError("E_INTERNAL", `native exec failed: ${detail}`, "SELECT 文と列名を確認", 1, dest);
  }

  // 隔離コピー予算の超過（P2・自テナント DoS 対策）。越境させず fail-closed で拒否する。
  if ((r.stdout || "").split("\n").includes("__COPY_BUDGET_EXCEEDED__")) {
    queryError("E_ARGS", "tenant data exceeds tenant-scoped native isolation budget",
      "テナントのデータ量が native 隔離実行の上限を超過しました。構造化 query / aggregate をご利用ください", 2, dest);
  }

  let truncated = false;
  const rows = [];
  for (const ln of (r.stdout || "").split("\n")) {
    if (!ln) continue;
    if (ln === "__TRUNCATED__") { truncated = true; continue; }
    if (ln === "__COPY_BUDGET_EXCEEDED__") continue;
    try { rows.push(JSON.parse(ln)); } catch {}
  }
  let i = 0;
  for (const row of rows) { emitRow(`native:${i}`, null, row, true); i++; } // 任意形は raw で出す
  // query-end。強制適用時のみ tenantScoped:true を additive に追記（監査信号・S7）。
  queryEnd({ count: rows.length, complete: !truncated, truncated, nextCursor: null, dest,
    dedupeApplied: false, native: true, ...(scoped ? { tenantScoped: true } : {}) });
  process.exit(0);
}

function runAggregate(aargs, G) {
  const { queryEnd, emitAggRow, queryError } = G.createReadKit(PLUGIN);
  // --name は query と同じ sqlite 固有フィルタ（extraFlags 方式）。MCP ブリッジは filter:true 宣言を
  // query/aggregate 両ツールへ転送するため、aggregate でも受理しないと <plugin>_aggregate で E_ARGS になる。
  // parseAggregateArgs は既に extraFlags 口を持つ（gemba-read.js は変更しない）。
  const opts = G.parseAggregateArgs(aargs, { "--db": "db", "--table": "table" }, queryError,
    { "--name": { key: "name" } });
  if (!opts.db) queryError("E_ARGS", "--db <path> is required", "集計対象の SQLite DB", 2);
  if (!opts.table) opts.table = "reports";
  if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(opts.table)) queryError("E_ARGS", `invalid table name: ${opts.table}`, null, 2);

  let dbp = opts.db;
  if (dbp.startsWith("~/")) dbp = resolve(homedir(), dbp.slice(2));
  dbp = resolve(dbp);
  const dest = `sqlite:${dbp}#${opts.table}`;

  const fs = require("node:fs");
  if (!fs.existsSync(dbp)) queryError("E_NOT_FOUND", `database not found: ${dbp}`, "配信が一度も成功していない可能性があります", 1, dest);

  const { DatabaseSync } = require("node:sqlite");
  let db;
  try { db = new DatabaseSync(dbp, { readOnly: true }); }
  catch (e) { queryError("E_CONNECT", `cannot open read-only: ${e.message}`, "WAL の場合は配信中でないか確認", 1, dest); }

  try {
    const t = db.prepare("SELECT name FROM sqlite_master WHERE type='table' AND name=?").get(opts.table);
    if (!t) { db.close(); queryError("E_NOT_FOUND", `table not found: ${opts.table}`, null, 1, dest); }
  } catch (e) { try { db.close(); } catch {} queryError("E_INTERNAL", e.message, null, 1, dest); }

  // ── 次元（group_by）→ SELECT 式。未宣言フィールドは拒否・scoped では PII 次元を拒否（多層）──
  const dimSelects = [], dimKeys = [], groupExprs = [];
  for (const g of opts.groupBy) {
    const meta = FIELD_META[g.field];
    if (!meta) { db.close(); queryError("E_ARGS", `未宣言のフィールドは次元にできません: ${g.field}`, "schema.fields の正準名のみ", 2, dest); }
    if (opts.noPiiDimensions && meta.pii) { db.close(); queryError("E_ARGS", `PII 宣言フィールドは次元(group_by)に使えません（テナント分離セッション）: ${g.field}`, "集計でも値集合が露出するため", 2, dest); }
    if (g.kind === "field") {
      dimKeys.push(g.field);
      dimSelects.push(`"${meta.col}" AS "${g.field}"`);
      groupExprs.push(`"${meta.col}"`);
    } else { // date_bucket
      if (!meta.datetime) { db.close(); queryError("E_ARGS", `date_bucket は datetime フィールドのみ: ${g.field}`, null, 2, dest); }
      const tz = G.resolveBucketTz(g.tz, meta.timezone, queryError, dest);
      // MVP は「変換なしで扱える組合せ」のみ: 局所壁時計(local)は tz を解釈ゾーンとみなし substr、
      // UTC 格納は UTC バケットのみ substr。UTC×非-UTC バケットは DST 変換が要り zero-dep SQL で不可＝未対応。
      if (meta.timezone === "utc" && tz !== "UTC") {
        db.close();
        queryError("E_UNSUPPORTED", `UTC 格納フィールド(${g.field})の非-UTC(${tz})バケットは未対応（MVP）`, "tz=UTC にするか局所時刻フィールドを使う", 2, dest);
      }
      const len = G.bucketSubstrLen(g.granularity);
      const key = `${g.field}_${g.granularity}`;
      dimKeys.push(key);
      dimSelects.push(`substr("${meta.col}", 1, ${len}) AS "${key}"`);
      groupExprs.push(`substr("${meta.col}", 1, ${len})`);
    }
  }

  // ── 指標（measure）→ SELECT 式（count/count_distinct/sum/avg・全て数値）──
  const measSelects = [], measKeys = [];
  for (const m of opts.measures) {
    let expr;
    if (m.op === "count") expr = "COUNT(*)";
    else {
      const meta = FIELD_META[m.field];
      if (!meta) { db.close(); queryError("E_ARGS", `未宣言のフィールドは指標にできません: ${m.field}`, "schema.fields の正準名のみ", 2, dest); }
      const c = `"${meta.col}"`;
      expr = m.op === "count_distinct" ? `COUNT(DISTINCT ${c})`
        : m.op === "sum" ? `SUM(CAST(${c} AS REAL))`
        : `AVG(CAST(${c} AS REAL))`; // avg
    }
    measSelects.push(`${expr} AS "${m.alias}"`);
    measKeys.push(m.alias);
  }

  // 出力キー（次元＋指標 alias）は一意でなければならない。衝突すると `AS "x" … AS "x"` となり
  // node:sqlite の .all() が同名列を1プロパティに畳んで次元値が指標値で上書きされる（出力破壊・P2）。
  const allKeys = [...dimKeys, ...measKeys];
  const dupKey = allKeys.find((k, i) => allKeys.indexOf(k) !== i);
  if (dupKey) { db.close(); queryError("E_ARGS", `出力キーが重複しています: ${dupKey}`, "group_by 次元と measure alias は一意にする（measure に別名 as を付ける）", 2, dest); }

  // ── WHERE（query と同一のフィルタ＋テナント厳格絞り §3.9）──
  const where = [], bind = [];
  if (opts.endpointFp) {
    if (hasColumn(db, opts.table, "endpoint_fp")) { where.push("endpoint_fp = ?"); bind.push(opts.endpointFp); }
    else where.push("0 = 1");
  }
  const tcol = opts.timeField === "updated" ? "update_time" : opts.timeField === "registered" ? "regist_time" : "loaded_at";
  const bounds = G.timeBounds(opts, tcol === "loaded_at" ? "iso" : "slash", queryError, dest);
  if (bounds?.gte) { where.push(`${tcol} >= ?`); bind.push(bounds.gte); }
  if (bounds?.lt) { where.push(`${tcol} < ?`); bind.push(bounds.lt); }
  if (opts.deleted != null) { where.push("deleted = ?"); bind.push(opts.deleted ? 1 : 0); }
  if (opts.ids && opts.ids.length) { where.push(`idempotency_key IN (${opts.ids.map(() => "?").join(",")})`); bind.push(...opts.ids); }
  if (opts.itemIds.length) { where.push(`item_id IN (${opts.itemIds.map(() => "?").join(",")})`); bind.push(...opts.itemIds); }
  // 帳票名称の部分一致（query と同一述語・escapeLike を共用）。名前で絞った集計はテナント述語と AND される。
  if (opts.name) { where.push("name LIKE '%' || ? || '%' ESCAPE '\\'"); bind.push(escapeLike(opts.name)); }
  const whereSql = where.length ? `WHERE ${where.join(" AND ")}` : "";

  // ── ORDER BY（top-N の決定性）。by は measure alias か dimension key のみ ──
  let orderSql;
  if (opts.orderBy && opts.orderBy.by) {
    if (![...measKeys, ...dimKeys].includes(opts.orderBy.by)) {
      db.close(); queryError("E_ARGS", `--order-by の対象が不明: ${opts.orderBy.by}`, "measure alias か group_by 次元名", 2, dest);
    }
    orderSql = `ORDER BY "${opts.orderBy.by}" ${opts.orderBy.dir === "asc" ? "ASC" : "DESC"}`;
  } else {
    orderSql = `ORDER BY ${dimKeys.map((k) => `"${k}"`).join(", ")} ASC`; // 既定は次元昇順（安定・再現的）
  }

  // limit+1 で取得し超過を truncated 判定（切り捨て群は order で決まる＝§limit 決定性）。
  const sql = `SELECT ${[...dimSelects, ...measSelects].join(", ")} FROM "${opts.table}" ${whereSql} GROUP BY ${groupExprs.join(", ")} ${orderSql} LIMIT ?`;
  let rows;
  try { rows = db.prepare(sql).all(...bind, opts.limit + 1); }
  catch (e) { db.close(); queryError("E_INTERNAL", e.message, null, 1, dest); }
  db.close();

  const truncated = rows.length > opts.limit;
  if (truncated) rows = rows.slice(0, opts.limit);
  for (const r of rows) {
    const dimensions = {}, measures = {};
    for (const k of dimKeys) dimensions[k] = dimVal(r[k]);
    for (const k of measKeys) measures[k] = measVal(r[k]);
    emitAggRow(dimensions, measures);
  }
  queryEnd({ count: rows.length, complete: !truncated, truncated, nextCursor: null, dest,
    aggregate: true, groupBy: dimKeys, measures: measKeys });
  process.exit(0);
}

// ── 引数解析 ─────────────────────────────────────────────────────────
let dbPath = "", table = "reports", dryRun = false, endpointFpFlag = "";
for (let i = 0; i < argv.length; i++) {
  switch (argv[i]) {
    case "--db":      dbPath = argv[++i] ?? ""; break;
    case "--table":   table = argv[++i] ?? "reports"; break;
    case "--dry-run": dryRun = true; break;
    // 配信元テナント指紋のフォールバック刻印値（gemba-adc/1.1）。各レコードが provenance を
    // 持たない（旧マニフェスト等）ときの保険。通常はレコードの provenance.endpointFingerprint を優先。
    case "--endpoint-fp": endpointFpFlag = (argv[++i] ?? "").trim(); break;
    default:
      console.error(`unknown option: ${argv[i]}`);
      process.exit(2);
  }
}
// dry-run は --db 未指定でも入力検証だけ行える (i-repo plugin verify が使う経路)
if (!dbPath && !dryRun) { console.error("--db <path> is required"); process.exit(2); }
// テーブル名はSQLに直接埋まるため識別子として検証する
if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(table)) {
  console.error(`invalid table name: ${table}`);
  process.exit(2);
}

if (dbPath.startsWith("~/")) dbPath = resolve(homedir(), dbPath.slice(2));
if (dbPath) dbPath = resolve(dbPath);

const jobId = `sqlite-${new Date().toISOString().replace(/[-:T]/g, "").slice(0, 15)}-${process.pid}`;

const receipt = (phase, count, failedCount, verified, extra = {}) => {
  process.stdout.write(JSON.stringify({
    schemaVersion: "1.0", recordType: "receipt", plugin: PLUGIN,
    producedBy: { plugin: PLUGIN, version: VERSION },
    phase, jobId, count, failedCount, verified,
    dest: `sqlite:${dbPath}#${table}`,
    ...(dryRun ? { dryRun: true } : {}),
    ...extra,
  }) + "\n");
};

// ── stdin を読み切り、stream-end トレーラを照合（SCHEMA.md §2.6） ────
async function readStdin() {
  const chunks = [];
  for await (const c of process.stdin) chunks.push(c);
  return Buffer.concat(chunks).toString("utf8");
}

(async () => {
  const text = await readStdin();
  const lines = text.split("\n").map((l) => l.trim()).filter(Boolean);

  const records = [];
  let trailer = null;
  let envelopes = 0;
  for (const line of lines) {
    let obj;
    try { obj = JSON.parse(line); }
    catch { records.push({ _raw: line }); continue; }   // 素のJSONでない行も件数には数える
    if (obj && obj.schemaVersion) envelopes++;
    if (obj && obj.recordType === "stream-end") { trailer = obj; continue; }
    records.push(obj);
  }

  // トレーラ照合: あれば count 一致が必須。封筒行があるのに無ければ不完全。
  if (trailer) {
    if (typeof trailer.count !== "number" || trailer.count !== records.length) {
      console.error(`❌ incomplete stream: trailer count=${trailer.count ?? "unreadable"} but received ${records.length} record line(s)`);
      receipt("write", records.length, records.length, false);
      process.exit(1);
    }
  } else if (envelopes > 0) {
    console.error("❌ truncated stream: envelope records present but no stream-end trailer");
    receipt("write", records.length, records.length, false);
    process.exit(1);
  }

  if (dryRun) {
    receipt("write", records.length, 0, false);
    console.error(`(dry-run) would upsert ${records.length} record(s) → ${dbPath} [${table}]`);
    process.exit(0);
  }

  // ── 書き込み（write 相）: idempotencyKey で UPSERT ─────────────────
  const { DatabaseSync } = require("node:sqlite");
  const db = new DatabaseSync(dbPath);
  db.exec("PRAGMA journal_mode=WAL");
  db.exec(`CREATE TABLE IF NOT EXISTS "${table}" (
    idempotency_key TEXT PRIMARY KEY,
    record_type     TEXT,
    item_id         TEXT,
    rev_no          TEXT,
    name            TEXT,
    deleted         INTEGER,
    regist_time     TEXT,
    update_time     TEXT,
    raw_json        TEXT NOT NULL,
    loaded_at       TEXT NOT NULL,
    endpoint_fp     TEXT
  )`);
  // 既存テーブル（endpoint_fp 導入前）への後方互換マイグレーション（gemba-adc/1.1）。
  // 列が無ければ足す。既存行の endpoint_fp は NULL のまま＝厳格 query で「未タグ＝除外」になる。
  if (!hasColumn(db, table, "endpoint_fp")) db.exec(`ALTER TABLE "${table}" ADD COLUMN endpoint_fp TEXT`);
  db.exec(`CREATE INDEX IF NOT EXISTS "idx_${table}_item" ON "${table}"(item_id)`);
  db.exec(`CREATE INDEX IF NOT EXISTS "idx_${table}_efp" ON "${table}"(endpoint_fp)`);

  const stmt = db.prepare(`INSERT INTO "${table}"
    (idempotency_key, record_type, item_id, rev_no, name, deleted, regist_time, update_time, raw_json, loaded_at, endpoint_fp)
    VALUES (?,?,?,?,?,?,?,?,?,?,?)
    ON CONFLICT(idempotency_key) DO UPDATE SET
      record_type=excluded.record_type, item_id=excluded.item_id, rev_no=excluded.rev_no,
      name=excluded.name, deleted=excluded.deleted, regist_time=excluded.regist_time,
      update_time=excluded.update_time, raw_json=excluded.raw_json, loaded_at=excluded.loaded_at,
      endpoint_fp=COALESCE(excluded.endpoint_fp, "${table}".endpoint_fp)`);

  const now = new Date().toISOString();
  let failed = 0;
  const keys = [];
  db.exec("BEGIN");
  for (let i = 0; i < records.length; i++) {
    const r = records[i];
    try {
      const v = r.values ?? r;
      const key = r.idempotencyKey ?? `${jobId}:${i}`;   // キーが無い行も一意に保存
      // テナント指紋: レコード自身の provenance（マニフェスト由来・SSOT）を最優先。無ければ
      // load フラグ（--endpoint-fp）で補完。どちらも無ければ NULL（＝厳格 query で除外・gemba-adc/1.1）。
      const efp = r.provenance?.endpointFingerprint || endpointFpFlag || null;
      stmt.run(
        key,
        r.recordType ?? null,
        String(r.itemId ?? v.itemId ?? ""),
        String(r.revNo ?? v.revNo ?? ""),
        v.name ?? null,
        r.deleted === true ? 1 : 0,
        v.registTime ?? null,
        v.updateTime ?? null,
        JSON.stringify(r),
        now,
        efp
      );
      keys.push(key);
    } catch (e) {
      failed++;
      console.error(`row ${i}: ${e.message}`);
    }
  }
  db.exec("COMMIT");
  receipt("write", records.length, failed, false);

  // ── 読み戻し検証（verify 相）: 今回のキーが全件 DB に存在するか ────
  const placeholders = keys.map(() => "?").join(",");
  const got = keys.length
    ? db.prepare(`SELECT COUNT(*) AS n FROM "${table}" WHERE idempotency_key IN (${placeholders})`).get(...keys).n
    : 0;
  const verified = failed === 0 && got === keys.length;
  receipt("verify", records.length, failed, verified, { verifiedRows: got });
  db.close();
  process.exit(verified ? 0 : 1);
})().catch((e) => {
  console.error(`${PLUGIN}: ${e.message}`);
  receipt("write", 0, 0, false);
  process.exit(1);
});
