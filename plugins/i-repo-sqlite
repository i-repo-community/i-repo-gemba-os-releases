  const cap = opts.limit; // 行数キャップ（§9.6・parseQueryArgs が 1..1000 clamp 済み）
  const byteCap = 1_000_000; // 結果サイズ上限 1MB（§9.6／ADC §6.4）。幅広行のメモリ/コンテキスト膨張を防ぐ。
  let timeoutMs = parseInt(opts.nativeTimeoutMs ?? "", 10); // 実行タイムアウト（§9.6）
