#!/usr/bin/env node
/**
 * i-repo-sqlite — sink plugin: accumulate i-repo NDJSON records into a local
 * SQLite database (BI Ready / 検索・分析の入口).
 *
 * ZERO DEPENDENCIES: uses node:sqlite (Node >= 22.5) only. Cross-platform.
 *   install: copy to ~/.i-repo/plugins/i-repo-sqlite && chmod +x
 *   Windows: also copy i-repo-sqlite.cmd shim
 *
 * Usage:
 *   i-repo rep list --format ndjson | i-repo sqlite --db ~/irepo-warehouse.db
 *   cat manifests/reports.ndjson    | i-repo sqlite --db ./wh.db --table reports
 *
 * Contract (docs/PLUGINS.md / SCHEMA.md):
 *   - reserved flags --plugin-schema / --plugin-healthcheck
 *   - IREPO_PLUGIN_API version check (exit 11 on mismatch)
 *   - stream-end trailer validation (§2.6): trailer count must match received
 *     record lines; envelope records without trailer = truncated → fail
 *   - receipts on stdout in the frozen §6 shape: write → verify phases.
 *     verify re-reads the DB and compares counts; only verified:true receipts
 *     may be used as a cleanup precondition.
 *   - idempotent: records UPSERT by idempotencyKey — re-runs do not duplicate.
 */
"use strict";

const PLUGIN = "i-repo-sqlite";
const VERSION = "0.5.0";

// ── 予約フラグ: プラグイン自身の引数より先に判定 ──────────────────────
const argv = process.argv.slice(2);
const { homedir } = require("node:os");
const { resolve } = require("node:path");

/** テーブルに指定列があるか（PRAGMA table_info）。endpoint_fp の有無判定を write/query で共有する。 */
function hasColumn(db, table, col) {
  try { return db.prepare(`PRAGMA table_info("${table}")`).all().some((c) => c.name === col); }
  catch { return false; }
}

/**
 * LIKE のワイルドカード（%・_）とエスケープ文字（\）を無効化する（--name 部分一致で使用）。
 * 呼び出し側は `name LIKE '%' || ? || '%' ESCAPE '\'` 相当のバインド値としてこの戻り値を使い、
 * ユーザ入力に含まれる %・_ を「リテラル文字」として扱わせる（入力が全件マッチのワイルドカードに
 * 化けるのを防ぐ）。repo に前例なし・流用可能ヘルパーもないため i-repo-sqlite 内に新規追加。
 */
function escapeLike(s) {
  return String(s).replace(/[\\%_]/g, (c) => "\\" + c);
}

// ── 構造化集計 aggregate（gemba-adc/1.2）で参照する正準名→列/属性の唯一の宣言源
// （--plugin-schema の dataset.fields と一致）。aggregate の次元/指標はここに在るフィールドのみ
// 参照可（未宣言＝E_ARGS＝越境穴を宣言駆動で封鎖）。dispatch より前に初期化する（TDZ 回避）。
const FIELD_META = {
  idempotencyKey: { col: "idempotency_key" },
  recordType: { col: "record_type" },
  itemId: { col: "item_id" },
  revNo: { col: "rev_no" },
  name: { col: "name", pii: true },
  deleted: { col: "deleted" },
  registTime: { col: "regist_time", datetime: true, timezone: "local" },
  updateTime: { col: "update_time", datetime: true, timezone: "local" },
  loadedAt: { col: "loaded_at", datetime: true, timezone: "utc" },
  endpointFp: { col: "endpoint_fp" },
};
const dimVal = (v) => (typeof v === "bigint" ? Number(v) : v);          // 次元値: string|number|boolean|null
const measVal = (v) => (v == null ? 0 : Number(v));                     // 指標値: 数値（null は 0）

if (argv[0] === "--plugin-schema") {
