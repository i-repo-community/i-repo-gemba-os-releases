    // 各タグの詳細（dialect/audience 等）は capabilityDetails で宣言する（ホストはそちらを読む）。
    capabilities: ["native-query"],
    // ── T2: ネイティブクエリ能力（仕様 §9）。query --native '<SQL>' で SELECT/WITH を素通し実行。
