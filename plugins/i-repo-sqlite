}

if (argv[0] === "--plugin-healthcheck") {
  let ok = true, hint = "";
  try { require("node:sqlite"); }
  catch { ok = false; hint = "Node 22.5+ が必要です（node:sqlite 内蔵モジュール）"; }
  process.stdout.write(JSON.stringify({
    ok,
    checks: [{ name: "node-sqlite", ok, severity: "required",
               hint: hint || "node:sqlite is available" }],
  }) + "\n");
  process.exit(ok ? 0 : 1);
}

// ── 契約バージョン確認: 非対応なら stderr + exit 11 ──────────────────
if (process.env.IREPO_PLUGIN_API && process.env.IREPO_PLUGIN_API !== "1") {
  console.error(`${PLUGIN}: unsupported IREPO_PLUGIN_API=${process.env.IREPO_PLUGIN_API} (supported: 1)`);
  process.exit(11);
}

// ── query サブコマンド（ADC-1 / gemba-read/1.0・読み取り専用） ─────────
// 共通部（envelope/時刻3形式/カーソル/フラグ解析）は lib/gemba-read.js（正本: plugins/lib/）。
// ここにはストア固有部（SQLite読み取り・record復元・dest）だけを置く。
if (argv[0] === "query") {
  let G;
  try { G = require("./lib/gemba-read.js"); }
  catch {
    console.error(JSON.stringify({ schemaVersion: "1.0", recordType: "error", contract: "gemba-read/1.0",
      plugin: PLUGIN, code: "E_INTERNAL",
      message: "gemba-read ライブラリが見つかりません（lib/gemba-read.js）。plugins/install.sh を再実行してください",
      retryable: false }));
    process.exit(1);
  }
  runQuery(argv.slice(1), G);
  return; // native は worker 非同期完了なので、ここで配信パス（下記）への fall-through を止める
}

// ── aggregate サブコマンド（gemba-adc/1.2・構造化集計・読み取り専用） ─────
// エージェント面に生 SQL を渡さず、次元(group_by)＋指標(measure)で集計する（audience:human 境界を保つ）。
if (argv[0] === "aggregate") {
  let G;
  try { G = require("./lib/gemba-read.js"); }
  catch {
    console.error(JSON.stringify({ schemaVersion: "1.0", recordType: "error", contract: "gemba-read/1.0",
      plugin: PLUGIN, code: "E_INTERNAL",
      message: "gemba-read ライブラリが見つかりません（lib/gemba-read.js）。plugins/install.sh を再実行してください",
      retryable: false }));
    process.exit(1);
  }
  runAggregate(argv.slice(1), G);
  return;
}

function runQuery(qargs, G) {
  const { queryEnd, emitRow, queryError } = G.createReadKit(PLUGIN);
  const opts = G.parseQueryArgs(qargs, { "--db": "db", "--table": "table" }, queryError,
    { "--name": { key: "name" }, "--native": { key: "native" }, "--native-timeout-ms": { key: "nativeTimeoutMs" } });
  if (!opts.db) queryError("E_ARGS", "--db <path> is required", "読み取り対象の SQLite DB", 2);
  if (!opts.table) opts.table = "reports";
  if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(opts.table)) queryError("E_ARGS", `invalid table name: ${opts.table}`, null, 2);

  let dbp = opts.db;
  if (dbp.startsWith("~/")) dbp = resolve(homedir(), dbp.slice(2));
  dbp = resolve(dbp);
  const dest = `sqlite:${dbp}#${opts.table}`;

  const fs = require("node:fs");
  if (!fs.existsSync(dbp)) {
    queryError("E_NOT_FOUND", `database not found: ${dbp}`, "配信が一度も成功していない可能性があります", 1, dest);
  }

  // 読み取り専用 open（§3.7）。失敗は推測せず E_CONNECT。
  const { DatabaseSync } = require("node:sqlite");
  let db;
  try { db = new DatabaseSync(dbp, { readOnly: true }); }
  catch (e) { queryError("E_CONNECT", `cannot open read-only: ${e.message}`, "WAL の場合は配信中でないか確認", 1, dest); }

  // ネイティブクエリ（capability: native-query / 仕様 §9・T2）。--native が「存在」すれば（空でも）
  // native 扱い＝空はバリデータが E_ARGS で弾く（空テキストボックスが通常クエリへ落ちて行を開示する事故防止・Codex P2）。
  // native は自分でテーブルを指定するため table チェックは飛ばす。メイン接続は使わず worker が read-only で再オープン。
  if (opts.native != null) {
    try { db.close(); } catch {}
    runNativeQuery(dbp, opts.native, opts, { queryEnd, emitRow, queryError }, dest);
    return; // runNativeQuery が worker 経由で process.exit する
  }

  try {
    const t = db.prepare("SELECT name FROM sqlite_master WHERE type='table' AND name=?").get(opts.table);
    if (!t) { db.close(); queryError("E_NOT_FOUND", `table not found: ${opts.table}`, null, 1, dest); }
  } catch (e) { try { db.close(); } catch {} queryError("E_INTERNAL", e.message, null, 1, dest); }

  // WHERE 構築。時刻境界は lib が格納形式（loaded=ISO / 業務時刻=slashローカル）へ正規化済み。
  const where = [], bind = [];
  // テナント厳格フィルタ（gemba-adc/1.1 §3.9）: endpoint_fp に完全一致（NULL=未タグは自動除外）。
  // 列が無い旧 DB（endpoint_fp 導入前）では全行が未タグ扱い＝厳格に何も返さない（0=1）。
  // 絞るときだけ列 probe すればよい（未指定なら調べない）。
  if (opts.endpointFp) {
    if (hasColumn(db, opts.table, "endpoint_fp")) { where.push("endpoint_fp = ?"); bind.push(opts.endpointFp); }
    else where.push("0 = 1");
  }
  const col = opts.timeField === "updated" ? "update_time"
    : opts.timeField === "registered" ? "regist_time" : "loaded_at";
  const bounds = G.timeBounds(opts, col === "loaded_at" ? "iso" : "slash", queryError, dest);
  if (bounds?.gte) { where.push(`${col} >= ?`); bind.push(bounds.gte); }
  if (bounds?.lt) { where.push(`${col} < ?`); bind.push(bounds.lt); }
  if (opts.deleted != null) { where.push("deleted = ?"); bind.push(opts.deleted ? 1 : 0); }
  if (opts.ids && opts.ids.length) { where.push(`idempotency_key IN (${opts.ids.map(() => "?").join(",")})`); bind.push(...opts.ids); }
  if (opts.itemIds.length) { where.push(`item_id IN (${opts.itemIds.map(() => "?").join(",")})`); bind.push(...opts.itemIds); }
  // 帳票名称の部分一致（sqlite 固有・extraFlags --name）。中間一致 LIKE '%…%'（%/_ は ESCAPE で
  // リテラル化）＝入力が全件マッチのワイルドカードへ化けない。SQLite 既定照合（ASCII 大小無視）・
  // NFKC 正規化なし・単一語。name NULL 行は LIKE が偽で自然に対象外。テナント述語（endpoint_fp）とは
  // AND で結合されるため tenant-scoped でも安全。索引なし＝フルスキャンだが許容（索引追加はスコープ外）。
  // ここで where[] に足すことで pageWhere コピー（下）にも伝播し keyset ページングと整合する。
  if (opts.name) { where.push("name LIKE '%' || ? || '%' ESCAPE '\\'"); bind.push(escapeLike(opts.name)); }
  const whereSql = where.length ? `WHERE ${where.join(" AND ")}` : "";

  const timeFilter = G.buildTimeFilter(opts);

  if (opts.countOnly) {
    let total = 0;
    try { total = db.prepare(`SELECT COUNT(*) AS n FROM "${opts.table}" ${whereSql}`).get(...bind).n; }
    catch (e) { db.close(); queryError("E_INTERNAL", e.message, null, 1, dest); }
    db.close();
    const end = { count: 0, complete: true, total, nextCursor: null, dest, dedupeApplied: false };
    if (timeFilter) end.timeFilter = timeFilter;
    queryEnd(end);
    process.exit(0);
  }

  // keyset ページング（idempotency_key 昇順・決定的）
  const pageWhere = [...where], pageBind = [...bind];
  if (opts.cursor != null) {
    const last = G.decodeCursor(opts.cursor);
    if (last == null) { db.close(); queryError("E_CURSOR", "カーソルが不正です", "前回の query-end.nextCursor をそのまま渡してください", 2, dest); }
    pageWhere.push("idempotency_key > ?"); pageBind.push(last);
  }
  const pageWhereSql = pageWhere.length ? `WHERE ${pageWhere.join(" AND ")}` : "";

  let rows;
  try {
    rows = db.prepare(
      `SELECT idempotency_key, record_type, raw_json, loaded_at FROM "${opts.table}" ${pageWhereSql} ORDER BY idempotency_key ASC LIMIT ?`
    ).all(...pageBind, opts.limit);
  } catch (e) { db.close(); queryError("E_INTERNAL", e.message, null, 1, dest); }
  db.close();

  let lastKey = null;
  for (const row of rows) {
    lastKey = row.idempotency_key;
    let record;
    try { record = JSON.parse(row.raw_json); }
    catch { record = { _raw: row.raw_json }; }
    let out = record;
    if (!opts.raw && opts.fields && record && record._raw === undefined) out = G.pickFields(record, opts.fields);
    emitRow(row.idempotency_key, row.loaded_at, out, opts.raw);
  }
  const complete = rows.length < opts.limit;
  const end = {
    count: rows.length, complete,
    nextCursor: complete ? null : G.encodeCursor(lastKey),
    dest, dedupeApplied: false,
  };
  if (timeFilter) end.timeFilter = timeFilter;
  queryEnd(end);
  process.exit(0);
}

// ── ネイティブクエリ（T2・capability:native-query / 仕様 §9）─────────────
// ホストは DSL を解釈せず素通し、プラグインがここで read-only を機械強制する。
// 多層防御: (1) DatabaseSync({readOnly:true}) でエンジンが本体DBへの書込/DDLを拒否、
//           (2) 下記バリデータで単一 SELECT/WITH 以外・ATTACH・スタック文・WITH内書込を拒否。
//
// tenant-scoped native（gemba-adc §3.11・--endpoint-fp 併用時）は、上記に加えて childCode 内で
// 全ユーザーテーブルを endpoint_fp = <fp> で絞る TEMP VIEW でシャドウし（無修飾参照が temp 側へ解決＝
// 集計/JOIN/CTE を封じ込め）、下記の scoped バリデータでシャドウ迂回口を塞ぐ。境界はユーザー供給 SQL では
// 外せない。scoped バリデータは **引用状態を追うトークナイザ**で行う（過去、テキストを strip してから regex を
// 当てる方式が文字列リテラル・引用境界を尊重せず越境漏洩を招いた——Codex 再指摘。字句境界を尊重する）。

// ── SQL 字句スキャナ（ゼロ依存・SQLite 字句規則準拠）─────────────────────
// 先頭からトークン化し、文字列 '…'（'' escaped）・識別子 "…"("")／[…]／`…`(``)・行コメント --…／
// ブロックコメント /* … */ をそれぞれの終端規則で 1 トークンとして正しく消費する（コメントと文字列を
// 取り違えない＝リテラル内の -- や /* を実コメントと誤認しない）。ws/コメントは捨てる。
// 返り値 { malformed, tokens }。tokens[]: { kind, name?, quoted? }。
//   kind: 'id'（bare word・"…"・[…]・`…`）| 'str'（'…'）| 'dot' | 'comma' | 'lparen' | 'rparen' | 'num' | 'punct'
//   name: id/str の正規化論理名（二重化エスケープ復元済み・casefold）。quoted: id が引用形なら true。
function readQuotedIdent(s, start, q) {
  let i = start, buf = "";
  const n = s.length;
  while (i < n) {
    if (s[i] === q) { if (s[i + 1] === q) { buf += q; i += 2; continue; } return { text: buf, next: i + 1 }; }
    buf += s[i++];
  }
  return null; // 未終端
}
function tokenizeSqlScoped(sql) {
  const s = String(sql);
  const n = s.length;
  const toks = [];
  let i = 0;
  const idStart = (c) => c === "_" || (c >= "A" && c <= "Z") || (c >= "a" && c <= "z") || c.charCodeAt(0) > 127;
  const idPart = (c) => idStart(c) || c === "$" || (c >= "0" && c <= "9");
  while (i < n) {
    const c = s[i];
    if (c === " " || c === "\t" || c === "\n" || c === "\r" || c === "\f" || c === "\v") { i++; continue; }
    if (c === "-" && s[i + 1] === "-") { i += 2; while (i < n && s[i] !== "\n") i++; continue; } // 行コメント
    if (c === "/" && s[i + 1] === "*") {                                                          // ブロックコメント
      i += 2; let closed = false;
      while (i < n) { if (s[i] === "*" && s[i + 1] === "/") { i += 2; closed = true; break; } i++; }
      if (!closed) return { malformed: true };
      continue;
    }
    if (c === "'") {                                                                              // 文字列リテラル
      i++; let buf = "", closed = false;
      while (i < n) {
        if (s[i] === "'") { if (s[i + 1] === "'") { buf += "'"; i += 2; continue; } i++; closed = true; break; }
        buf += s[i++];
      }
      if (!closed) return { malformed: true };
      toks.push({ kind: "str", name: buf.toLowerCase() });
      continue;
    }
    if (c === '"') { const r = readQuotedIdent(s, i + 1, '"'); if (!r) return { malformed: true }; toks.push({ kind: "id", quoted: true, name: r.text.toLowerCase() }); i = r.next; continue; }
    if (c === "`") { const r = readQuotedIdent(s, i + 1, "`"); if (!r) return { malformed: true }; toks.push({ kind: "id", quoted: true, name: r.text.toLowerCase() }); i = r.next; continue; }
    if (c === "[") {                                                                              // [ … ]（] は escape 不可）
      i++; let buf = "", closed = false;
      while (i < n) { if (s[i] === "]") { i++; closed = true; break; } buf += s[i++]; }
      if (!closed) return { malformed: true };
      toks.push({ kind: "id", quoted: true, name: buf.toLowerCase() });
      continue;
    }
    if (idStart(c)) { let j = i + 1; while (j < n && idPart(s[j])) j++; toks.push({ kind: "id", quoted: false, name: s.slice(i, j).toLowerCase() }); i = j; continue; }
    if (c >= "0" && c <= "9") { let j = i + 1; while (j < n && ((s[j] >= "0" && s[j] <= "9") || s[j] === "_")) j++; toks.push({ kind: "num" }); i = j; continue; }
    if (c === ".") { toks.push({ kind: "dot" }); i++; continue; }
    if (c === ",") { toks.push({ kind: "comma" }); i++; continue; }
    if (c === "(") { toks.push({ kind: "lparen" }); i++; continue; }
    if (c === ")") { toks.push({ kind: "rparen" }); i++; continue; }
    toks.push({ kind: "punct" }); i++;
  }
  return { malformed: false, tokens: toks };
}

// scoped 判定: トークン列を走査し、シャドウ迂回口を拒否理由として返す＋テーブル参照名の集合を返す。
//   R1 スキーマ修飾: 論理名 ∈ {main,temp,sqlite_temp} の識別子/文字列トークンの直後（コメント/空白跨ぎは
//      トークナイザが吸収済み）に `.` が続く（'main'.reports の 5 引用形すべて・Codex P1）。
//   R2 sqlite_ 接頭辞・R3 pragma_ 接頭辞・R4 eponymous 仮想表 dbstat: **識別子トークン**は常に拒否。
//      文字列トークンは **テーブル参照位置のときだけ**拒否する（SQLite は FROM 位置で 'sqlite_master' 等の
//      文字列も識別子として受理して漏らすため／一方 WHERE の 'sqlite_x' 等のデータは通す＝過検知しない）。
//   tableRefs: テーブル参照位置に現れた識別子/文字列の論理名集合（R5 ビュー突合に使う・二重化エスケープ復元済み）。
// fail-closed: 未終端引用/コメント等で字句解析に失敗したら reject。
function analyzeScopedSql(sql) {
  const scan = tokenizeSqlScoped(sql);
  if (scan.malformed) return { ok: false, reason: "字句解析に失敗（引用/コメントの不整合・fail-closed）", tableRefs: new Set() };
  const toks = scan.tokens;
  const SCHEMA = new Set(["main", "temp", "sqlite_temp"]);
  const FROMJOIN = new Set(["from", "join"]);
  // FROM 節（テーブルリスト領域）を終える/切り替えるキーワード。
  const ENDFROM = new Set(["where", "group", "having", "order", "limit", "offset", "window",
    "union", "except", "intersect", "on", "using", "values", "set", "returning", "select", "with"]);
  const dangerReason = (name) =>
    name === "dbstat" ? "eponymous 仮想表 dbstat は不可（シャドウ対象外・R4）"
    : /^pragma_/.test(name) ? "pragma_ table-valued 関数は不可（R3）"
    : "sqlite_ 内部オブジェクト（sqlite_master 等）は不可（R2）";
  const isDanger = (name) => /^sqlite_/.test(name) || /^pragma_/.test(name) || name === "dbstat";
  const tableRefs = new Set();
  let inFrom = false, expectTable = false, reason = null;
  const stack = [];
  for (let k = 0; k < toks.length; k++) {
    const t = toks[k];
    // '(' はテーブル位置文脈を括弧内へ引き継ぐ（SQLite の table-or-subquery は `'(' table-or-subquery ')'` を許す。
    // 括弧内先頭が SELECT/WITH/VALUES ならサブクエリとして ENDFROM でリセット、テーブル/ビュー名なら tableRefs へ
    // 記録して R5 が捕捉する）。expectTable をリセットしないのが要点＝括弧付きビュー参照 `(view)` の取りこぼし防止。
    if (t.kind === "lparen") { stack.push([inFrom, expectTable]); inFrom = false; continue; }
    if (t.kind === "rparen") { const st = stack.pop(); inFrom = st ? st[0] : false; expectTable = false; continue; }
    if (t.kind === "comma") { if (inFrom) expectTable = true; continue; }
    if (t.kind !== "id" && t.kind !== "str") continue; // dot/num/punct は素通し（FSM に影響しない）
    // bare 識別子のみがキーワードたり得る（"from" 等の引用/文字列はキーワードでない）
    if (t.kind === "id" && !t.quoted) {
      if (FROMJOIN.has(t.name)) { inFrom = true; expectTable = true; continue; }
      if (ENDFROM.has(t.name)) { inFrom = false; expectTable = false; continue; }
    }
    // R1 スキーマ修飾（直後が dot）
    if (SCHEMA.has(t.name) && toks[k + 1] && toks[k + 1].kind === "dot") {
      reason = reason || `スキーマ修飾（${t.name}.）は不可（テナント閉じ込め迂回防止 R1）`;
    }
    // R2/R3/R4 危険識別子（id は常に・str はテーブル参照位置のみ）
    if (isDanger(t.name) && (t.kind === "id" || expectTable)) reason = reason || dangerReason(t.name);
    // テーブル参照位置の実名を記録（修飾子直後 dot のときは実名待ちで expectTable 継続）
    if (expectTable) {
      const nextIsDot = toks[k + 1] && toks[k + 1].kind === "dot";
      if (!nextIsDot) { tableRefs.add(t.name); expectTable = false; }
    }
  }
  return { ok: !reason, reason, tableRefs };
}

function validateReadOnlySql(sql, { scoped = false } = {}) {
  const s = String(sql || "").trim().replace(/;+\s*$/, ""); // 末尾セミコロン除去
  if (!s) return { ok: false, reason: "空のクエリ" };
  if (s.includes(";")) return { ok: false, reason: "複数文は不可（; 区切りのスタック）" };
  if (!/^(select|with)\b/i.test(s)) return { ok: false, reason: "SELECT / WITH で始まる単一文のみ" };
  if (/\b(attach|detach)\b/i.test(s)) return { ok: false, reason: "ATTACH/DETACH は不可（read-only バイパス防止）" };
  if (/^with\b/i.test(s) && /\b(insert|update|delete|replace)\b/i.test(s)) {
    return { ok: false, reason: "WITH 内の書込文は不可" };
  }
  // ── ここまでは非 scoped native と完全に同一（1ビットも変えない）。以降は scoped 時のみ ──
  // scoped 追加規則（R1〜R4）は analyzeScopedSql（引用状態を追うトークナイザ）で判定する。文字列リテラル内の
  // -- や /* を実コメントと誤認しない・データ文字列内の main./sqlite_/dbstat を過検知しない（Codex 再指摘の核）。
  // R5（ビュー参照拒否）はビュー名一覧が要るため runNativeQuery 側で analyzeScopedSql().tableRefs を使って行う。
  if (scoped) {
    const a = analyzeScopedSql(s);
    if (!a.ok) return { ok: false, reason: a.reason };
  }
  return { ok: true, sql: s };
}

function runNativeQuery(dbp, rawSql, opts, kit, dest) {
  const { queryEnd, emitRow, queryError } = kit;

  // テナント閉じ込め経路の判定（gemba-adc §3.11）。--endpoint-fp があれば scoped。
  const scoped = !!opts.endpointFp;
