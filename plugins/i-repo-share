async function main() {
  const [command, ...rest] = process.argv.slice(2);
  if (command === "put-catalog-s3") return putCatalog(parsePutArgs(rest, S3_BACKEND), S3_BACKEND);
  if (command === "put-catalog-gcs") return putCatalog(parsePutArgs(rest, GCS_BACKEND), GCS_BACKEND);
  if (command === "put-catalog-azure") return putCatalog(parsePutArgs(rest, AZURE_BACKEND), AZURE_BACKEND);
  if (command === "put-catalog-local") return putCatalog(parsePutArgs(rest, LOCAL_BACKEND), LOCAL_BACKEND);
  if (command === "push-snapshot-s3") return pushSnapshot(parsePushSnapshotArgs(rest, S3_BACKEND), S3_BACKEND);
  if (command === "push-snapshot-gcs") return pushSnapshot(parsePushSnapshotArgs(rest, GCS_BACKEND), GCS_BACKEND);
  if (command === "push-snapshot-azure") return pushSnapshot(parsePushSnapshotArgs(rest, AZURE_BACKEND), AZURE_BACKEND);
  if (command === "push-snapshot-local") return pushSnapshot(parsePushSnapshotArgs(rest, LOCAL_BACKEND), LOCAL_BACKEND);
  if (command === "pull-azure") return pullShare(parsePullArgs(rest, AZURE_PULL), AZURE_PULL);
  if (command === "pull-s3") return pullShare(parsePullArgs(rest, S3_PULL), S3_PULL);
  if (command === "pull-gcs") return pullShare(parsePullArgs(rest, GCS_PULL), GCS_PULL);
  if (command === "pull-local") return pullShare(parsePullArgs(rest, LOCAL_PULL), LOCAL_PULL);
  usage();
  process.exitCode = command === undefined || command === "--help" || command === "-h" ? 0 : 2;
}

