// ── Contract version check: unsupported → stderr + exit 11 ──
const announcedApi = process.env.IREPO_PLUGIN_API;
if (arg0 !== "--plugin-healthcheck" && announcedApi && announcedApi !== PLUGIN_API) {
  console.error(`${PLUGIN}: unsupported IREPO_PLUGIN_API=${announcedApi} (supported: ${PLUGIN_API})`);
  process.exit(11);
}

// Promise.resolve() でモジュール評価の完了後に起動する（main は async でも本文の先頭は
// 同期実行されるため、直接呼ぶと後方で const 宣言している backend が TDZ になる）。
if (arg0 === "--plugin-healthcheck") {
  Promise.resolve().then(healthcheck).then((ok) => process.exit(ok ? 0 : 1));
} else {
  Promise.resolve().then(main).catch((error) => {
    console.error(`${PLUGIN}: ${error instanceof Error ? error.message : String(error)}`);
    // usageError=2 / preconditionError=3 / それ以外の実行時失敗=1（verify 不達も main が 1 を立てる）。
    process.exitCode = (error && error.exitCode) || 1;
  });
}

// 使い方・入力検証の失敗（呼び出し側が引数/入力を直せば解決するもの）は exit 2 に分類する。
function usageError(message) {
  return Object.assign(new Error(message), { exitCode: 2 });
}
// CAS の precondition 失敗（412/PreconditionFailed）。専用コード 3 で 0/1/2 と機械判別可能にする。
// メッセージ先頭を E_PRECONDITION にして stderr から grep できる形にする（spec §9.1）。
function preconditionError(message) {
  return Object.assign(new Error(`E_PRECONDITION: ${message}`), { exitCode: 3 });
}
// ストア状態起因の失敗（pull・exit 1）: DL 失敗・更新中再読後も sha256 不一致・取得目次の契約違反
// （fail-closed / schema 核 / SI-1 読み手版 / SI-7）・verify 不達・目次に無い --dataset。呼び出し側が
// 引数を直しても解決しない（＝exit 2 ではない）ものを 1 に分類する（spec §9.2.5 exit 表）。
function storeError(message) {
  return Object.assign(new Error(message), { exitCode: 1 });
}

async function healthcheck() {
  // クラウド CLI は各サブコマンド専用 — severity でスコープを示す。必須依存はゼロ
  // （local は Node fs のみ・pull-azure は内蔵 fetch）なので全体 ok は常に true。
  const checks = [];
  checks.push({
    name: "aws-cli", ok: await commandExists("aws", ["--version"]), severity: "required-for:put-catalog-s3,push-snapshot-s3,pull-s3,issue-ticket-s3,revoke-ticket-s3,presign-s3",
    hint: "Install AWS CLI v2 to use put-catalog-s3 / push-snapshot-s3 / pull-s3 / issue-ticket-s3 / revoke-ticket-s3 / presign-s3 (revoke-ticket-s3 uses aws only to CAS-update revoked.json)",
  });
  checks.push({
    name: "gcloud-cli", ok: await commandExists("gcloud", ["--version"]), severity: "required-for:put-catalog-gcs,push-snapshot-gcs,pull-gcs,issue-ticket-gcs,revoke-ticket-gcs",
    hint: "Install Google Cloud SDK (gcloud) to use put-catalog-gcs / push-snapshot-gcs / pull-gcs / issue-ticket-gcs / revoke-ticket-gcs (revoke-ticket-gcs deletes the SA key and updates revoked.json)",
  });
  // presign-gcs は gcloud ではなく gsutil（Cloud SDK 同梱）を使う（gcloud storage には signed URL 発行が無い）。
  checks.push({
    name: "gsutil", ok: await commandExists("gsutil", ["version"]), severity: "required-for:presign-gcs",
    hint: "Install the Google Cloud SDK (includes gsutil) to use presign-gcs (gsutil signurl)",
  });
  // az CLI は put-catalog-azure / push-snapshot-azure / issue-ticket-azure / revoke-ticket-azure / presign-azure 専用（pull-azure は az でなく内蔵 fetch を使うため az を要さない）。
  checks.push({
    name: "az-cli", ok: await commandExists("az", ["--version"]), severity: "required-for:put-catalog-azure,push-snapshot-azure,issue-ticket-azure,revoke-ticket-azure,presign-azure",
    hint: "Install Azure CLI (az) to use put-catalog-azure / push-snapshot-azure / issue-ticket-azure / revoke-ticket-azure / presign-azure (revoke-ticket-azure CAS-updates revoked.json)",
  });
  checks.push({
    name: "local-fs", ok: true, severity: "required-for:put-catalog-local,push-snapshot-local,pull-local,issue-ticket-local,revoke-ticket-local,show-pubkey,rotate-key",
    hint: "No external CLI needed (uses Node fs; show-pubkey / rotate-key are fully local)",
  });
  // pull-azure は素の HTTPS 直 GET（elastic の fetch 流儀・§7.2）。Node 内蔵 fetch（>=18）が要る。
  const fetchOk = typeof fetch === "function";
  checks.push({
    name: "node-fetch", ok: fetchOk, severity: "required-for:pull-azure",
    hint: fetchOk ? `Node ${process.version} built-in fetch available`
      : "Node.js 18+ is required for pull-azure (uses built-in fetch)",
  });
  console.log(JSON.stringify({ ok: true, checks }));
  return true;
}

