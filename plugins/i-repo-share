#!/usr/bin/env node
/**
 * i-repo-share — gemba-share の**目次系可変オブジェクト**（share-catalog.json /
 * datasets/<id>/dataset.json / runs/<YYYY-MM>.ndjson）を shareRoot へ **clean に PUT** する
 * egress verb（put-catalog-*）、snapshot 実体（バイナリ .db/.db.gz）を世代キーへ **clean に単発 PUT**
 * する egress verb（push-snapshot-*）、および目次を辿って着地実体を**ローカルへ取り戻す** read-only な
 * pull verb。spec/gemba-share/spec.md §9.1（put-catalog 契約=雛形）/ §9.2（pull 契約）/ §9.6（予約動詞）。
 *
 * 目的: archive push（bundle レイアウト・着地 receipt・manifests を作る）と違い、
 * put-catalog は **1 つの目次系オブジェクトを 1 キーへ置くだけ**。bundle レイアウトも
 * 裏方ファイルも一切作らない。付加価値は「spec の SI（不変条件）を**書込時に強制する**」こと:
 *   - SI-1（portable）: 目次・dataset・run 行にローカル絶対パスを混入させない（書込前に拒否）。
 *   - SI-5（secret 非混入）: credential 値・signed URL 断片・チケット URI を混入させない。
 * fail-loud（違反は書かずに exit 2）で、汚れた目次が shareRoot に着地するのを未然に防ぐ。
 *
 * 【pull 系（pull-azure/pull-s3/pull-gcs/pull-local・§9.2）の設計要点】
 *   - **read-only**: ストアへ write/delete API を一切呼ばない。取得は「1 オブジェクト＝1 GET」のみ
 *     （pull-azure=内蔵 fetch 直 GET・s3=aws s3api get-object・gcs=gcloud storage cp・local=fs コピー）。
 *   - **列挙不要（§7.1）**: object store の list（ListObjects 等）を経路に含めない。既知キー
 *     share-catalog.json を GET し、目次が教える相対キー（dataset.json / snapshot / runs シャード）
 *     だけを 1 個ずつ取りに行く（archive pull の再帰 DL とは違う）。
 *   - **SI-1 読み手版**: 取得目次への全文字列スキャン（put の SI-1/SI-5）は掛けない。読み手は
 *     「自分が dereference するキーだけ」を検証する（REL_KEY_RE 一致・絶対 URL/先頭 /・.. 拒否・
 *     join(out,key) 後の containment。local は source 側 containment も）。違反は exit 1（ストア汚染）。
 *   - **更新中（§3.4）**: 目次記載 sha256 と取得実体の sha256 が食い違えば「更新中」とみなし、
 *     IREPO_SHARE_PULL_RETRY_MS 待って目次から丸ごと再読（プロセス全体で 1 回）。なお不一致は exit 1。
 *   - **.gz 再水和（§4.3）**: snapshot .db.gz は .gz バイトで sha256 照合後 node:zlib で展開し .db
 *     のみ着地（.gz は残さない）。materialize は実体→dataset.json→runs→**最後に目次**（§3.4 の鏡映）。
 *   - **secret 非露出（§8.1/SI-5）**: SAS/credential を receipt・stderr のどこにも出さない
 *     （エラー表示は URL の query を落とす。elastic の fetch マスク流儀・§7.2）。
 *
 * 【push-snapshot 系（push-snapshot-s3/gcs/azure/local・spec §4.2/§9.3/§9.6・#147）の設計要点】
 *   - archive push（bundle レイアウト・manifests/receipts マーカーを撒く）と違い、snapshot 実体
 *     （バイナリ .db / .db.gz）1 個を世代キー `datasets/<id>/snapshot-<compactUTC>[-<suffix>].db[.gz]`
 *     へ **単発 PUT する**だけ。裏方ファイル（manifests/ ・receipts/）を一切作らない clean PUT。
 *   - **--key（世代キー）必須・既定なし**: relKey 文法（REL_KEY_RE）＋ §2 snapshot キー文法
 *     （SNAPSHOT_KEY_RE）で検証。世代キーは一意ゆえ `--if-none-match`（新規のみ作成）を推奨する。
 *   - **generation の前進（目次 share-catalog.json の再 PUT）は行わない**: それは put-catalog で
 *     owner writer が行う（§6.2.2 の owner 責務・DC 分担・#147）。push-snapshot は実体 PUT＋verify まで。
 *   - **書込前検査はバイナリ向け**: JSON/SI-1/SI-5 の内容スキャンはしない。代わりに (a) ファイル存在・
 *     非空 (b) キー文法 (c) `.gz` キーなのに gzip マジック(1f 8b)でない／逆＝非 .gz キーなのに gzip
 *     内容、を exit 2 で弾く（.db/.db.gz 取り違え防止）。
 *   - **sourceDigest（#142 前倒し）**: 素の .db は sourceDigest=sha256 と同値。.gz はストリーム gunzip →
 *     非圧縮 .db の sha256 を sourceDigest に併記（sha256 は転送物＝.gz バイトに対して計算）。壊れた gz は
 *     gunzip 失敗で exit 2。DC は目次エントリの generation.sourceDigest にそのまま転記できる。
 *   - PUT／verify／exit 規約／CAS 配管／認証は put-catalog（§9.1）と同型（backend put/stat 流用）。
 *
 * 【SI-1/SI-5 検査ロジックは「第2実装」である旨の注記】
 * 下の findPortabilityViolations / findSecretViolations は scripts/check-share.mjs の
 * SH3/SH4（findPortabilityViolations / findSecretViolations）と**同じ判定**を持つ。
 * プラグインはゼロ依存・単体コピー配布（~/.i-repo/plugins/ へ本体と lib/ だけコピーされて動く）
 * なので check-share.mjs から import できない — 配布制約ゆえの自己完結コピーである。
 * **正本は scripts/check-share.mjs 側**（適合ハーネス）。判定を変えるときは両方を同時に直す
 * （.claude/rules/gemba-share-spec.md「三面をセットで動かす」）。
 *
 * 成功判定は receipt `verified:true` のみ（SCHEMA.md §6・stdout NDJSON・§0.1-1）。
 *
 * exit code 規約（put-catalog=spec §9.1・pull=spec §9.2 で契約化）:
 *   0 = 成功（put=verify receipt verified:true／pull=verified:true・unchanged 含む）
 *   1 = put: verify 不達（PUT はしたが read-back の存在／サイズ照合に失敗）／
 *       pull: DL 失敗・更新中再読後も sha256 不一致・取得目次の契約違反（fail-closed/schema 核/
 *       SI-1 読み手版/SI-7）・verify 不達・目次に無い --dataset（ストア状態起因）
 *   2 = 引数・入力検証エラー（put=relKey 文法・SI-1/SI-5 違反・非 JSON/非 NDJSON／
 *       pull=--from/--out 欠落/形式・Azure [?#]・--dataset/--since-generation 文法・使い方）
 *   3 = E_PRECONDITION（put の条件付き書込 CAS の precondition 失敗＝412/PreconditionFailed。
 *       将来の CAS read-merge-write リトライが 0/1/2 と機械判別できる専用コード。**pull では未使用・予約**）
 *   11 = 非対応 IREPO_PLUGIN_API
 *
 * ZERO DEPENDENCIES: node 内蔵 + ./lib/spawn.js（同梱の spawn 正本）のみ。単一ファイル・CJS。
 *   install: ~/.i-repo/plugins/ へ本体と lib/ をコピー && chmod +x
 *
 * Usage:
 *   i-repo share put-catalog-s3    <file> --to s3://bucket/prefix [--key <relKey>] [options]
 *   i-repo share put-catalog-gcs   <file> --to gs://bucket/prefix [--key <relKey>] [options]
 *   i-repo share put-catalog-azure <file> --to https://<acct>.blob.core.windows.net/<container>/<p> [--key <relKey>] [options]
 *   i-repo share put-catalog-local <file> --to <folder|network-share> [--key <relKey>] [options]
 *   i-repo share pull-azure --from https://<acct>.blob.core.windows.net/<container>/<p> --out <dir> [options]
 *   i-repo share pull-s3    --from s3://bucket/prefix --out <dir> [options]
 *   i-repo share pull-gcs   --from gs://bucket/prefix --out <dir> [options]
 *   i-repo share pull-local --from <folder|network-share> --out <dir> [options]
 *   i-repo share push-snapshot-s3    <file.db[.gz]> --to s3://bucket/prefix --key datasets/<id>/snapshot-<compactUTC>.db[.gz] [options]
 *   i-repo share push-snapshot-gcs   <file.db[.gz]> --to gs://bucket/prefix --key … [options]
 *   i-repo share push-snapshot-azure <file.db[.gz]> --to https://<acct>.blob.core.windows.net/<container>/<p> --key … [options]
 *   i-repo share push-snapshot-local <file.db[.gz]> --to <folder|network-share> --key … [options]
 *   i-repo share issue-ticket-s3    --to s3://bucket/prefix --endpoint <url> --dataset ds-… --issued-to <id> --expires <n|ISO> [options]
 *   i-repo share issue-ticket-gcs   --to gs://bucket/prefix --endpoint … --reader-service-account <email> [options]
 *   i-repo share issue-ticket-azure --to https://<acct>.blob.core.windows.net/<container>/<p> --endpoint … [options]
 *   i-repo share issue-ticket-local --to <folder|network-share> --endpoint … [options]
 *   i-repo share revoke-ticket-s3    --to s3://bucket/prefix --jti <uuid> [--list-only] [--reason <r>] [options]
 *   i-repo share revoke-ticket-gcs   --to gs://bucket/prefix --jti <uuid> [--credential-ref <keyId> --reader-service-account <email>] [options]
 *   i-repo share revoke-ticket-azure --to https://<acct>.blob.core.windows.net/<container>/<p> --jti <uuid> [options]
 *   i-repo share revoke-ticket-local --to <folder|network-share> --jti <uuid> [options]
 *   i-repo share presign-s3    --to s3://bucket/prefix --key documents/<file> --expires <n(m|h|d|w)|ISO> [options]
 *   i-repo share presign-gcs   --to gs://bucket/prefix --key documents/<file> --expires <n(m|h|d|w)|ISO> [options]
 *   i-repo share presign-azure --to https://<acct>.blob.core.windows.net/<container>/<p> --key documents/<file> --expires <n(m|h|d|w)|ISO> [options]
 *   i-repo share show-pubkey [--kid k-…]
 *   i-repo share rotate-key
 * push-snapshot は実装済み（#147・実体 PUT＋verify まで）。ls / get は本弾では未実装（spec §11 の Phase 3）。
 *
 * 【issue-ticket 系（issue-ticket-{s3,gcs,azure,local}・show-pubkey・rotate-key・spec §9.7・#472）の設計要点】
 *   - **発行台帳モデル（1 チケット = 1 read-only 資格）**: jti を主キーに、ストア別に read-only 資格を
 *     mint（gcs=SA 鍵・azure=SAS）または既存資格をフォールバック（s3=readonly-key・azure=既存 SAS・local=none）し、
 *     クレーム（sub/iat/exp/jti/endpoint/endpointFp/store/credential/scope）を EdDSA(Ed25519) で署名して
 *     `gemba-share://v1/<JWS>` を発行する。ストア別の mint 可否・失効可否は receipt の `revocation` で正直に申告する
 *     （azure=expiry-only・gcs=individual・s3=shared-credential・local=none）。失効（revoke-ticket）は PR (b)。
 *   - **チケット URI・credential 実値は receipt・ログ・エラーに一切出さない**（SI-5・check-share SH19）。
 *     チケット原文は stdout **最終行**の専用 NDJSON レコード（recordType:"share-ticket"）でのみ返す。receipt は
 *     非 secret メタ（jti/kid/expiresAt/scope/credentialKind/credentialRef?/revocation/publicKeyFingerprint 等）のみ。
 *   - **鍵の保管**: `~/.i-repo/share/keys/<kid>.json`（EdDSA 秘密鍵・0600）・`keys/current.json`（現行 kid）・
 *     `issued/<jti>.json`（非 secret 発行台帳・revoke が読む）。書込は src/config/scoped-store.ts:168-205 の流儀を
 *     自己完結コピー（mkdir 0o700・temp 0o600→rename・chmod 失敗は非致命/Windows no-op）。プラグインは src/ を
 *     import できない（ゼロ依存）ため複製＋正本注記。署名（signJws/signData）は check-share.mjs:292-311 の逐語
 *     コピー（発行 alg は EdDSA 固定）。endpointFp 正規化は check-share.mjs:97-121（正本 docs/SCHEMA.md §2.5a）の逐語コピー。
 *   - **公開鍵の shareRoot 配置**: `keys/<kid>.json`（recordType:"share-key"・公開鍵 JWK のみ）を --if-none-match で
 *     冪等 PUT する（既存は read-back バイト一致で skip・不一致は fail-closed）。真正性は帯域外ピンのみが根拠（§5.4 自己参照封じは不変）。--no-publish-key で省略可。
 *
 * 【revoke-ticket 系（revoke-ticket-{s3,gcs,azure,local}・pull --ticket-jti・spec §9.8/§9.2.2・#472 PR (b)）の設計要点】
 *   - **真の失効は credential 側**（不変）。gcs のみ実失効（`gcloud iam service-accounts keys delete <keyId> --iam-account <sa>`）。
 *     s3/azure/local は資格側操作なし（s3=共有資格・azure=exp＋協調・local=資格概念なし）。receipt に `revocation` と
 *     `credentialRevoked:true|false` を正直に載せる。keyId/SA は発行台帳 issued/<jti>.json（PR (a)）から解決し、`--credential-ref`・
 *     `--reader-service-account` で上書き可。
 *   - **鍵削除の冪等性（#172）**: gcs の SA 鍵 delete が NOT_FOUND（404・鍵が既に無い＝過去の失効の途中終了/環境掃除）を返したら
 *     「既に失効済み」＝失効の目的状態は達成済みとして**冪等成功**扱いにし（credentialRevoked:true＋receipt に credentialAlreadyAbsent:true）、
 *     verify 相も通常どおり通す。分類は gcloud の **stderr（診断）だけ**で行い e.message は使わない（message はフルコマンド＋argv を
 *     前置するため、SA email 等ユーザ制御 argv の "404" 等に誤マッチして false success へ陥る危険がある・#173）。
 *     PERMISSION_DENIED（roles/iam.serviceAccountKeyAdmin 不足、または gcloud の仕様上 **SA 自体の不存在**）は NOT_FOUND と区別して
 *     実因を報告し従来どおり失敗させる。SA 不存在っぽい NOT_FOUND 文言（"unknown service account" 等）も冪等成功にせず失敗させる。
 *   - **協調的失効リスト revoked.json**（shareRoot 直下・recordType:"share-revocations"）: jti を CAS マージ PUT する
 *     （GET→etag→jti 和集合マージ〔同一 jti は revokedAt min 勝ち・同刻 kid 辞書順＝決定的〕→ --if-match/--if-none-match PUT・
 *     bounded read-merge-write リトライ 3 回・3 敗 exit 3・local は temp→rename）。**強制の本体ではなく補助**（§5.5）。
 *   - **pull --ticket-jti**（任意）: 目次 GET 直後に revoked.json を GET し、jti 掲載なら **materialize 前に exit 1**（out 未 commit）。
 *     404→続行（fail-open）・parse 不能/版違い→ stderr 警告のみ続行（強制の本体は資格無効化）。
 *   - secret 衛生（SI-5）: revoked.json・receipt・エラーに credential 実値/チケット URI を載せない（scrubMsg/dropQuery 流儀）。
 *
 * 【presign 系（presign-{s3,gcs,azure}・spec §9.9・#175）の設計要点】
 *   - 1 オブジェクトの短命 signed URL（**GET のみ**）を mint する。PUT/DELETE の署名は発行しない（read-only 境界）。
 *     azure=コンテナ SAS mint（§9.7.3）の object SAS 縮退（az storage blob generate-sas --permissions r --https-only）、
 *     s3=aws s3 presign（per-object・vendor CLI 標準）、gcs=gsutil signurl（signed URL・SA 鍵ファイル必須）。
 *   - **signed URL は secret**（SI-5）: stdout 最終行の専用レコード（recordType:"presigned-url"）でのみ返し、
 *     receipt・ログ・エラーに URL（sig=/X-Amz-Signature=）を一切出さない。消費者は台帳・監査にも残さないこと（§9.9）。
 *   - 資格は既存の書き手 auth フラグを流用（secret は argv でなく env・§8.1）。local は対象外（presign 相手がいない）。
 */
"use strict";

const fs = require("node:fs");
const fsp = require("node:fs/promises");
const zlib = require("node:zlib");
const { pipeline } = require("node:stream/promises");
const { Readable } = require("node:stream");
const { createHash, randomBytes, randomUUID, generateKeyPairSync, sign: cryptoSign } = require("node:crypto");
const { spawn } = require("node:child_process");
const { homedir, tmpdir } = require("node:os");
const { join, dirname, basename, resolve, relative, isAbsolute, sep } = require("node:path");
// 子プロセスの spec 構築は全プラグイン共通の正本 lib/spawn.js に一本化する
// （Windows .cmd シム対応・cmd.exe メタ文字拒否）。spawn 自体はここで非同期に行う。
const { spawnSpec } = require("./lib/spawn.js");

const PLUGIN = "i-repo-share";
const VERSION = "0.6.0";
const PLUGIN_API = "1";

const PUT_SUBS = ["put-catalog-s3", "put-catalog-gcs", "put-catalog-azure", "put-catalog-local"];
const PUSH_SNAP_SUBS = ["push-snapshot-s3", "push-snapshot-gcs", "push-snapshot-azure", "push-snapshot-local"];
const PULL_SUBS = ["pull-azure", "pull-s3", "pull-gcs", "pull-local"];
// issue-ticket-*（発行台帳モデル・spec §9.7・DC epic #472）: read-only 資格を mint（可能なストアのみ）
// し、gemba-share://v1/<JWS> を EdDSA で署名発行する egress verb。put-catalog の PUT backend を流用して
// keys/<kid>.json を shareRoot へ配置する（--no-publish-key で省略可）。show-pubkey / rotate-key は
// ローカル完結（外部ストア・CLI 不要）。revoke-ticket・pull --ticket-jti は PR (b)（本弾では出さない）。
const ISSUE_SUBS = ["issue-ticket-s3", "issue-ticket-gcs", "issue-ticket-azure", "issue-ticket-local"];
// revoke-ticket-*（協調的失効・spec §9.8・DC epic #472 PR (b)）: --jti の資格を無効化（gcs のみ実失効）し、
// shareRoot の revoked.json（協調的失効リスト）を CAS マージ PUT する destructive verb。真の失効は credential
// 側であり revoked.json は補助（fail-open・強制の本体ではない）。pull-* の --ticket-jti が読む。
const REVOKE_SUBS = ["revoke-ticket-s3", "revoke-ticket-gcs", "revoke-ticket-azure", "revoke-ticket-local"];
// presign-*（spec §9.9・#175）: 1 オブジェクトの短命 signed URL（GET のみ）を mint する read-only verb。
// local は無い（presign 相手となるオブジェクトストアが存在しない）。DC #504 が消費者。
const PRESIGN_SUBS = ["presign-s3", "presign-gcs", "presign-azure"];

// 「更新中」（目次 sha256 ≠ 取得実体）と判断したときに、目次から丸ごと再読するまでの待ち時間
// （§3.4/§7.3）。既定 1500ms・テストは IREPO_SHARE_PULL_RETRY_MS=10 で短縮する。schema には載せない
// 内部 knob（読み手 UX ではなく整合窓の調整）。
const PULL_RETRY_MS = Number(process.env.IREPO_SHARE_PULL_RETRY_MS) || 1500;

// 内蔵 fetch（pull-azure）の 1 GET あたりのタイムアウト。既定 120000ms。--plugin-schema 非掲載の内部
// knob（RETRY_MS と同じ流儀・読み手 UX ではなく整合窓/耐障害性の調整）。ネットワークが応答しないときに
// 無限待ちにならないための安全網。
const HTTP_TIMEOUT_MS = Number(process.env.IREPO_SHARE_HTTP_TIMEOUT_MS) || 120000;

// shareRoot 相対キーの文法（spec §2/§3.2）。**正本は
// spec/gemba-share/share-catalog.schema.json の $defs.relKey.pattern**。ゼロ依存ゆえ schema を
// 読み込まず同一パターンを焼き込む（変更時は schema と check-share SH3e を同時に直す）。
// 印字可能 ASCII のみ・先頭 /・~ 禁止・# ? % @ : \ 禁止・.. セグメント禁止。
const REL_KEY_RE = /^(?!\/|~)(?!(?:.*\/)?\.\.(?:\/|$))(?:(?![#?%@:\\])[\x21-\x7e])+$/;
const DEFAULT_KEY = "share-catalog.json";

// snapshot 世代キー文法（spec §2/§4.2・push-snapshot 専用）: datasets/<datasetId>/snapshot-<compactUTC>
// [-<suffix>].db[.gz]。<compactUTC>=YYYYMMDDThhmmssZ（辞書順＝時系列順のソートキー）・<suffix>=[0-9a-z]{1,16}
// （同一秒衝突回避）・.gz は任意（.db / .db.gz 両合法）。REL_KEY_RE の狭い部分集合（この形は必ず relKey
// にも合致する）だが、push-snapshot は「実体を世代キー以外へ置かせない」ため追加でこの形を強制する。
const SNAPSHOT_KEY_RE = /^datasets\/ds-[0-9a-f]{12}\/snapshot-\d{8}T\d{6}Z(-[0-9a-z]{1,16})?\.db(\.gz)?$/;

// ── 予約フラグ: --plugin-schema は API 検査より先に応答する（docs/PLUGINS.md）──
const arg0 = process.argv[2];
if (arg0 === "--plugin-schema") {
