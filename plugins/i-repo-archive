async function main() {
  const [command, ...rest] = process.argv.slice(2);
  if (command === "create") return createArchive(parseCreateArgs(rest));
  if (command === "push-s3") return pushArchiveBundle(parsePushArgs(rest, S3_BACKEND), S3_BACKEND);
  if (command === "push-gcs") return pushArchiveBundle(parsePushArgs(rest, GCS_BACKEND), GCS_BACKEND);
  if (command === "push-azure") return pushArchiveBundle(parsePushArgs(rest, AZURE_BACKEND), AZURE_BACKEND);
  if (command === "push-local") return pushArchiveBundle(parsePushArgs(rest, LOCAL_BACKEND), LOCAL_BACKEND);
  if (command === "pull-s3") return pullArchiveBundle(parsePullArgs(rest, S3_BACKEND), S3_BACKEND);
  if (command === "pull-gcs") return pullArchiveBundle(parsePullArgs(rest, GCS_BACKEND), GCS_BACKEND);
  if (command === "pull-azure") return pullArchiveBundle(parsePullArgs(rest, AZURE_BACKEND), AZURE_BACKEND);
  usage();
  process.exitCode = command === undefined || command === "--help" || command === "-h" ? 0 : 2;
}

function usage() {
  console.error(`Usage:
  ${PLUGIN} create [options]
      --out <path>             Archive directory (default: ~/.i-repo/archives/<timestamp>)
      --allow-worktree         Allow writing inside the current git worktree
      --force                  Reuse an existing archive directory
      --with-artifacts <t,..>  pdf,pdfLayer,excel,text,none (default: pdf; text=no binaries, cluster values only)
      --with-detail            Embed cluster values (reports get per record)
      --detail-sleep-ms <ms>   Sleep between detail fetches (default: 0)
      --detail-sleep-every <n> Apply sleep every N records (default: 1)
      --dry-run                Resolve inputs and report without writing
      --endpoint/--user/--password <v>   Override i-repo credentials
      Filters: -l/--label-id -w/--word --public-status -e/--edit-status
               -t/--type -d/--definition --definition-id --word-target
               --history --regist-from --regist-to --update-from --update-to
               -k/--system-key <n=v> (repeatable)
  ${PLUGIN} push-s3    <archive-dir> --to s3://bucket/prefix [--cleanup] [--dry-run]
  ${PLUGIN} push-gcs   <archive-dir> --to gs://bucket/prefix [--cleanup] [--dry-run]
  ${PLUGIN} push-azure <archive-dir> --to https://<account>.blob.core.windows.net/<container>/<prefix>
      [--sas <token> | --connection-string <cs>] [--cleanup] [--dry-run]
  ${PLUGIN} push-local <archive-dir> --to <folder|network-share path> [--cleanup] [--dry-run]
      --cleanup                Delete the local archive after the upload is verified
      (gcs requires gcloud; azure requires az CLI. push-local needs no external CLI
       (Node fs copy) and accepts a plain folder or mounted network-share path.
       secrets are read from --sas/--connection-string or AZURE_STORAGE_* env and
       passed to az via env, never argv)`);
}

// ── Tiny argv parser (no dependencies) ─────────────────────────────────────
// spec: { "--name": "value" | "flag" | "list", "-x": "--name" (alias) }

function parseArgv(argv, spec, label) {
  const out = { _: [] };
  for (let i = 0; i < argv.length; i++) {
    let token = argv[i];
    if (!token.startsWith("-")) {
      out._.push(token);
      continue;
    }
    let inlineValue;
    const eq = token.indexOf("=");
    if (eq > -1) {
      inlineValue = token.slice(eq + 1);
      token = token.slice(0, eq);
    }
    let kind = spec[token];
    if (typeof kind === "string" && kind.startsWith("--")) {
      token = kind; // alias → canonical
      kind = spec[token];
    }
    if (!kind) throw new Error(`Unknown option for ${label}: ${token}\nRun "${PLUGIN} --help".`);
    const key = token.replace(/^--/, "");
    if (kind === "flag") {
      if (inlineValue !== undefined) throw new Error(`Option ${token} does not take a value.`);
      out[key] = true;
      continue;
    }
    const value = inlineValue !== undefined ? inlineValue : argv[++i];
    if (value === undefined) throw new Error(`Option ${token} requires a value.`);
    if (kind === "list") (out[key] = out[key] ?? []).push(value);
    else out[key] = value;
  }
  return out;
}

const CREATE_SPEC = {
  "--out": "value", "--allow-worktree": "flag", "--force": "flag",
  "--with-artifacts": "value", "--with-detail": "flag", "--dry-run": "flag",
  "--detail-sleep-ms": "value", "--detail-sleep-every": "value",
  "--endpoint": "value", "--user": "value", "--password": "value",
  "--label-id": "value", "-l": "--label-id",
  "--word": "value", "-w": "--word",
  "--public-status": "value",
  "--edit-status": "value", "-e": "--edit-status",
  "--type": "value", "-t": "--type",
  "--definition": "value", "-d": "--definition",
  "--definition-id": "value",
  "--word-target": "value", "--history": "flag",
  "--regist-from": "value", "--regist-to": "value",
  "--update-from": "value", "--update-to": "value",
  "--system-key": "list", "-k": "--system-key",
};

function parseCreateArgs(argv) {
  const o = parseArgv(argv, CREATE_SPEC, "create");
  if (o._.length > 0) throw new Error(`Unexpected argument: ${o._[0]}`);
  const artifacts = (o["with-artifacts"] ?? "pdf").split(",").map((s) => s.trim()).filter(Boolean);
  for (const a of artifacts) {
    if (!["pdf", "pdfLayer", "excel", "text", "none"].includes(a)) {
      throw new Error(`Unsupported artifact type "${a}". Use pdf, pdfLayer, excel, text, or none.`);
    }
  }
  return {
    out: o.out,
    allowWorktree: Boolean(o["allow-worktree"]),
    force: Boolean(o.force),
    withArtifacts: artifacts,
    // text モードはバイナリ無し＋フィールド値（クラスター値）を必ず埋めるので detail を強制 ON。
    withDetail: Boolean(o["with-detail"]) || artifacts.includes("text"),
    detailSleepMs: Math.max(0, parseInt(o["detail-sleep-ms"] ?? "200", 10) || 0),
    detailSleepEvery: Math.max(1, parseInt(o["detail-sleep-every"] ?? "1", 10) || 1),
    dryRun: Boolean(o["dry-run"]),
    endpoint: o.endpoint,
    user: o.user,
    password: o.password,
    filters: {
      labelId: o["label-id"], word: o.word, publicStatus: o["public-status"],
      editStatus: o["edit-status"], itemType: o.type,
      definition: o["definition-id"] ?? o.definition,
      wordTarget: o["word-target"], history: Boolean(o.history),
      registFrom: o["regist-from"], registTo: o["regist-to"],
      updateFrom: o["update-from"], updateTo: o["update-to"],
      systemKeys: o["system-key"] ?? [],
    },
  };
}

// file:// URL を OS パスへ正規化する（catalog.rs の normalize_local_dest と同基準）。host/path を
// 分けて扱う:
// - 空ホスト / localhost: file:///abs→/abs、file:///C:/x・file://localhost/C:/x→C:/x
//   （Windows ドライブは先頭 / を落とす。/C:/x は Windows で別物/解釈不能）
// - ホスト指定: file://server/share→//server/share（Windows は UNC \\server\share と解釈）
// scheme 無しのプレーンパスはそのまま。単純 replace だと host/ドライブを壊すため明示分解する。
function normalizeLocalDest(to) {
  const t = String(to).trim();
  if (!t.startsWith("file://")) return t;
  const rest = t.slice("file://".length);
  const i = rest.indexOf("/");
  if (i === -1) return "//" + rest;            // ホストのみ → UNC host
  const host = rest.slice(0, i);
  const path = rest.slice(i);                   // 先頭 '/'
  const isDrive = (s) => /^[A-Za-z]:/.test(s);
  if (host === "" || host.toLowerCase() === "localhost") {
    const inner = path.slice(1);
    return isDrive(inner) ? inner : path;       // C:/... か /abs
  }
  return "//" + host + path;                     // UNC //server/share/...
}

function parsePushArgs(argv, backend) {
  const label = `push-${backend.store}`;
  const spec = { "--to": "value", "--prefix": "value", "--dry-run": "flag", "--cleanup": "flag" };
  // Azure は認証 secret を受ける（値は argv に出さず env で az に渡す。buildPushEnv 参照）。
  if (backend.store === "azure") { spec["--sas"] = "value"; spec["--connection-string"] = "value"; }
  const o = parseArgv(argv, spec, label);
  if (o._.length !== 1) throw new Error(`${label} requires exactly one <archive-dir> argument.`);
  // local は scheme 付き URL ではなくファイルパス（フォルダ/ネットワーク共有）。scheme 検査を外し、
  // 非空パスのみ要求する（任意で file:// 接頭辞を剥がす）。cloud は従来どおり scheme を強制。
  if (backend.store === "local") {
    const to = normalizeLocalDest(o.to ?? "");
    if (!to) throw new Error(`${label} requires --to <folder|network-share path>.`);
    o.to = to;
  } else {
    if (!o.to) throw new Error(`${label} requires --to ${backend.scheme}…`);
    if (!o.to.startsWith(backend.scheme)) throw new Error(`destination must start with "${backend.scheme}".`);
  }
  // Azure は blob エンドポイント URL の構造（account/container/prefix）まで parse 時に検証する
  // （dry-run でも不正 URL を早期に弾く。upload 時の parseAzureTo と同基準）。
  if (backend.store === "azure") parseAzureTo(o.to);
  const out = { archiveDir: o._[0], to: o.to, prefix: o.prefix, dryRun: Boolean(o["dry-run"]), cleanup: Boolean(o.cleanup) };
  if (backend.store === "azure") {
    out.azure = true;
    // フラグ未指定なら env から拾う（host の secret env 注入＝envVar 宣言と整合）。
    out.sas = o.sas || process.env.AZURE_STORAGE_SAS_TOKEN || "";
    out.connectionString = o["connection-string"] || process.env.AZURE_STORAGE_CONNECTION_STRING || "";
  }
  return out;
}

// ── create ──────────────────────────────────────────────────────────────────

async function createArchive(options) {
  // "none"（一覧メタのみ）と "text"（フィールド値まで・バイナリ無し）はどちらもバイナリDLをスキップ。
  // 矛盾指定（例 pdf,text）でもバイナリ無しを優先する。
  const noBinaries = options.withArtifacts.some((a) => a === "none" || a === "text");
  const artifacts = noBinaries
    ? []
    : Array.from(new Set(options.withArtifacts.filter((a) => a !== "none" && a !== "text")));
  const archivePath = resolveArchivePath(options.out);
  ensureArchiveLocationIsSafe(archivePath, options.allowWorktree);

  if (!options.dryRun) await prepareArchiveDirectory(archivePath, options.force);

  const jobId = `archive-${timestampTag()}-${process.pid}`;
  const credentials = await resolveCredentials(options);
  const manifestText = await listReports(credentials, options.filters);
  const records = parseManifest(manifestText); // validates the stream-end trailer
  const savedFiles = [];
  // Flat per-record landed map for the write receipt, so a fan-out host
  // (i-repo deliver §9.4) can build the real artifact locator
  // (bundle landedPrefix + objectKey) keyed by itemId+revNo — without needing
  // --with-detail (which embeds the same objectKey into manifest records).
  const landedArtifacts = [];

  if (!options.dryRun) {
    // ── 成果物ダウンロード（先に実行し、各レコードへ objectKey を記録） ──
    // With --history the same report id appears across multiple revisions, so
    // count ids and add a -rev<n> discriminator only where it's needed.
    const idCounts = new Map();
    for (const record of records) {
      const id = getReportId(record);
      if (id !== null) idCounts.set(id, (idCounts.get(id) ?? 0) + 1);
    }
    const usedNames = new Set();
    for (const record of records) {
      const reportId = getReportId(record);
      if (reportId === null) {
        console.error("skipping artifact download for a record without itemId/topId");
        continue;
      }
      const revNo = record.revNo != null ? String(record.revNo) : "";
      const needsRev = (idCounts.get(reportId) ?? 0) > 1 && revNo !== "";
      for (const artifact of artifacts) {
        const dl = await downloadArtifactNamed(credentials, reportId, artifact);
        try {
          const fileName = chooseArtifactFileName(dl.name, {
            record, reportId, revNo, needsRev, artifact,
            multipleArtifacts: artifacts.length > 1, usedNames,
          });
          usedNames.add(fileName);
          const outputPath = join(archivePath, "documents", fileName);
          await moveFile(dl.tempPath, outputPath);
          savedFiles.push(outputPath);
          // NoSQLドキュメントから添付を辿れるよう、相対 objectKey を記録（S3なら <prefix>/documents/<name>）
          (record.artifacts = record.artifacts ?? []).push({
            type: artifact, file: fileName, objectKey: `documents/${fileName}`,
          });
          // 同じ objectKey を receipt 向けの平坦マップにも積む（itemId+revNo で索ける）。
          landedArtifacts.push({
            itemId: String(reportId), revNo: revNo || null,
            type: artifact, objectKey: `documents/${fileName}`,
          });
        } finally {
          await fsp.rm(dl.tempDir, { recursive: true, force: true });
        }
      }
    }

    // ── --with-detail: 各帳票の reports get を呼び、クラスター値を record.detail に埋め込む ──
    // これにより manifest が一覧レベルから「クラスター値＋添付パス入りの richな NDJSON」になり、
    // どの sink（mongo/sqlite/s3…）でも帳票の中身まで届く。
    let manifestToWrite = manifestText; // 既定は verbatim（トレーラ込みの忠実コピー）
    if (options.withDetail) {
      const sleepMs = options.detailSleepMs;
      const sleepEvery = options.detailSleepEvery;
      if (sleepMs > 0) {
        console.error(`--with-detail: sleep ${sleepMs}ms every ${sleepEvery} record(s)`);
      }
      let enriched = 0, fetched = 0;
      for (const record of records) {
        const id = getReportId(record);
        if (id === null) continue;
        try {
          record.detail = await fetchReportDetail(credentials, id);
          enriched++;
        } catch (error) {
          console.error(`detail fetch failed for report ${id}: ${error.message}`);
        }
        fetched++;
        if (sleepMs > 0 && fetched % sleepEvery === 0) {
          await new Promise((r) => setTimeout(r, sleepMs));
        }
      }
      console.error(`--with-detail: embedded clusters for ${enriched}/${records.length} report(s)`);
      const trailerLine = manifestText
        .split(/\r?\n/).map((l) => l.trim()).filter(Boolean)
        .find((l) => { try { return JSON.parse(l).recordType === "stream-end"; } catch { return false; } });
      const lines = records.map((r) => JSON.stringify(r));
      if (trailerLine) lines.push(trailerLine);
      manifestToWrite = lines.join("\n") + "\n";
    }

    // The manifest is written verbatim (or enriched when --with-detail).
    const manifestPath = join(archivePath, "manifests", "reports.ndjson");
    await writeTextFile(manifestPath, manifestToWrite);
    savedFiles.push(manifestPath);
  }

  // ── write phase receipt (SCHEMA.md §6 + plugin-specific extras) ──
  const extras = {
    archivePath,
    createdAt: new Date().toISOString(),
    requestedArtifacts: artifacts,
    savedFiles,
    // record → landed objectKey map (deliver §9.4 enrich source). Empty on dry-run.
    artifacts: landedArtifacts,
    filters: compactObject(options.filters),
    ...(options.dryRun ? { dryRun: true } : {}),
  };
  emitReceipt("write", jobId, records.length, 0, false, extras);

  if (options.dryRun) return;

  // Completion marker written last: its absence marks an incomplete bundle.
  const receiptPath = join(archivePath, "receipts", "archive.json");
  const provenance = endpointProvenance();
  await writeJsonFile(receiptPath, {
    jobId, count: records.length,
    producedBy: { plugin: PLUGIN, version: VERSION }, // 来歴: stdout だけでなく archive.json にも残す
    ...(provenance ? { provenance } : {}), // 接続来歴も stdout receipt と同一値で残す
    ...extras,
  });
  savedFiles.push(receiptPath);

  // ── verify phase: read back every saved file (exists and non-empty) ──
  let failed = 0;
  for (const file of savedFiles) {
    const details = await fsp.stat(file).catch(() => null);
    if (!details || !details.isFile() || details.size === 0) {
      console.error(`verify failed: missing or empty ${file}`);
      failed++;
    }
  }
  emitReceipt("verify", jobId, records.length, failed, failed === 0, { archivePath });
  if (failed > 0) process.exitCode = 1;
}

// ── push to object storage (s3 / gcs / azure) ────────────────────────────────
//
// 共通スケルトン pushArchiveBundle が「upload → push receipt 配置 → 読み戻して verify →
// --cleanup（verified 時のみ削除）」を担い、各 backend は store 固有の「アップロード・存在
// 確認・dest 計算」だけを実装する。push-s3 の確立パターンを s3/gcs/azure へ一般化したもの。
//
// 検証状況: s3 は既存どおり実運用検証済み。gcs は cp の非決定的なディレクトリ扱い（宛先既存で UUID 入れ子）を
// 避けるため rsync（内容を決定的に同期・--delete 無し）に変更し、--prefix 込みの up/down＋verify 通過を実機
// gcloud で確認済み。azure は az CLI 不在のため実行未検証（コマンド配線は az docs 準拠）。

// スキーム非依存のスラッシュ結合（s3:// / gs:// / https:// すべてに使える）。
function joinUri(prefix, child) {
  return joinS3Uri(prefix, child);
}

// secret（SAS / 接続文字列）は argv に載せず az が読む環境変数で渡す（AGENTS.md / 本番化方針）。
function buildPushEnv(options) {
  const env = { ...process.env };
  if (options.connectionString) env.AZURE_STORAGE_CONNECTION_STRING = options.connectionString;
  else if (options.sas) env.AZURE_STORAGE_SAS_TOKEN = options.sas;
  // Azure で明示 secret が無ければ az login 認証を使う（既定の account-key モードは
  // RBAC-only / listKeys 無効アカウントで失敗するため・Codex #76 P2）。s3/gcs は options.azure
  // 未設定なので素通り。
  else if (options.azure) env.AZURE_STORAGE_AUTH_MODE = "login";
  return env;
}

const S3_BACKEND = {
  store: "s3", scheme: "s3://", prefixKey: "s3Prefix", receiptName: "push-s3.json",
  async upload(archivePath, to, destSub, env) {
    // aws s3 cp <dir> <dest> --recursive は <dir> の中身を <dest> 直下へ置く（明示宛先）。
    const destination = joinUri(to, destSub);
    await runCommand("aws", ["s3", "cp", archivePath, destination, "--recursive"], { env, captureStdout: false });
    return destination;
  },
  async uploadReceipt(receiptPath, destination, env) {
    await runCommand("aws", ["s3", "cp", receiptPath, joinUri(destination, `receipts/${this.receiptName}`)], { env, captureStdout: false });
  },
  async verify(destination, env) {
    const r = await runCommand("aws", ["s3", "ls", joinUri(destination, `receipts/${this.receiptName}`)], { env, captureStdout: true }).catch(() => null);
    return r !== null && r.stdout.trim().length > 0;
  },
  // 取り戻し（read-only）: from(リモート)→out(ローカル)。固定 argv「cp … --recursive」のみ＝書込/削除コマンドは呼ばない。
  async download(from, out, env) {
    await runCommand("aws", ["s3", "cp", from, out, "--recursive"], { env, captureStdout: false });
  },
};

const GCS_BACKEND = {
  store: "gcs", scheme: "gs://", prefixKey: "gcsPrefix", receiptName: "push-gcs.json",
  async upload(archivePath, to, destSub, env) {
    // gcloud storage cp --recursive はディレクトリの扱いが非決定的（宛先が既存なら basename(<dir>)=UUID を
    // 末尾に入れ子化、新規なら中身を展開）で、--prefix の任意フォルダ名と相性が悪い（実機で UUID 入れ子を確認）。
    // → 内容を決定的に同期する rsync に変更（s3/azure の「明示宛先へ内容コピー」と等価）。--delete は付けない
    //   ので既存オブジェクトを消さない（追加/更新のみ）。
    const destination = joinUri(to, destSub);
    await runCommand("gcloud", ["storage", "rsync", "--recursive", archivePath, destination], { env, captureStdout: false });
    return destination;
  },
  async uploadReceipt(receiptPath, destination, env) {
    await runCommand("gcloud", ["storage", "cp", receiptPath, joinUri(destination, `receipts/${this.receiptName}`)], { env, captureStdout: false });
  },
  async verify(destination, env) {
    const r = await runCommand("gcloud", ["storage", "ls", joinUri(destination, `receipts/${this.receiptName}`)], { env, captureStdout: true }).catch(() => null);
    return r !== null && r.stdout.trim().length > 0;
  },
  // 取り戻し（read-only）。rsync でリモート(from)の内容をローカル(out)へ決定的に同期する。--delete 無し＝
  // ストアもローカルも余分を消さない。from→out（リモート→ローカル）なのでストアは読むだけ＝read-only。
  async download(from, out, env) {
    await runCommand("gcloud", ["storage", "rsync", "--recursive", from, out], { env, captureStdout: false });
  },
};

// https://<account>.blob.core.windows.net/<container>/<prefix...> を分解。
function parseAzureTo(to) {
  // SAS 付き URL（?sv=…&sig=… / #fragment）を --to に貼られると、--to は secret:true でないため
  // SAS トークンが azurePrefix receipt・カタログ・表示コマンドへ漏洩する。query/fragment を含む
  // URL は拒否し、SAS は env-only の --sas で渡させる（Codex #76 P2・secret 取り扱い契約）。
  if (/[?#]/.test(to)) {
    throw new Error('Azure --to must not contain a query string or SAS token (pass the SAS via --sas; --to is not secret).');
  }
  const m = /^https:\/\/([a-z0-9]+)\.blob\.core\.windows\.net\/([^/]+)(?:\/(.*))?$/i.exec(to);
  if (!m) throw new Error('Azure destination must be https://<account>.blob.core.windows.net/<container>/<prefix>.');
  return { account: m[1], container: m[2], prefix: (m[3] || "").replace(/\/+$/, "") };
}

const AZURE_BACKEND = {
  store: "azure", scheme: "https://", prefixKey: "azurePrefix", receiptName: "push-azure.json",
  async upload(archivePath, to, destSub, env) {
    const { account, container, prefix } = parseAzureTo(to);
    const destPath = [prefix, destSub].filter(Boolean).join("/");
    // upload-batch は <source> の中身を相対パス保持で <container>/<destPath>/ へ置く。
    await runCommand("az", ["storage", "blob", "upload-batch", "--account-name", account,
      "--destination", container, "--destination-path", destPath, "--source", archivePath, "--overwrite"],
      { env, captureStdout: false });
    return joinUri(to, destSub);
  },
  async uploadReceipt(receiptPath, destination, env) {
    const { account, container, prefix } = parseAzureTo(destination);
    const name = [prefix, `receipts/${this.receiptName}`].filter(Boolean).join("/");
    await runCommand("az", ["storage", "blob", "upload", "--account-name", account,
      "--container-name", container, "--name", name, "--file", receiptPath, "--overwrite"],
      { env, captureStdout: false });
  },
  async verify(destination, env) {
    const { account, container, prefix } = parseAzureTo(destination);
    const name = [prefix, `receipts/${this.receiptName}`].filter(Boolean).join("/");
    const r = await runCommand("az", ["storage", "blob", "exists", "--account-name", account,
      "--container-name", container, "--name", name, "-o", "json"], { env, captureStdout: true }).catch(() => null);
    if (r === null) return false;
    try { return JSON.parse(r.stdout).exists === true; } catch { return false; }
  },
  // 取り戻し（read-only）。download-batch で <container>/<prefix>/* を out へ（相対パス保持）。固定 argv「download-batch」のみ。
  async download(from, out, env) {
    const { account, container, prefix } = parseAzureTo(from);
    const pattern = prefix ? `${prefix}/*` : "*";
    await runCommand("az", ["storage", "blob", "download-batch", "--account-name", account,
      "--source", container, "--destination", out, "--pattern", pattern],
      { env, captureStdout: false });
  },
};

// push-local（ローカル/ファイルサーバー）: 外部CLI不要・Node fs で再帰コピーする。
// パス結合は path.join（cloud の "/" 強制ではなく OS のセパレータ）。Windows UNC（\\server\share）・
// macOS（/Volumes/…）・Linux マウントの3形を素通しする（CLAUDE.md: OS 依存を局所化／cmd.exe を介さない）。
const LOCAL_BACKEND = {
  store: "local", scheme: "", prefixKey: "localPrefix", receiptName: "push-local.json",
  // dry-run の dest プレビュー用（共通スケルトンが joinUri の代わりに使う）。
  joinDest(to, destSub) { return join(to, destSub); },
  async upload(archivePath, to, destSub, _env) {
    const destination = join(to, destSub);
    // 越境ガード（多層防御）: destSub は resolvePrefixTemplate で相対パス保証済みだが、結合後も
    // --to 配下に収まることを resolve で確認する（path.join が外へ出る事故を二重で防ぐ・Cursor P1）。
    const root = resolve(to);
    const resolved = resolve(destination);
    if (resolved !== root && !resolved.startsWith(root + sep)) {
      throw new Error(`push-local: resolved destination escapes --to (${destination}).`);
    }
    await fsp.mkdir(destination, { recursive: true });
    // fs.cp(src, dest, {recursive}) は src ツリーを dest にミラーする（dest が src の複製になる）。
    await fsp.cp(archivePath, destination, { recursive: true });
    return destination;
  },
  async uploadReceipt(receiptPath, destination, _env) {
    const target = join(destination, "receipts", this.receiptName);
    await fsp.mkdir(dirname(target), { recursive: true });
    await fsp.cp(receiptPath, target);
  },
  async verify(destination, _env) {
    const st = await fsp.stat(join(destination, "receipts", this.receiptName)).catch(() => null);
    return st !== null && st.size > 0;
  },
};

const PUSH_BACKENDS = { s3: S3_BACKEND, gcs: GCS_BACKEND, azure: AZURE_BACKEND, local: LOCAL_BACKEND };

async function pushArchiveBundle(options, backend) {
  const archivePath = resolveArchivePath(options.archiveDir);
  await validateArchiveDirectory(archivePath);

  const jobId = `push-${timestampTag()}-${process.pid}`;
  const archiveReceipt = await readJsonObject(join(archivePath, "receipts", "archive.json"));
  const count = typeof archiveReceipt.count === "number" ? archiveReceipt.count : 0;
  const batchDir = basename(archivePath);
  // 宛先サブパス。--prefix 指定時はテンプレ解決後の安全な相対パスが「実行ごとフォルダ」を置き換える。
  // 未指定なら従来どおり batchDir(UUID)。destSub は宛先専用で、ローカル dir 名(batchDir)とは分離する。
  const destSub = options.prefix ? resolvePrefixTemplate(options.prefix, { batchDir }) : batchDir;
  // --to のテンプレ（{flow} 等）を展開し、着地も dest も展開後の値で扱う（issue #89）。
  const expandedTo = expandToTemplate(options.to);
  // バッチ非依存の安定 store location（catalog 掲載用）。実行フォルダ destSub は含めない。
  const dest = canonicalBundleDest(backend.store, expandedTo);
  const storeKind = `${backend.store}-bundle`;
  const env = buildPushEnv(options);

  if (options.dryRun) {
    // local は OS パス結合（joinDest）、cloud は scheme ベースの joinUri。
    const previewDest = backend.joinDest ? backend.joinDest(expandedTo, destSub) : joinUri(expandedTo, destSub);
    emitReceipt("write", jobId, count, 0, false, { archivePath, [backend.prefixKey]: previewDest, dest, storeKind, dryRun: true });
    return;
  }

  const receiptPath = join(archivePath, "receipts", backend.receiptName);
  // Drop any push receipt left by a previous run BEFORE the recursive copy,
  // so a partial/failed copy can never ship a stale "ok" receipt upstream.
  await fsp.rm(receiptPath, { force: true });
  // Upload the bundle first; only after the recursive copy succeeds do we
  // write the push receipt and upload it as a final, separate object.
  const destination = await backend.upload(archivePath, expandedTo, destSub, env);
  emitReceipt("write", jobId, count, 0, false, { archivePath, [backend.prefixKey]: destination, dest, storeKind });

  await writeJsonFile(receiptPath, { jobId, count, archivePath, [backend.prefixKey]: destination, dest, storeKind, pushedAt: new Date().toISOString() });
  await backend.uploadReceipt(receiptPath, destination, env);

  // ── verify phase: read the receipt object back from the destination ──
  const verified = await backend.verify(destination, env);

  // ── --cleanup: verified:true を確認できたときだけローカルを削除する ──
  // (PLUGINS.md: 不可逆処理は exit 0 ではなく verified receipt を条件にする)。
  // 削除失敗は配送の失敗ではないので exit 0 のまま、ただし receipt の
  // cleanedUp:false と stderr で必ず報告する (沈黙させない)。
  const extras = { archivePath, [backend.prefixKey]: destination, dest, storeKind };
  if (options.cleanup) {
    if (verified) {
      try {
        await fsp.rm(archivePath, { recursive: true, force: true });
        extras.cleanedUp = true;
        console.error(`cleaned up local archive: ${archivePath}`);
      } catch (error) {
        extras.cleanedUp = false;
        // 非 Error が throw されても二次例外で本来の失敗を隠さない
        console.error(
          `cleanup failed (local archive kept): ${error instanceof Error ? error.message : String(error)}`,
        );
      }
    } else {
      extras.cleanedUp = false; // verify 失敗時は絶対に消さない
    }
  }
  emitReceipt("verify", jobId, count, verified ? 0 : count, verified, extras);
  if (!verified) process.exitCode = 1;
}

// ── pull（取り戻し・read-only）: クラウドの bundle をローカルへ DL するだけ。store へ write/delete しない。
function parsePullArgs(argv, backend) {
  const label = `pull-${backend.store}`;
  const spec = { "--from": "value", "--out": "value" };
  if (backend.store === "azure") { spec["--sas"] = "value"; spec["--connection-string"] = "value"; }
  const o = parseArgv(argv, spec, label);
  if (!o.from) throw new Error(`${label} requires --from ${backend.scheme || "<source>"}…`);
  if (!o.out) throw new Error(`${label} requires --out <local-dir>.`);
  // read-only ガード（対称）: from は必ずリモート(scheme 一致)、out は必ずローカル(scheme 無し)。
  // 引数逆転（local を source に／remote を dest に）＝誤アップロード/上書きを両方向で防ぐ。
  if (backend.scheme && !o.from.startsWith(backend.scheme)) {
    throw new Error(`${label}: --from must start with "${backend.scheme}".`);
  }
  if (/^[a-z][a-z0-9+.-]*:\/\//i.test(o.out)) {
    throw new Error(`${label}: --out must be a local directory (no scheme).`);
  }
  if (backend.store === "azure") parseAzureTo(o.from);
  const out = { from: o.from, out: o.out };
  if (backend.store === "azure") {
    out.azure = true;
    out.sas = o.sas || process.env.AZURE_STORAGE_SAS_TOKEN || "";
    out.connectionString = o["connection-string"] || process.env.AZURE_STORAGE_CONNECTION_STRING || "";
  }
  return out;
}

async function pullArchiveBundle(options, backend) {
  const jobId = `pull-${timestampTag()}-${process.pid}`;
  const out = resolve(options.out);
  await fsp.mkdir(out, { recursive: true });
  const env = buildPushEnv(options); // 認証は push と同形（aws/gcloud は ambient、azure は SAS/接続文字列を env で）。
  await backend.download(options.from, out, env); // 固定 argv（cp / download-batch のみ）。
  // 取得成功 = マニフェストが落ちていること（read-back の土台）。無ければ取得失敗 or 空 prefix。
  const manifest = join(out, "manifests", "reports.ndjson");
  const verified = await fsp.stat(manifest).then((s) => s.size > 0).catch(() => false);
  process.stdout.write(JSON.stringify({
    schemaVersion: "1.0", recordType: "receipt", plugin: PLUGIN,
    producedBy: { plugin: PLUGIN, version: VERSION },
    phase: "read", jobId, verified, source: options.from, out,
  }) + "\n");
  if (!verified) process.exitCode = 1;
}

// ── receipts (SCHEMA.md §6) ─────────────────────────────────────────────────

// 接続来歴: CLI(dispatch) が precomputed して env で渡した値を echo するだけ。指紋は
// 計算しない（CLI が正本＝凍結規則の第2実装を作らない。SCHEMA.md §2.5a/§6）。
// IREPO_ENDPOINT_FINGERPRINT が無い＝endpoint 未解決 → provenance を省略（不明＝
// fail-closed; 消費側は空/不在を「一致」と解釈しない契約）。
function endpointProvenance() {
  const endpointFingerprint = process.env.IREPO_ENDPOINT_FINGERPRINT;
  if (!endpointFingerprint) return undefined;
  return {
    endpoint: process.env.IREPO_ENDPOINT || "",
    endpointFingerprint,
    user: process.env.IREPO_USER || "",
    resolvedFrom: process.env.IREPO_ENDPOINT_RESOLVED_FROM || "",
  };
}

function emitReceipt(phase, jobId, count, failedCount, verified, extras) {
  const provenance = endpointProvenance();
  process.stdout.write(JSON.stringify({
    schemaVersion: "1.0", recordType: "receipt", plugin: PLUGIN,
    producedBy: { plugin: PLUGIN, version: VERSION },
    phase, jobId, count, failedCount, verified,
    ...(provenance ? { provenance } : {}),
    ...extras,
  }) + "\n");
}

// ── manifest parsing + stream-end validation (SCHEMA.md §2.6) ───────────────

function parseManifest(text) {
  const lines = text.split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
  const records = [];
  let trailer = null;
  for (const [index, line] of lines.entries()) {
    let row;
    try {
      row = JSON.parse(line);
    } catch (error) {
      throw new Error(`Failed to parse NDJSON line ${index + 1}: ${error.message}`);
    }
    if (!row || typeof row !== "object" || Array.isArray(row)) {
      throw new Error(`NDJSON line ${index + 1} is not an object.`);
    }
    if (row.recordType === "stream-end") trailer = row;
    else records.push(row);
  }
  const isEnvelope = records.some((r) => "schemaVersion" in r);
  if (isEnvelope && !trailer) {
    throw new Error("truncated manifest: envelope records present but no stream-end trailer (SCHEMA.md §2.6).");
  }
  if (trailer && trailer.count !== records.length) {
    throw new Error(
      `incomplete manifest: stream-end count=${trailer.count} but received ${records.length} record(s) (SCHEMA.md §2.6).`,
    );
  }
  return records;
}

/** Identifier for download/file naming, or null when the row has none. */
function getReportId(record) {
  const raw = record.itemId ?? record.topId;
  return raw === undefined || raw === null ? null : String(raw);
}

// ── archive locations ───────────────────────────────────────────────────────

function resolveArchivePath(out) {
  if (out && out.trim().length > 0) return resolve(expandHome(out));
  return resolve(defaultArchiveRoot(), timestampTag());
}

function expandHome(value) {
  if (value === "~") return homedir();
  if (value.startsWith(`~${sep}`) || value.startsWith("~/")) return join(homedir(), value.slice(2));
  return value;
}

async function prepareArchiveDirectory(path, force) {
  if (fs.existsSync(path)) {
    const details = await fsp.stat(path);
    if (!details.isDirectory()) throw new Error(`Archive path exists and is not a directory: ${path}`);
    if (!force) {
      throw new Error(
        `Archive directory already exists: ${path}\nPick a new --out path or pass --force to reuse that directory.`,
      );
    }
    // --force reuses the directory: clear the managed subdirectories so stale
    // files from a previous run cannot leak into a later recursive push-s3.
    for (const sub of ["manifests", "documents", "receipts"]) {
      await fsp.rm(join(path, sub), { recursive: true, force: true });
    }
  }
  for (const sub of ["manifests", "documents", "receipts"]) {
    await fsp.mkdir(join(path, sub), { recursive: true });
  }
}

function ensureArchiveLocationIsSafe(path, allowWorktree) {
  if (allowWorktree) return;
  const worktreeRoot = findUp(process.cwd(), (dir) => fs.existsSync(join(dir, ".git")));
  if (!worktreeRoot) return;
  const target = resolve(path);
  const parent = resolve(worktreeRoot);
  if (target === parent || target.startsWith(parent + sep)) {
    throw new Error(
      `Refusing to write archive data inside the current git worktree:\n` +
      `  worktree: ${worktreeRoot}\n  archive:  ${path}\n` +
      "Use a path outside the repo, or pass --allow-worktree if you really want that.",
    );
  }
}

function findUp(from, predicate) {
  let current = resolve(from);
  while (true) {
    if (predicate(current)) return current;
    const parent = dirname(current);
    if (parent === current) return null;
    current = parent;
  }
}

async function validateArchiveDirectory(path) {
  const details = await fsp.stat(path).catch(() => null);
  if (!details || !details.isDirectory()) throw new Error(`Archive directory does not exist: ${path}`);
  await fsp.access(join(path, "manifests", "reports.ndjson"));
  // Require the completion marker: create writes receipts/archive.json last,
  // so its absence means create failed mid-run and the bundle is incomplete.
  await fsp.access(join(path, "receipts", "archive.json")).catch(() => {
    throw new Error(
      `Archive is incomplete (missing receipts/archive.json): ${path}\n` +
      "The create step may have failed before finishing; re-run create.",
    );
  });
}

// ── credentials (flags > env > i-repo config files > TTY prompt) ────────────

async function resolveCredentials(options) {
  const config = await readMergedIRepoConfig(process.cwd());
  const endpoint = options.endpoint ?? process.env.IREPO_ENDPOINT ?? config.endpoint;
  const user = options.user ?? process.env.IREPO_USER ?? config.user;
  let password = options.password ?? process.env.IREPO_PASSWORD ?? config.password;

  if (!endpoint) {
    throw new Error(
      'i-Repo endpoint is not configured.\nPass --endpoint, set IREPO_ENDPOINT, or save it with "i-repo config set endpoint <url>".',
    );
  }
  if (!user) {
    throw new Error(
      'i-Repo user is not configured.\nPass --user, set IREPO_USER, or save it with "i-repo config set user <name>".',
    );
  }
  if (!password) {
    if (!process.stdin.isTTY) {
      throw new Error(
        "i-Repo password is required.\nPass --password, set IREPO_PASSWORD, or save it in i-repo config before running this plugin.",
      );
    }
    password = await promptPassword(`Password for ${user}: `);
    if (!password) throw new Error("Password is required.");
  }
  return { endpoint, user, password };
}

/** Masked password prompt with Node built-ins only (raw mode + stderr echo). */
function promptPassword(message) {
  return new Promise((resolvePromise, rejectPromise) => {
    const stdin = process.stdin;
    process.stderr.write(message);
    stdin.setRawMode(true);
    stdin.resume();
    stdin.setEncoding("utf8");
    let value = "";
    const cleanup = () => {
      stdin.setRawMode(false);
      stdin.pause();
      stdin.removeListener("data", onData);
    };
    const onData = (chunk) => {
      for (const ch of chunk) {
        if (ch === "") { // Ctrl+C
          cleanup();
          process.stderr.write("\n");
          rejectPromise(new Error("Aborted."));
          return;
        }
        if (ch === "\r" || ch === "\n") {
          cleanup();
          process.stderr.write("\n");
          resolvePromise(value);
          return;
        }
        if (ch === "" || ch === "\b") {
          if (value.length > 0) {
            value = value.slice(0, -1);
            process.stderr.write("\b \b");
          }
          continue;
        }
        value += ch;
        process.stderr.write("*");
      }
    };
    stdin.on("data", onData);
  });
}

async function readMergedIRepoConfig(from) {
  const root = findUp(from, (dir) =>
    fs.existsSync(join(dir, ".git")) || fs.existsSync(join(dir, "package.json")));
  const userConfig = await readJsonObject(join(homedir(), ".i-repo", "i-repo.json"));
  const projectConfig = root ? await readJsonObject(join(root, ".i-repo", "i-repo.json")) : {};
  const localConfig = root ? await readJsonObject(join(root, ".i-repo", "i-repo.local.json")) : {};
  return { ...userConfig, ...projectConfig, ...localConfig };
}

async function readJsonObject(path) {
  try {
    const parsed = JSON.parse(await fsp.readFile(path, "utf8"));
    if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) return {};
    return parsed;
  } catch {
    return {};
  }
}

// ── i-repo callbacks ────────────────────────────────────────────────────────

async function listReports(credentials, filters) {
  const args = ["rep", "list", "--format", "ndjson", ...buildListArgs(filters)];
  const result = await runCommand(iRepoBin(), args, {
    env: buildIRepoEnv(credentials), captureStdout: true,
  });
  return result.stdout;
}

/**
 * 帳票詳細（GetReportDetail 相当）を取得し、クラスター配列を返す。
 * 文字クラスターは value に入力値、画像クラスターは value:"Image"（実体は別途S3へ）。
 */
async function fetchReportDetail(credentials, reportId) {
  const result = await runCommand(
    iRepoBin(),
    ["reports", "get", String(reportId), "--format", "json"],
    { env: buildIRepoEnv(credentials), captureStdout: true },
  );
  let parsed = JSON.parse(result.stdout);
  if (Array.isArray(parsed)) parsed = parsed[0] ?? {};
  const clusters = parsed?.clusters?.cluster ?? [];
  return {
    sheetCount: parsed.sheetCount ?? null,
    clusterCount: Array.isArray(clusters) ? clusters.length : 0,
    clusters: Array.isArray(clusters) ? clusters : [],
  };
}

function buildListArgs(filters) {
  const args = [];
  const push = (flag, value) => { if (value && value.length > 0) args.push(flag, value); };
  push("--label-id", filters.labelId);
  push("--word", filters.word);
  push("--public-status", filters.publicStatus);
  push("--edit-status", filters.editStatus);
  push("--type", filters.itemType);
  push("--definition", filters.definition);
  push("--word-target", filters.wordTarget);
  if (filters.history) args.push("--history");
  push("--regist-from", filters.registFrom);
  push("--regist-to", filters.registTo);
  push("--update-from", filters.updateFrom);
  push("--update-to", filters.updateTo);
  for (const value of filters.systemKeys) push("--system-key", value);
  return args;
}

/**
 * Download one artifact into a fresh temp dir and return the single file that
 * appears. We always force the CLI's default name `report-<id>.<ext>` via -o
 * (never let it derive the name from the server):
 *   - i-repo CLI は RFC5987 `filename*=UTF-8''…` を復号せず生の %XX 名で `.part` を作るため、
 *     日本語1文字が9バイト（`%E3%83%86`）に膨張し、長い帳票名だとファイル名がファイルシステムの
 *     上限（NAME_MAX 255B）を超えて ENAMETOOLONG で落ちる（実機報告）。既定名に固定して根本回避する。
 *   - downloadedName が chooseArtifactFileName の cliFallback と一致するので、最終名は manifest の
 *     帳票名称から `<帳票ID>_<帳票名称>.<ext>` で統一的に組める（サーバの自動出力設定名は使わない）。
 */
async function downloadArtifactNamed(credentials, reportId, artifact) {
  const tempDir = await fsp.mkdtemp(join(tmpdir(), "irepo-archive-dl-"));
  try {
    const safeName = `report-${reportId}${fileExtensionFor(artifact)}`;
    await runCommand(
      iRepoBin(),
      ["rep", "download", reportId, "--file-type", artifact, "-o", join(tempDir, safeName)],
      { env: buildIRepoEnv(credentials), captureStdout: true, cwd: tempDir },
    );
    const entries = await fsp.readdir(tempDir);
    if (entries.length !== 1) {
      throw new Error(
        `expected exactly one downloaded file for report ${reportId} (${artifact}), found ${entries.length}`,
      );
    }
    return { tempDir, tempPath: join(tempDir, entries[0]), name: entries[0] };
  } catch (error) {
    await fsp.rm(tempDir, { recursive: true, force: true });
    throw error;
  }
}

/**
 * rename で移動し、tmpdir と保存先が別ボリュームのとき (EXDEV) は copy+unlink。
 * Windows ではアンチウイルス/インデクサが書込直後のファイルを一瞬開くため、
 * rename が EPERM/EBUSY/EACCES で散発的に失敗する — CLI 本体の
 * renameWithRetry と同じく短い指数バックオフでリトライする。
 */
async function moveFile(from, to) {
  await fsp.mkdir(dirname(to), { recursive: true });
  const transient = new Set(["EPERM", "EBUSY", "EACCES"]);
  for (let attempt = 0; ; attempt++) {
    try {
      await fsp.rename(from, to);
      return;
    } catch (error) {
      // throw null 等の非オブジェクトでも二次例外を起こさない (?. は安全)
      const code = error?.code;
      if (code === "EXDEV") {
        await fsp.copyFile(from, to);
        await fsp.unlink(from);
        return;
      }
      if (attempt >= 9 || !transient.has(code)) throw error;
      await new Promise((r) => setTimeout(r, 10 + attempt * 15));
    }
  }
}

function buildIRepoEnv(credentials) {
  return {
    ...process.env,
    IREPO_ENDPOINT: credentials.endpoint,
    IREPO_USER: credentials.user,
    IREPO_PASSWORD: credentials.password,
  };
}

function iRepoBin() {
  return process.env.IREPO_BIN && process.env.IREPO_BIN.length > 0 ? process.env.IREPO_BIN : "i-repo";
}

function commandExists(command, args) {
  return runCommand(command, args, { env: process.env, captureStdout: true })
    .then(() => true)
    .catch(() => false);
}

/**
 * Build a spawn invocation that works on every OS WITHOUT shell:true.
 * shell:true concatenates args unescaped through cmd.exe, so a filter value
 * like `--word "a & calc"` could execute an extra command. Instead — same
 * approach as i-repo's own plugin dispatcher — build the cmd.exe argv
 * explicitly (each token quoted, /s strips the outer pair) and refuse
 * cmd.exe metacharacters outright, since cmd.exe re-parses them even when
 * quoted. POSIX spawns the argv array directly (no shell, nothing to escape).
 */
function spawnSpec(command, args) {
  if (process.platform !== "win32") {
    return { bin: command, argv: args, extra: {} };
  }
  // "i-repo"/"aws" may resolve to .cmd shims, which Node refuses to spawn
  // directly — cmd.exe must run them.
  const unsafe = [command, ...args].find((a) => /[&|<>^"%!()\r\n]/.test(a));
  if (unsafe !== undefined) {
    throw new Error(
      `Refusing to run ${command}: argument contains characters unsafe for cmd.exe: ${unsafe}`,
    );
  }
  const inner = [command, ...args].map((a) => `"${a}"`).join(" ");
  return {
    bin: process.env.ComSpec || "cmd.exe",
    argv: ["/d", "/s", "/c", `"${inner}"`],
    extra: { windowsVerbatimArguments: true },
  };
}

function runCommand(command, args, options) {
  return new Promise((resolvePromise, rejectPromise) => {
    let spec;
    try {
      spec = spawnSpec(command, args);
    } catch (error) {
      rejectPromise(error);
      return;
    }
    const child = spawn(spec.bin, spec.argv, {
      env: options.env,
      cwd: options.cwd,
      ...spec.extra,
      // When not capturing, route the child's stdout to OUR stderr (fd 2) so
      // child chatter (download progress, aws cp output) never pollutes the
      // machine-readable receipts on our stdout.
      stdio: ["inherit", options.captureStdout ? "pipe" : 2, "inherit"],
    });
    let stdout = "";
    if (options.captureStdout && child.stdout) {
      child.stdout.setEncoding("utf8");
      child.stdout.on("data", (chunk) => { stdout += chunk; });
    }
    child.on("error", (error) => {
      if (error.code === "ENOENT") {
        rejectPromise(new Error(
          `Required command not found: ${command}\n` +
          (command === "aws" ? "Install the AWS CLI or skip push-s3." : `Make sure "${command}" is on PATH.`),
        ));
        return;
      }
      rejectPromise(error);
    });
    // Use "close" (not "exit"): it fires after the stdout pipe has fully
    // drained, so a large captured manifest is never truncated.
    child.on("close", (code, signal) => {
      if (signal) return rejectPromise(new Error(`${command} exited from signal ${signal}.`));
      if ((code ?? 0) !== 0) {
        return rejectPromise(new Error(`${command} ${args.join(" ")} failed with exit code ${code}.`));
      }
      resolvePromise({ stdout });
    });
  });
}

// ── small helpers ───────────────────────────────────────────────────────────

/**
 * Decide the final documents/ filename for one downloaded artifact.
 *
 * Base name: the CLI-saved name as-is when the server provided one
 * (Content-Disposition = ファイル自動出力設定の名称). When the CLI fell back to
 * its default `report-<id>.<ext>`, build `帳票ID_帳票名称.<ext>` from the
 * manifest instead (公式 DownloadReport の ZIP 内命名 `pdf_帳票ID_帳票名称.pdf`
 * に準拠した、ID込みで衝突しない形)。
 *
 * Discriminators (applied to either base):
 *   -rev<n>      … --history で同一帳票IDが複数リビジョンあるとき
 *   -<artifact>  … 複数タイプ要求時 (pdf と pdfLayer は同じ .pdf で衝突する)
 *   _<帳票ID>    … それでも他帳票のサーバ名と衝突したとき (自動出力設定が
 *                  帳票名のみ等、ID を含まない場合に起こる)
 */
function chooseArtifactFileName(downloadedName, ctx) {
  // サーバ提供名（Content-Disposition = ファイル自動出力設定の名称）が percent-encoded のことがある:
  // i-repo CLI が RFC5987 `filename*=UTF-8''…` を復号せずに書くと、Windows で帳票名が
  // `%E5%85%AB%E7%8E%8B%E5%AD%90…pdf` のようなファイル名になる（実機報告）。表示名は復号して
  // 元の名前（日本語等）へ戻す。%XX を含まない名前・不正な % 列はそのまま（decodeServerFileName 参照）。
  const serverName = decodeServerFileName(downloadedName);
  const dot = serverName.lastIndexOf(".");
  let stem = dot > 0 ? serverName.slice(0, dot) : serverName;
  let ext = dot > 0 ? serverName.slice(dot) : fileExtensionFor(ctx.artifact);

  // fallback 判定は CLI が書いた生の名前で行う（report-<id>.<ext> は % を含まないので復号の影響なし）。
  const cliFallback = `report-${ctx.reportId}${fileExtensionFor(ctx.artifact)}`;
  if (downloadedName === cliFallback) {
    // サーバ名なし → manifest の帳票名称から組み立てる (日本語は保持)。
    // 封筒 (SCHEMA.md §2.5) では帳票名称は values.name に入る。
    // 封筒でない生の行 (recordTypes:["*"] 経由) のために record.name も見る。
    const rawName =
      (ctx.record.values && typeof ctx.record.values.name === "string"
        ? ctx.record.values.name.trim()
        : "") ||
      (typeof ctx.record.name === "string" ? ctx.record.name.trim() : "");
    const cleanName = rawName ? sanitizeUnicodeFileName(rawName) : "";
    stem = cleanName
      ? `${sanitizeFileName(ctx.reportId)}_${cleanName}`
      : sanitizeFileName(ctx.reportId);
  } else {
    // サーバ提供名: 復号後を無害化する。**stem だけでなく ext も**潰すのが要点 — 復号で `%2F`→`/` や
    // `%2E%2E`→`..` が ext 側に入ると `documents/` 外への書き込み（パストラバーサル）になり得るため
    // （Cursor P1）。sanitizeUnicodeFileName は区切り(/ \)・禁止文字を `_` 化し、末尾の `.`/空白を除く
    // ので、`.`/`..` は空文字になる（日本語は保持）。
    stem = sanitizeUnicodeFileName(stem);
    ext = sanitizeUnicodeFileName(ext);
  }
  // `..`/`.` などが全て削れて空になった basename は親ディレクトリを指すので、id ベースへ倒して
  // 必ず `documents/` 内の正規ファイル名にする（区切りは上で除去済み＝以降は単一コンポーネント）。
  if (!stem) stem = sanitizeFileName(ctx.reportId);
  if (!ext || ext === ".") ext = fileExtensionFor(ctx.artifact);

  if (ctx.needsRev) stem += `-rev${sanitizeFileName(ctx.revNo)}`;
  if (ctx.multipleArtifacts) stem += `-${sanitizeFileName(ctx.artifact)}`;

  let fileName = `${stem}${ext}`;
  if (ctx.usedNames.has(fileName)) fileName = `${stem}_${sanitizeFileName(ctx.reportId)}${ext}`;
  for (let n = 2; ctx.usedNames.has(fileName); n++) {
    fileName = `${stem}_${sanitizeFileName(ctx.reportId)}-${n}${ext}`;
  }
  return fileName;
}

/**
 * 帳票名称をファイル名に使えるよう無害化する。sanitizeFileName と違い
 * 日本語等の Unicode は保持し、パス区切り・制御文字・Windows 禁止文字のみ潰す。
 * 末尾のドット/空白は Windows が黙って剥がすため先に剥がす — ディスク上の
 * 名前と一致させ、usedNames の衝突検出が迂回されないようにする。
 */
function sanitizeUnicodeFileName(value) {
  return value.replace(/[/\\<>:"|?*\u0000-\u001f\u007f]/g, "_").replace(/[. ]+$/, "");
}

/**
 * サーバ提供のファイル名が percent-encoded（RFC5987 `filename*=UTF-8''…` を CLI が復号せず書く）の
 * とき復号して元の名前（日本語等）へ戻す。Windows で帳票名が `%E5%85%AB…` のファイル名になる問題への対応。
 * `%XX` を含まない名前はそのまま。不正な % 列（`decodeURIComponent` が投げる）も元の名前を返す（壊さない）。
 */
function decodeServerFileName(name) {
  if (!/%[0-9A-Fa-f]{2}/.test(name)) return name;
  try {
    return decodeURIComponent(name);
  } catch {
    return name;
  }
}

function fileExtensionFor(artifact) {
  return artifact === "excel" ? ".xlsx" : ".pdf"; // pdf / pdfLayer → .pdf
}

function sanitizeFileName(value) {
  return value.replace(/[^A-Za-z0-9._-]/g, "_");
}

async function writeTextFile(path, content) {
  await fsp.mkdir(dirname(path), { recursive: true });
  await fsp.writeFile(path, content, "utf8");
}

async function writeJsonFile(path, content) {
  await writeTextFile(path, JSON.stringify(content, null, 2) + "\n");
}

function compactObject(input) {
  return Object.fromEntries(Object.entries(input).filter(
    ([, value]) => value !== undefined && value !== false &&
      !(Array.isArray(value) && value.length === 0),
  ));
}

function timestampTag(date = new Date()) {
  const pad = (n) => String(n).padStart(2, "0");
  return `${date.getFullYear()}${pad(date.getMonth() + 1)}${pad(date.getDate())}T` +
    `${pad(date.getHours())}${pad(date.getMinutes())}${pad(date.getSeconds())}`;
}

// {date} = YYYY-MM-DD（{datetime} は timestampTag が担う）。
function dateTag(date = new Date()) {
  const pad = (n) => String(n).padStart(2, "0");
  return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
}

const PREFIX_MAX_LEN = 200; // 宛先キー総長の上限（S3/GCS/Azure のキー長・Windows パス長の安全側）。
// push-local で危険な Windows 予約デバイス名（拡張子付きも同様に予約）。セグメント単位で弾く。
const WIN_RESERVED = /^(con|prn|aux|nul|com[1-9]|lpt[1-9])(\.|$)/i;

/**
 * --prefix テンプレートを解決し、アップロード先キーとして安全な「相対パス」へ無害化する。
 * これはオブジェクトストレージ/ローカルの宛先キーを組み立てる security-sensitive な経路:
 * バケット/--to の外へ出る（先頭 /・.. 上昇・ドライブ文字・UNC・scheme 注入）ことを必ず防ぐ。
 * 無害化後に空・危険判定なら batchDir へフォールバックし、空/ルート/越境の宛先は絶対に作らない。
 * {flow} は host が env で渡す（IREPO_FLOW_NAME）。Rust 指紋同様、値は host 由来で plugin は料理しない。
 */
function resolvePrefixTemplate(template, { batchDir }) {
  // {flow} は env 生値。template と同様に制御文字を除去してから差し込む（防御深度・Cursor P2）。
  const flow = (process.env.IREPO_FLOW_NAME || "").replace(/[\x00-\x1f\x7f]/g, "");
  const now = new Date();
  // 制御文字を先に除去（置換前の生入力に \0 等が混ざる事故を断つ）。
  const substituted = String(template)
    .replace(/[\x00-\x1f\x7f]/g, "")
    .replace(/\{batchId\}/g, batchDir)
    .replace(/\{datetime\}/g, timestampTag(now))
    .replace(/\{date\}/g, dateTag(now))
    .replace(/\{flow\}/g, flow);
  // `/` と `\` 双方で分割（Windows 風入力が segment 跨ぎにならないよう）→ 各 segment を無害化 → 空/./.. を除去。
  // Windows 予約デバイス名（CON/NUL/COM1…）は push-local で危険なので先頭に `_` を付けて無害化する。
  const segments = substituted
    .split(/[/\\]/)
    .map((seg) => sanitizeUnicodeFileName(seg))
    .map((seg) => (WIN_RESERVED.test(seg) ? `_${seg}` : seg))
    .filter((seg) => seg !== "" && seg !== "." && seg !== "..");
  const safe = segments.join("/");
  // 再結合後ガード: 相対パスのみ許可。絶対/ドライブ/UNC/scheme 等が残ったら宛先を作らず batchDir へ倒す
  // （path.join(base,'/abs'|'C:/x') が base を無視して外へ出る事故・scheme 注入を防ぐ）。
  const unsafe =
    safe === "" ||
    safe.length > PREFIX_MAX_LEN ||
    /^[/\\]/.test(safe) ||            // 先頭スラッシュ（絶対）
    /^[A-Za-z]:/.test(safe) ||        // ドライブ文字 C:
    /^\/\//.test(safe) ||             // UNC //server
    /:\//.test(safe) ||               // scheme っぽい :/ の残骸
    /^[a-z][a-z0-9+.-]*:/i.test(safe); // scheme（file: 等）
  return unsafe ? batchDir : safe;
}

function joinS3Uri(prefix, child) {
  return `${prefix.replace(/\/+$/, "")}/${child.replace(/^\/+/, "")}`;
}

/**
 * --to トークンを URI パスセグメント安全な**単一トークン**へ無害化する（issue #89）。
 * `sanitizeUnicodeFileName` が `/\` 等を `_` に潰す（パス深さ注入防止）のに加え、URI 予約/
 * 問題文字（`#`・`?`・`@`・`%`・空白）も `_` にする — これで dest が round-trippable かつ
 * 全ストアで安全（azure の `[?#]` 拒否や `#` フラグメント切れを防ぐ）。Windows 予約名も無害化。
 */
function sanitizeToToken(value) {
  let s = sanitizeUnicodeFileName(String(value).replace(/[\x00-\x1f\x7f]/g, ""));
  s = s.replace(/[#?@%\s]/g, "_");
  return WIN_RESERVED.test(s) ? `_${s}` : s;
}

/**
 * --to のテンプレートを展開する（issue #89・§9.4a）。dest は**バッチ非依存**でなければ
 * ならないので、--to で許すのは**安定キー `{flow}` のみ**。run-varying トークン
 * （{batchId}/{datetime}/{date}）は --prefix（実行フォルダ）専用で、--to にあれば拒否する。
 * {flow} は host が env(IREPO_FLOW_NAME) で渡す。scheme/bucket/区切りは保持。
 */
function expandToTemplate(to) {
  const raw = String(to).replace(/[\x00-\x1f\x7f]/g, "");
  if (/\{(batchId|datetime|date)\}/.test(raw)) {
    throw new Error(
      "--to must not contain run-varying tokens ({batchId}/{datetime}/{date}) — dest must be batch-independent; " +
      "put those in --prefix. --to may use {flow} only.",
    );
  }
  const flow = sanitizeToToken(process.env.IREPO_FLOW_NAME || "");
  const expanded = raw.replace(/\{flow\}/g, flow);
  // 空 {flow} 等で生じる連続スラッシュを畳む（scheme の :// は保持）。
  return expanded.replace(/(?<!:)\/{2,}/g, "/");
}

/**
 * 展開後 --to から、バッチに依らず安定した canonical な store location（dest）を作る（issue #89）。
 * DC(gemba-os) catalog.rs の canonical_dest と同形（単一コロン）: s3:bucket/prefix・gcs:bucket/prefix・
 * azure:account/container[/prefix]・dir:absPath。実行フォルダ（--prefix/destSub）は dest に含めない。
 * secret(userinfo) は含めない（azure --to は query/SAS を parseAzureTo で既に拒否）。
 */
function canonicalBundleDest(store, expandedTo) {
  if (store === "s3" || store === "gcs") {
    const scheme = store === "s3" ? "s3://" : "gs://";
    const rest = String(expandedTo).slice(scheme.length).replace(/\/+$/, ""); // bucket[/prefix...]
    return `${store === "s3" ? "s3" : "gcs"}:${rest}`;
  }
  if (store === "azure") {
    const { account, container, prefix } = parseAzureTo(expandedTo);
    return prefix ? `azure:${account}/${container}/${prefix}` : `azure:${account}/${container}`;
  }
  // local: 絶対パスへ正規化して dir: スキーム（dir-bundle と同表現）。
  const abs = resolve(normalizeLocalDest(expandedTo));
  return `dir:${abs}`;
}
