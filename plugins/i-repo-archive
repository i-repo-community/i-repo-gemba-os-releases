// ── Contract version check: unsupported → stderr + exit 11 ──
const announcedApi = process.env.IREPO_PLUGIN_API;
if (arg0 !== "--plugin-healthcheck" && announcedApi && announcedApi !== PLUGIN_API) {
  console.error(`${PLUGIN}: unsupported IREPO_PLUGIN_API=${announcedApi} (supported: ${PLUGIN_API})`);
  process.exit(11);
}

loadBuiltins()
  .then(() =>
    arg0 === "--plugin-healthcheck"
      ? healthcheck().then((ok) => process.exit(ok ? 0 : 1))
      : main(),
  )
  .catch((error) => {
    console.error(`${PLUGIN}: ${error instanceof Error ? error.message : String(error)}`);
    process.exitCode = 1;
  });

async function healthcheck() {
  const checks = [];
  const irepoOk = await commandExists(iRepoBin(), ["--version"]);
  checks.push({
    name: "i-repo-cli", ok: irepoOk, severity: "required",
    hint: "Install i-repo (npm i -g i-repo) or fix PATH",
  });
  // クラウド転送 CLI は各 push サブコマンド専用 — severity でスコープを示すので、
  // 不在でも全体の ok は落とさない（i-repo CLI だけが必須）。
  const awsOk = await commandExists("aws", ["--version"]);
  checks.push({
    name: "aws-cli", ok: awsOk, severity: "required-for:push-s3",
    hint: "Install AWS CLI v2 to use push-s3",
  });
  const gcloudOk = await commandExists("gcloud", ["--version"]);
  checks.push({
    name: "gcloud-cli", ok: gcloudOk, severity: "required-for:push-gcs",
    hint: "Install Google Cloud SDK (gcloud) to use push-gcs",
  });
  const azOk = await commandExists("az", ["--version"]);
  checks.push({
    name: "az-cli", ok: azOk, severity: "required-for:push-azure",
    hint: "Install Azure CLI (az) to use push-azure",
  });
  // push-local は Node 組み込み fs でコピーするため外部 CLI 不要 — 常に充足。
  checks.push({
    name: "local-fs", ok: true, severity: "required-for:push-local",
    hint: "No external CLI needed (uses Node fs)",
  });
  const ok = irepoOk;
  console.log(JSON.stringify({ ok, checks }));
  return ok;
}

