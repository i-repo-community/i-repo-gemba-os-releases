#!/usr/bin/env node
/**
 * i-repo-archive — example plugin: stage report archives locally, then
 * optionally push the finished bundle to Amazon S3.
 *
 * ZERO DEPENDENCIES by design: a single file using Node 20 built-ins only.
 * i-repo itself requires Node >= 20 (package.json engines), so Node is
 * guaranteed to exist wherever i-repo runs — no npm install, no lockfile,
 * no supply-chain surface. This is the recommended shape for plugins.
 *
 * Cross-platform: works on macOS / Linux / Windows.
 *   macOS/Linux: copy this file to ~/.i-repo/plugins/i-repo-archive && chmod +x
 *   Windows:     copy BOTH this file and i-repo-archive.cmd (the shim next to
 *                it) into %USERPROFILE%\.i-repo\plugins\
 *
 * Contract (docs/PLUGINS.md, docs/SCHEMA.md):
 *   - reserved flags --plugin-healthcheck / --plugin-schema
 *   - IREPO_PLUGIN_API version check (exit 11 on mismatch)
 *   - stream-end trailer validation on the manifest (SCHEMA.md §2.6)
 *   - receipts on stdout in the frozen §6 shape (write → verify phases)
 *
 * Usage:
 *   i-repo archive create [filters...] [--out DIR] [--with-artifacts pdf,excel]
 *   i-repo archive push-s3 <archive-dir> --to s3://bucket/prefix [--cleanup] [--dry-run]
 *
 * Artifact naming: the server-provided filename (Content-Disposition =
 * ファイル自動出力設定の名称) is used when available; otherwise
 * 帳票ID_帳票名称.<ext>. Collisions get a _帳票ID suffix.
 * --cleanup deletes the local archive only after the upload is verified.
 */
"use strict";

// Loaded via dynamic import() so this single extensionless file runs under
// BOTH module systems: inside a "type":"module" package tree it is ESM, while
// in ~/.i-repo/plugins (no package.json above) Node loads it as CommonJS.
// Static require()/import would each break in one of the two environments.
let spawn, fs, fsp, homedir, tmpdir, basename, dirname, join, resolve, sep;
async function loadBuiltins() {
  ({ spawn } = await import("node:child_process"));
  fs = await import("node:fs");
  fsp = await import("node:fs/promises");
  ({ homedir, tmpdir } = await import("node:os"));
  ({ basename, dirname, join, resolve, sep } = await import("node:path"));
}

