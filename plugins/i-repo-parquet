      { name: "--iceberg-endpoint", type: "string",
        label: "Iceberg RESTカタログURL", placeholder: "http://localhost:8181",
        description: "Iceberg REST catalog endpoint (Icebergモード)" },
      { name: "--warehouse", type: "string",
        label: "ウェアハウス名", placeholder: "warehouse",
        description: "Iceberg warehouse name to ATTACH" },
      { name: "--iceberg-table", type: "string",
        label: "テーブル（ns.table）", placeholder: "irepo.reports",
        description: "Target table as namespace.table (created if missing)" },
      { name: "--s3-endpoint", type: "string",
        label: "S3/MinIOエンドポイント（任意）", placeholder: "http://localhost:9000",
        description: "Object store endpoint for Iceberg data files (MinIO等。省略時はAWS S3)" },
      { name: "--s3-key-id", type: "string",
        label: "S3アクセスキー（任意）",
        description: "Object store access key id" },
