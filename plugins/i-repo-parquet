        description: "配信元 i-Reporter の endpointFp に厳格一致で絞る（未タグ=旧配信は除外・gemba-adc/1.1 §3.9）" },
    ],
    // ── ADC-1（gemba-adc/1.0）着地スキーマ宣言。--iceberg-table の有無で2形態 ──
    dataset: [
      { datasetApi: ["1"], contract: "gemba-adc/1.2", store: "parquet",
        selector: { param: "--iceberg-table", present: false },
        locator: { out: { param: "--out" } },
        naming: "snake_case",
        keys: { primary: "idempotency_key", upsert: false, dedupe: null },
        contents: "latest-batch-only",
        fields: parquetFields(),
        quirks: ["raw-json-embedded", "string-dates", "non-json-sentinel", "overwrite-on-rerun", "detail-optional"] },
      { datasetApi: ["1"], contract: "gemba-adc/1.2", store: "iceberg",
        selector: { param: "--iceberg-table", present: true },
        // locator は query が必要とする接続フラグを**全て**宣言する（access.query の正本になる。
        // 漏らすと読み返しがその引数なしで実行され失敗する — レビューで --warehouse 欠落を検出済み）。
        locator: {
          table: { param: "--iceberg-table" }, endpoint: { param: "--iceberg-endpoint" },
          warehouse: { param: "--warehouse" },
          s3Endpoint: { param: "--s3-endpoint" }, s3KeyId: { param: "--s3-key-id" },
          s3Secret: { param: "--s3-secret", secret: true }, s3Region: { param: "--s3-region", default: "us-east-1" },
        },
        naming: "snake_case",
        keys: { primary: "idempotency_key", upsert: false, dedupe: "latest-wins-by-key" },
