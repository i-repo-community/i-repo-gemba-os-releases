    ],
  }) + "\n");
  process.exit(0);
}

// flat10 列（Parquet/Iceberg 共通）。正準名でストア間命名分裂を橋渡しする。
function parquetFields() {
  return [
    { name: "idempotency_key", canonical: "idempotencyKey", source: "idempotencyKey", type: "string", role: "key" },
    { name: "record_type", canonical: "recordType", source: "recordType", type: "string" },
    { name: "item_id", canonical: "itemId", source: "itemId", type: "string", role: "report-id" },
    { name: "rev_no", canonical: "revNo", source: "revNo", type: "string", role: "revision" },
    { name: "name", canonical: "name", source: "values.name", type: "string", pii: "possible" },
    { name: "deleted", canonical: "deleted", source: "deleted", type: "boolean" },
    { name: "regist_time", canonical: "registTime", source: "values.registTime", type: "datetime", storedAs: "string", format: "local-datetime-slash", timezone: "local" },
    { name: "update_time", canonical: "updateTime", source: "values.updateTime", type: "datetime", storedAs: "string", format: "local-datetime-slash", timezone: "local" },
    { name: "raw_json", canonical: "raw", source: ".", type: "json-string", schemaRef: "envelope/1.0", pii: "likely" },
    { name: "loaded_at", canonical: "loadedAt", type: "datetime", storedAs: "string", format: "iso8601", timezone: "utc", role: "lineage" },
    { name: "endpoint_fp", canonical: "endpointFp", source: "provenance.endpointFingerprint", type: "string", role: "tenant", description: "配信元 i-Reporter エンドポイントの正準指紋（テナント同一性・gemba-adc/1.1）。旧配信行は NULL/列不在" },
  ];
}

if (argv[0] === "--plugin-healthcheck") {
  const checks = [];
  const has = spawnSyncSpec("duckdb", ["--version"], { encoding: "utf8" });
  const duckOk = has.status === 0;
  checks.push({ name: "duckdb", ok: duckOk, severity: "required",
    hint: duckOk ? `duckdb ${String(has.stdout).trim()}`
      : "DuckDB CLI をインストールしてください（brew install duckdb 等）" });
  const ok = checks.every((c) => c.ok);
  process.stdout.write(JSON.stringify({ ok, checks }) + "\n");
  process.exit(ok ? 0 : 1);
}

// ── 契約バージョン ───────────────────────────────────────────────────
if (process.env.IREPO_PLUGIN_API && process.env.IREPO_PLUGIN_API !== "1") {
  console.error(`${PLUGIN}: unsupported IREPO_PLUGIN_API=${process.env.IREPO_PLUGIN_API} (supported: 1)`);
  process.exit(11);
}

// ── query サブコマンド（ADC-1 / gemba-read/1.0・読み取り専用） ─────────
// 着地済みレコードを「正準封筒形」で読み出す。書込・新規作成・スキーマ変更はしない。
// 成功は末尾 query-end トレーラの存在で判定（契約 §3.4）。0件でも query-end を出す。
// 読み取り手段は duckdb CLI を spawn（SELECT のみ）。parquet は read_parquet、
// iceberg は write 経路と同じ ATTACH 手順で SELECT し、追記重複を QUALIFY で排除する。
// 共通部（envelope/時刻3形式/カーソル/フラグ解析）は lib/gemba-read.js（正本: plugins/lib/）。
// ここにはストア固有部（duckdb 実行・SQL構築・record復元・dest）だけを置く。
if (argv[0] === "query") {
  let G;
  try { G = require("./lib/gemba-read.js"); }
  catch {
    console.error(JSON.stringify({ schemaVersion: "1.0", recordType: "error", contract: "gemba-read/1.0",
      plugin: PLUGIN, code: "E_INTERNAL",
      message: "gemba-read ライブラリが見つかりません（lib/gemba-read.js）。plugins/install.sh を再実行してください",
      retryable: false }));
    process.exit(1);
  }
  runQuery(argv.slice(1), G);   // 内部で process.exit。以降へは進まない。
}

// ── aggregate サブコマンド（gemba-adc/1.2・構造化集計・読み取り専用） ─────
// エージェント面に生 SQL を渡さず、次元(group_by)＋指標(measure)で集計する（audience:human 境界を保つ）。
if (argv[0] === "aggregate") {
  let G;
  try { G = require("./lib/gemba-read.js"); }
  catch {
    console.error(JSON.stringify({ schemaVersion: "1.0", recordType: "error", contract: "gemba-read/1.0",
      plugin: PLUGIN, code: "E_INTERNAL",
      message: "gemba-read ライブラリが見つかりません（lib/gemba-read.js）。plugins/install.sh を再実行してください",
      retryable: false }));
    process.exit(1);
  }
  runAggregate(argv.slice(1), G);   // 内部で process.exit。以降へは進まない。
}

function runQuery(qargs, G) {
  const { queryEnd, emitRow, queryError } = G.createReadKit(PLUGIN);
  const opts = G.parseQueryArgs(qargs, {
    "--out": "out", "--iceberg-endpoint": "icebergEndpoint", "--warehouse": "warehouse",
    "--iceberg-table": "icebergTable", "--s3-endpoint": "s3Endpoint",
    "--s3-key-id": "s3KeyId", "--s3-secret": "s3Secret", "--s3-region": "s3Region",
  }, queryError);
  if (!opts.s3Region) opts.s3Region = "us-east-1";

  // --iceberg-table があれば iceberg、なければ --out で parquet（write と同判定）。
  const icebergMode = !!(opts.icebergEndpoint || opts.warehouse || opts.icebergTable);
  if (icebergMode) {
    if (!opts.icebergEndpoint || !opts.warehouse || !opts.icebergTable) {
      queryError("E_ARGS", "Iceberg mode requires --iceberg-endpoint, --warehouse and --iceberg-table", null, 2);
    }
    if (!/^[A-Za-z0-9_]+\.[A-Za-z0-9_]+$/.test(opts.icebergTable)) {
      queryError("E_ARGS", "--iceberg-table must be namespace.table (e.g. irepo.reports)", null, 2);
    }
  } else {
    if (!opts.out) queryError("E_ARGS", "--out <path> (Parquet) or --iceberg-* (Iceberg) is required", "読み取り対象の出力先", 2);
  }

  let outp = opts.out;
  if (outp.startsWith("~/")) outp = path.join(os.homedir(), outp.slice(2));
  const dest = icebergMode ? `iceberg:${opts.icebergTable}@${opts.icebergEndpoint}` : `parquet:${outp}`;
  const dedupeApplied = icebergMode;   // append-only の重複を QUALIFY で排除（§3.3）

  // duckdb 不在は推測せず E_CONNECT。
  const has = spawnSyncSpec("duckdb", ["--version"], { encoding: "utf8" });
  if (has.status !== 0) {
    queryError("E_CONNECT", "duckdb CLI not found", "DuckDB CLI をインストールしてください（brew install duckdb 等）", 1, dest);
  }

  // parquet モードはファイル不在を CREATE せず E_NOT_FOUND（§3.7）。
  if (!icebergMode && !fs.existsSync(outp)) {
    queryError("E_NOT_FOUND", `parquet not found: ${outp}`, "配信が一度も成功していない可能性があります", 1, dest);
  }

  // ── ソース式と setup（write 経路の ATTACH 手順を踏襲） ────────────────
  let setup = "";
  let srcExpr;
  if (icebergMode) {
    const [ns, tbl] = opts.icebergTable.split(".");
    setup = "INSTALL iceberg; LOAD iceberg; INSTALL httpfs; LOAD httpfs;\n";
    if (opts.s3KeyId || opts.s3Endpoint) {
      const ep = opts.s3Endpoint.replace(/^https?:\/\//, "");
      const ssl = opts.s3Endpoint.startsWith("https://");
      setup += `CREATE OR REPLACE SECRET obj (TYPE s3, KEY_ID ${q(opts.s3KeyId)}, SECRET ${q(opts.s3Secret)}, ` +
        `REGION ${q(opts.s3Region)}${opts.s3Endpoint ? `, ENDPOINT ${q(ep)}, URL_STYLE 'path', USE_SSL ${ssl}` : ""});\n`;
    }
    setup += `ATTACH ${q(opts.warehouse)} AS ic (TYPE iceberg, ENDPOINT ${q(opts.icebergEndpoint)}, AUTHORIZATION_TYPE 'none');\n`;
    srcExpr = `ic."${ns}"."${tbl}"`;
  } else {
    srcExpr = `read_parquet(${q(outp)})`;
  }

  // WHERE 構築。時刻境界は lib が格納形式（loaded=ISO / 業務時刻=slashローカル）へ正規化済み。
  const where = [];
  // テナント厳格フィルタ（gemba-adc/1.1 §3.9）: endpoint_fp に完全一致。列を持たない旧ストア
  // （v0.2.0 以前の parquet ファイル / iceberg テーブル）はエラーにせず 0 件（厳格・fail-closed）。
  // 列 probe（DESCRIBE）は絞るときだけ行う。未指定なら全件（後方互換）。
  if (opts.endpointFp) {
    const probe = runDuckdbJson(setup +
      `SELECT column_name FROM (DESCRIBE SELECT * FROM ${srcExpr}) WHERE column_name = ${q("endpoint_fp")};`);
    let hasCol = false;
    if (probe.status === 0) { try { hasCol = parseDuckdbJsonArrays(probe.stdout).length > 0; } catch { hasCol = false; } }
    if (hasCol) where.push(`endpoint_fp = ${q(opts.endpointFp)}`);
    else where.push("false");   // 列不在＝未タグ扱いで厳格に 0 件（DuckDB は WHERE false を許容）
  }
  const col = opts.timeField === "updated" ? "update_time" : opts.timeField === "registered" ? "regist_time" : "loaded_at";
  const bounds = G.timeBounds(opts, col === "loaded_at" ? "iso" : "slash", queryError, dest);
  if (bounds?.gte) where.push(`${col} >= ${q(bounds.gte)}`);
  if (bounds?.lt) where.push(`${col} < ${q(bounds.lt)}`);   // 半開区間 [since, until)
  // query-end の timeFilter 報告（parquet 固有）は常に UTC ISO で持つ。
  // timeBounds が解釈不能時に exit 済みなので、ここでの再パースは必ず成功する。
  const sinceUtc = opts.since != null ? G.parseFlexibleDate(opts.since).toISOString() : null;
  const untilUtc = opts.until != null ? G.parseFlexibleDate(opts.until).toISOString() : null;
  if (opts.deleted != null) { where.push(`deleted = ${opts.deleted ? "true" : "false"}`); }
  if (opts.ids && opts.ids.length) { where.push(`idempotency_key IN (${opts.ids.map((s) => q(s)).join(",")})`); }
  if (opts.itemIds.length) { where.push(`item_id IN (${opts.itemIds.map((s) => q(s)).join(",")})`); }

  // iceberg は追記重複があるため、冪等キー単位で loaded_at 最新の1行へ畳む（dedupHint）。
  const dedupQual = icebergMode
    ? " QUALIFY row_number() OVER (PARTITION BY idempotency_key ORDER BY loaded_at DESC) = 1"
    : "";
  const baseWhereSql = where.length ? ` WHERE ${where.join(" AND ")}` : "";

  const timeFilter = (sinceUtc || untilUtc) ? { field: opts.timeField, sinceUtc, untilUtc } : null;

  if (opts.countOnly) {
    // dedup 後の総件数を数える（iceberg は重複排除後の論理件数）。
    const sql = setup +
      `SELECT COUNT(*) AS n FROM (SELECT idempotency_key FROM ${srcExpr}${baseWhereSql}${dedupQual}) AS t;`;
    const r = runDuckdbJson(sql);
    if (r.status !== 0) {
      const msg = (r.stderr || r.stdout || "duckdb count failed").trim();
      queryError("E_INTERNAL", msg, null, 1, dest);
    }
    let total = 0;
    try { const arr = parseDuckdbJsonArrays(r.stdout); total = arr.length ? Number(arr[0].n) : 0; }
    catch (e) { queryError("E_INTERNAL", `cannot parse duckdb output: ${e.message}`, null, 1, dest); }
    const end = { count: 0, complete: true, total, nextCursor: null, dest, dedupeApplied };
    if (timeFilter) end.timeFilter = timeFilter;
    queryEnd(end);
    process.exit(0);
  }

  // keyset ページング（idempotency_key 昇順・決定的）
  const pageWhere = [...where];
  if (opts.cursor != null) {
    const last = G.decodeCursor(opts.cursor);
    if (last == null) queryError("E_CURSOR", "カーソルが不正です", "前回の query-end.nextCursor をそのまま渡してください", 2, dest);
    pageWhere.push(`idempotency_key > ${q(last)}`);
  }
  const pageWhereSql = pageWhere.length ? ` WHERE ${pageWhere.join(" AND ")}` : "";

  // dedup を先に適用してからページングする（カーソルが論理行に乗るように）。
  const inner = `SELECT idempotency_key, record_type, raw_json, loaded_at FROM ${srcExpr}${pageWhereSql}${dedupQual}`;
  const sql = setup +
    `SELECT idempotency_key, record_type, raw_json, loaded_at FROM (${inner}) AS t ` +
    `ORDER BY idempotency_key ASC LIMIT ${opts.limit};`;

  const r = runDuckdbJson(sql);
  if (r.status !== 0) {
    const msg = (r.stderr || r.stdout || "duckdb query failed").trim();
    queryError("E_INTERNAL", msg, null, 1, dest);
  }
  let rows;
  try { rows = parseDuckdbJsonArrays(r.stdout); }
  catch (e) { queryError("E_INTERNAL", `cannot parse duckdb output: ${e.message}`, null, 1, dest); }

  let lastKey = null;
  for (const row of rows) {
    lastKey = row.idempotency_key;
    let record;
    try { record = JSON.parse(row.raw_json); }
    catch { record = { _raw: row.raw_json }; }
    let outRec = record;
    if (!opts.raw && opts.fields && record && record._raw === undefined) outRec = G.pickFields(record, opts.fields);
    emitRow(row.idempotency_key, row.loaded_at, outRec, opts.raw);
  }
  const complete = rows.length < opts.limit;
  const end = {
    count: rows.length, complete,
    nextCursor: complete ? null : G.encodeCursor(lastKey),
    dest, dedupeApplied,
  };
  if (timeFilter) end.timeFilter = timeFilter;
  queryEnd(end);
  process.exit(0);
}

function runAggregate(aargs, G) {
  const { queryEnd, emitAggRow, queryError } = G.createReadKit(PLUGIN);
  const opts = G.parseAggregateArgs(aargs, {
    "--out": "out", "--iceberg-endpoint": "icebergEndpoint", "--warehouse": "warehouse",
    "--iceberg-table": "icebergTable", "--s3-endpoint": "s3Endpoint",
    "--s3-key-id": "s3KeyId", "--s3-secret": "s3Secret", "--s3-region": "s3Region",
  }, queryError);
  if (!opts.s3Region) opts.s3Region = "us-east-1";

  // --iceberg-table があれば iceberg、なければ --out で parquet（write/query と同判定）。
  const icebergMode = !!(opts.icebergEndpoint || opts.warehouse || opts.icebergTable);
  if (icebergMode) {
    if (!opts.icebergEndpoint || !opts.warehouse || !opts.icebergTable) {
      queryError("E_ARGS", "Iceberg mode requires --iceberg-endpoint, --warehouse and --iceberg-table", null, 2);
    }
    if (!/^[A-Za-z0-9_]+\.[A-Za-z0-9_]+$/.test(opts.icebergTable)) {
      queryError("E_ARGS", "--iceberg-table must be namespace.table (e.g. irepo.reports)", null, 2);
    }
  } else {
    if (!opts.out) queryError("E_ARGS", "--out <path> (Parquet) or --iceberg-* (Iceberg) is required", "集計対象の出力先", 2);
  }

  let outp = opts.out;
  if (outp.startsWith("~/")) outp = path.join(os.homedir(), outp.slice(2));
  const dest = icebergMode ? `iceberg:${opts.icebergTable}@${opts.icebergEndpoint}` : `parquet:${outp}`;

  // duckdb 不在は推測せず E_CONNECT。
  const has = spawnSyncSpec("duckdb", ["--version"], { encoding: "utf8" });
  if (has.status !== 0) {
    queryError("E_CONNECT", "duckdb CLI not found", "DuckDB CLI をインストールしてください（brew install duckdb 等）", 1, dest);
  }

  // parquet モードはファイル不在を CREATE せず E_NOT_FOUND（§3.7）。
  if (!icebergMode && !fs.existsSync(outp)) {
    queryError("E_NOT_FOUND", `parquet not found: ${outp}`, "配信が一度も成功していない可能性があります", 1, dest);
  }

  // ── ソース式と setup（write/query 経路の ATTACH 手順を踏襲） ────────────
  let setup = "";
  let srcExpr;
  if (icebergMode) {
    const [ns, tbl] = opts.icebergTable.split(".");
    setup = "INSTALL iceberg; LOAD iceberg; INSTALL httpfs; LOAD httpfs;\n";
    if (opts.s3KeyId || opts.s3Endpoint) {
      const ep = opts.s3Endpoint.replace(/^https?:\/\//, "");
      const ssl = opts.s3Endpoint.startsWith("https://");
      setup += `CREATE OR REPLACE SECRET obj (TYPE s3, KEY_ID ${q(opts.s3KeyId)}, SECRET ${q(opts.s3Secret)}, ` +
        `REGION ${q(opts.s3Region)}${opts.s3Endpoint ? `, ENDPOINT ${q(ep)}, URL_STYLE 'path', USE_SSL ${ssl}` : ""});\n`;
    }
    setup += `ATTACH ${q(opts.warehouse)} AS ic (TYPE iceberg, ENDPOINT ${q(opts.icebergEndpoint)}, AUTHORIZATION_TYPE 'none');\n`;
    srcExpr = `ic."${ns}"."${tbl}"`;
  } else {
    srcExpr = `read_parquet(${q(outp)})`;
  }

  // ── 次元（group_by）→ SELECT 式。未宣言フィールドは拒否・scoped では PII 次元を拒否（多層）──
  const dimSelects = [], dimKeys = [], groupExprs = [];
  for (const g of opts.groupBy) {
    const meta = FIELD_META[g.field];
    if (!meta) queryError("E_ARGS", `未宣言のフィールドは次元にできません: ${g.field}`, "schema.fields の正準名のみ", 2, dest);
    if (opts.noPiiDimensions && meta.pii) queryError("E_ARGS", `PII 宣言フィールドは次元(group_by)に使えません（テナント分離セッション）: ${g.field}`, "集計でも値集合が露出するため", 2, dest);
    if (g.kind === "field") {
      dimKeys.push(g.field);
      dimSelects.push(`"${meta.col}" AS "${g.field}"`);
      groupExprs.push(`"${meta.col}"`);
    } else { // date_bucket
      if (!meta.datetime) queryError("E_ARGS", `date_bucket は datetime フィールドのみ: ${g.field}`, null, 2, dest);
      const tz = G.resolveBucketTz(g.tz, meta.timezone, queryError, dest);
      // MVP は「変換なしで扱える組合せ」のみ: 局所壁時計(local)は tz を解釈ゾーンとみなし substr、
      // UTC 格納は UTC バケットのみ substr。UTC×非-UTC バケットは DST 変換が要り zero-dep SQL で不可＝未対応。
      if (meta.timezone === "utc" && tz !== "UTC") {
        queryError("E_UNSUPPORTED", `UTC 格納フィールド(${g.field})の非-UTC(${tz})バケットは未対応（MVP）`, "tz=UTC にするか局所時刻フィールドを使う", 2, dest);
      }
      const len = G.bucketSubstrLen(g.granularity);
      const key = `${g.field}_${g.granularity}`;
      dimKeys.push(key);
      dimSelects.push(`substr("${meta.col}", 1, ${len}) AS "${key}"`);
      groupExprs.push(`substr("${meta.col}", 1, ${len})`);
    }
  }

  // ── 指標（measure）→ SELECT 式（count/count_distinct/sum/avg・全て数値）──
  const measSelects = [], measKeys = [];
  for (const m of opts.measures) {
    let expr;
    if (m.op === "count") expr = "COUNT(*)";
    else {
      const meta = FIELD_META[m.field];
      if (!meta) queryError("E_ARGS", `未宣言のフィールドは指標にできません: ${m.field}`, "schema.fields の正準名のみ", 2, dest);
      const c = `"${meta.col}"`;
      // TRY_CAST: 非数値は実行時エラーでなく NULL（SUM/AVG が無視）＝1行でも非数値混入で集計全体が
      // E_INTERNAL になるのを防ぐ（duckdb の CAST はハードエラー）。NULL 無視は SQL の AVG と整合。
      expr = m.op === "count_distinct" ? `COUNT(DISTINCT ${c})`
        : m.op === "sum" ? `SUM(TRY_CAST(${c} AS DOUBLE))`
        : `AVG(TRY_CAST(${c} AS DOUBLE))`; // avg
    }
    measSelects.push(`${expr} AS "${m.alias}"`);
    measKeys.push(m.alias);
  }

  // 出力キー（次元＋指標 alias）は一意でなければならない。衝突すると `AS "x" … AS "x"` となり
  // 出力が破壊される（次元値が指標値で上書きされる・P2）。
  const allKeys = [...dimKeys, ...measKeys];
  const dupKey = allKeys.find((k, i) => allKeys.indexOf(k) !== i);
  if (dupKey) queryError("E_ARGS", `出力キーが重複しています: ${dupKey}`, "group_by 次元と measure alias は一意にする（measure に別名 as を付ける）", 2, dest);

  // ── WHERE（query と同一のフィルタ＋テナント厳格絞り §3.9）──
  const where = [];
  // 列を持たない旧ストア（v0.2.0 以前）はエラーにせず 0 件（厳格・fail-closed）。列 probe は絞るときだけ。
  if (opts.endpointFp) {
    const probe = runDuckdbJson(setup +
      `SELECT column_name FROM (DESCRIBE SELECT * FROM ${srcExpr}) WHERE column_name = ${q("endpoint_fp")};`);
    let hasCol = false;
    if (probe.status === 0) { try { hasCol = parseDuckdbJsonArrays(probe.stdout).length > 0; } catch { hasCol = false; } }
    if (hasCol) where.push(`endpoint_fp = ${q(opts.endpointFp)}`);
    else where.push("false");   // 列不在＝未タグ扱いで厳格に 0 件
  }
  const tcol = opts.timeField === "updated" ? "update_time" : opts.timeField === "registered" ? "regist_time" : "loaded_at";
  const bounds = G.timeBounds(opts, tcol === "loaded_at" ? "iso" : "slash", queryError, dest);
  if (bounds?.gte) where.push(`${tcol} >= ${q(bounds.gte)}`);
  if (bounds?.lt) where.push(`${tcol} < ${q(bounds.lt)}`);   // 半開区間 [since, until)
  if (opts.deleted != null) where.push(`deleted = ${opts.deleted ? "true" : "false"}`);
  if (opts.ids && opts.ids.length) where.push(`idempotency_key IN (${opts.ids.map((s) => q(s)).join(",")})`);
  if (opts.itemIds.length) where.push(`item_id IN (${opts.itemIds.map((s) => q(s)).join(",")})`);
  const whereSql = where.length ? ` WHERE ${where.join(" AND ")}` : "";

  // ── ORDER BY（top-N の決定性）。by は measure alias か dimension key のみ ──
  let orderSql;
  if (opts.orderBy && opts.orderBy.by) {
    if (![...measKeys, ...dimKeys].includes(opts.orderBy.by)) {
      queryError("E_ARGS", `--order-by の対象が不明: ${opts.orderBy.by}`, "measure alias か group_by 次元名", 2, dest);
    }
    orderSql = `ORDER BY "${opts.orderBy.by}" ${opts.orderBy.dir === "asc" ? "ASC" : "DESC"}`;
  } else {
    orderSql = `ORDER BY ${dimKeys.map((k) => `"${k}"`).join(", ")} ASC`; // 既定は次元昇順（安定・再現的）
  }

  // iceberg/parquet の append 重複を集計前に dedup（冪等キー単位で loaded_at 最新の1行へ畳む）。
  // parquet モードは元来キー一意（ファイル上書き）だが、同一 SQL 経路にすることで挙動を一本化する。
  const dedupInner = `SELECT * FROM ${srcExpr}${whereSql} QUALIFY row_number() OVER (PARTITION BY idempotency_key ORDER BY loaded_at DESC) = 1`;

  // limit+1 で取得し超過を truncated 判定（切り捨て群は order で決まる＝§limit 決定性）。
  const sql = setup +
    `SELECT ${[...dimSelects, ...measSelects].join(", ")} FROM (${dedupInner}) AS t ` +
    `GROUP BY ${groupExprs.join(", ")} ${orderSql} LIMIT ${opts.limit + 1};`;

  const r = runDuckdbJson(sql);
  if (r.status !== 0) {
    const msg = (r.stderr || r.stdout || "duckdb aggregate failed").trim();
    queryError("E_INTERNAL", msg, null, 1, dest);
  }
  let rows;
  try { rows = parseDuckdbJsonArrays(r.stdout); }
  catch (e) { queryError("E_INTERNAL", `cannot parse duckdb output: ${e.message}`, null, 1, dest); }

  const truncated = rows.length > opts.limit;
  if (truncated) rows = rows.slice(0, opts.limit);
  for (const row of rows) {
    const dimensions = {}, measures = {};
    for (const k of dimKeys) dimensions[k] = row[k] === undefined ? null : row[k];
    for (const k of measKeys) measures[k] = row[k] == null ? 0 : Number(row[k]);
    emitAggRow(dimensions, measures);
  }
  queryEnd({ count: rows.length, complete: !truncated, truncated, nextCursor: null, dest,
    aggregate: true, groupBy: dimKeys, measures: measKeys });
  process.exit(0);
}

// query 用の duckdb 実行（-json で配列を得る。SELECT のみ＝読み取り専用 §3.7）。
// SQL は -c 引数ではなく stdin で渡す: SQL は cmd.exe メタ文字（括弧・引用符等）を含むため、
// Windows で cmd.exe 経由起動するときに引数に載せると spawnSpec が拒否する（lib/spawn.js）。
function runDuckdbJson(sql) {
  return spawnSyncSpec("duckdb", ["-json"], {
    encoding: "utf8",
    input: sql,
    maxBuffer: 256 * 1024 * 1024,
  });
}

// duckdb -json は「1 文につき 1 配列」を文ごとに出力する。iceberg 経路は実クエリの前に setup 文
// （CREATE SECRET 等）が [{"Success":true}] を吐くため stdout に複数の JSON 配列が並ぶ。しかも複数行
// 結果は配列が改行をまたぐ（行頭 '[' 判定では取りこぼす）。文字列リテラル/エスケープを尊重して括弧深度で
// top-level 配列を切り出し、最後の配列（＝実クエリ結果）だけを parse する。parquet 単文経路は配列 1 個の
// まま不変。gemba-adc/1.1 のテナント列 probe（DESCRIBE）も iceberg では setup 前置になるためこれを通す。
function parseDuckdbJsonArrays(stdout) {
  const text = String(stdout || "");
  let depth = 0, inStr = false, esc = false, start = -1, last = null;
  for (let i = 0; i < text.length; i++) {
    const c = text[i];
    if (inStr) {
      if (esc) esc = false;
      else if (c === "\\") esc = true;
      else if (c === '"') inStr = false;
      continue;
    }
    if (c === '"') inStr = true;
    else if (c === "[") { if (depth === 0) start = i; depth++; }
    else if (c === "]") { if (--depth === 0 && start >= 0) last = text.slice(start, i + 1); }
  }
  return last ? JSON.parse(last) : [];
}

// ── 引数 ─────────────────────────────────────────────────────────────
let out = "", icebergEndpoint = "", warehouse = "", icebergTable = "";
let s3Endpoint = "", s3KeyId = "", s3Secret = "", s3Region = "us-east-1";
let dryRun = false, endpointFpFlag = "";
for (let i = 0; i < argv.length; i++) {
  switch (argv[i]) {
    case "--out":              out = argv[++i] ?? ""; break;
    case "--iceberg-endpoint": icebergEndpoint = argv[++i] ?? ""; break;
    case "--warehouse":        warehouse = argv[++i] ?? ""; break;
    case "--iceberg-table":    icebergTable = argv[++i] ?? ""; break;
    case "--s3-endpoint":      s3Endpoint = argv[++i] ?? ""; break;
    case "--s3-key-id":        s3KeyId = argv[++i] ?? ""; break;
    case "--s3-secret":        s3Secret = argv[++i] ?? ""; break;
    case "--s3-region":        s3Region = argv[++i] ?? "us-east-1"; break;
    case "--dry-run":          dryRun = true; break;
    // 配信元テナント指紋のフォールバック刻印値（gemba-adc/1.1）。レコードが provenance を持たない
    // ときの保険。通常はレコードの provenance.endpointFingerprint を優先。
    case "--endpoint-fp":      endpointFpFlag = (argv[++i] ?? "").trim(); break;
    default: console.error(`unknown option: ${argv[i]}`); process.exit(2);
  }
}

const icebergMode = !!(icebergEndpoint || warehouse || icebergTable);
// dry-run は出力先なしでも入力検証だけ行える（plugin verify が使う経路）
if (!dryRun) {
  if (icebergMode) {
    if (!icebergEndpoint || !warehouse || !icebergTable) {
      console.error("Iceberg mode requires --iceberg-endpoint, --warehouse and --iceberg-table");
      process.exit(2);
    }
    if (!/^[A-Za-z0-9_]+\.[A-Za-z0-9_]+$/.test(icebergTable)) {
      console.error("--iceberg-table must be namespace.table (e.g. irepo.reports)");
      process.exit(2);
    }
  } else if (!out) {
    console.error("--out (Parquet) or --iceberg-endpoint/--warehouse/--iceberg-table (Iceberg) is required");
    process.exit(2);
  }
}
if (out.startsWith("~/")) out = path.join(os.homedir(), out.slice(2));

const jobId = `parquet-${new Date().toISOString().replace(/[-:T]/g, "").slice(0, 15)}-${process.pid}`;
const dest = icebergMode ? `iceberg:${icebergTable}@${icebergEndpoint}` : `parquet:${out}`;

const receipt = (phase, count, failedCount, verified, extra = {}) => {
  process.stdout.write(JSON.stringify({
    schemaVersion: "1.0", recordType: "receipt", plugin: PLUGIN,
    producedBy: { plugin: PLUGIN, version: VERSION },
    phase, jobId, count, failedCount, verified, dest,
    ...(dryRun ? { dryRun: true } : {}),
    ...extra,
  }) + "\n");
};

async function readStdin() {
  const chunks = [];
  for await (const c of process.stdin) chunks.push(c);
  return Buffer.concat(chunks).toString("utf8");
}

// SQL 文字列リテラル用エスケープ（関数宣言: query 経路から先行参照されるため巻き上げ必須）
function q(s) { return "'" + String(s).replace(/'/g, "''") + "'"; }

function runDuckdb(sql) {
  // SQL は stdin で渡す（runDuckdbJson と同じ理由・cmd.exe メタ文字回避）。
  return spawnSyncSpec("duckdb", ["-noheader", "-list"], {
    encoding: "utf8",
    input: sql,
    maxBuffer: 256 * 1024 * 1024,
  });
}

// フラット列スキーマ（i-repo-sqlite と同じ展開。detail/artifacts は raw_json に保持）
const COLUMNS =
  "columns={idempotency_key:'VARCHAR', record_type:'VARCHAR', item_id:'VARCHAR', " +
  "rev_no:'VARCHAR', name:'VARCHAR', deleted:'BOOLEAN', regist_time:'VARCHAR', " +
  "update_time:'VARCHAR', raw_json:'VARCHAR', loaded_at:'VARCHAR', endpoint_fp:'VARCHAR'}";

(async () => {
  const text = await readStdin();
  const lines = text.split("\n").map((l) => l.trim()).filter(Boolean);

  const docs = [];
  let trailer = null, envelopes = 0;
  for (const line of lines) {
    let obj;
    try { obj = JSON.parse(line); } catch { docs.push({ _raw: line }); continue; }
    if (obj && obj.schemaVersion) envelopes++;
    if (obj && obj.recordType === "stream-end") { trailer = obj; continue; }
    docs.push(obj);
  }

  // stream-end 照合（§2.6）
  if (trailer) {
    if (typeof trailer.count !== "number" || trailer.count !== docs.length) {
      console.error(`❌ incomplete stream: trailer count=${trailer.count ?? "unreadable"} but received ${docs.length}`);
      receipt("write", docs.length, docs.length, false);
      process.exit(1);
    }
  } else if (envelopes > 0) {
    console.error("❌ truncated stream: envelope records present but no stream-end trailer");
    receipt("write", docs.length, docs.length, false);
    process.exit(1);
  }

  // フラット行に展開（i-repo-sqlite と同じマッピング）
  const now = new Date().toISOString();
  const rows = docs.map((r, i) => {
    const v = r.values ?? r;
    return {
      idempotency_key: r.idempotencyKey ?? `${jobId}:${i}`,
      record_type: r.recordType ?? null,
      item_id: String(r.itemId ?? v.itemId ?? ""),
      rev_no: String(r.revNo ?? v.revNo ?? ""),
      name: v.name ?? null,
      deleted: r.deleted === true,
      regist_time: v.registTime ?? null,
      update_time: v.updateTime ?? null,
      raw_json: JSON.stringify(r),
      loaded_at: now,
      // テナント指紋: レコードの provenance（マニフェスト由来・SSOT）を最優先。無ければ load フラグで
      // 補完。どちらも無ければ NULL（＝厳格 query で除外・gemba-adc/1.1 §3.9）。
      endpoint_fp: r.provenance?.endpointFingerprint || endpointFpFlag || null,
    };
  });

  if (dryRun) {
    receipt("write", rows.length, 0, false);
    console.error(`(dry-run) would write ${rows.length} row(s) → ${dest}`);
    process.exit(0);
  }

  // 一時 NDJSON に書き出して duckdb に読ませる（引数長制限を回避）
  const tmp = path.join(os.tmpdir(), `${jobId}.ndjson`);
  fs.writeFileSync(tmp, rows.map((r) => JSON.stringify(r)).join("\n") + "\n");
  const cleanup = () => { try { fs.unlinkSync(tmp); } catch { /* noop */ } };

  const src = `read_ndjson(${q(tmp)}, ${COLUMNS})`;
  let writeSql, verifySql;

  if (icebergMode) {
    // ── Iceberg: REST カタログに ATTACH して追記 ──────────────────────
    const [ns, tbl] = icebergTable.split(".");
    let setup = "INSTALL iceberg; LOAD iceberg; INSTALL httpfs; LOAD httpfs;\n";
    if (s3KeyId || s3Endpoint) {
      const ep = s3Endpoint.replace(/^https?:\/\//, "");
      const ssl = s3Endpoint.startsWith("https://");
      setup += `CREATE OR REPLACE SECRET obj (TYPE s3, KEY_ID ${q(s3KeyId)}, SECRET ${q(s3Secret)}, ` +
        `REGION ${q(s3Region)}${s3Endpoint ? `, ENDPOINT ${q(ep)}, URL_STYLE 'path', USE_SSL ${ssl}` : ""});\n`;
    }
    setup += `ATTACH ${q(warehouse)} AS ic (TYPE iceberg, ENDPOINT ${q(icebergEndpoint)}, AUTHORIZATION_TYPE 'none');\n`;
    // endpoint_fp（gemba-adc/1.1）: 新規テーブルは src の全列（endpoint_fp 含む）で作られる。
    // v0.2.0 以前に作られた既存テーブルには列が無いので ADD COLUMN IF NOT EXISTS で追補し（Iceberg の
    // スキーマ進化）、列順に依存しない INSERT ... BY NAME で追記する（既存行の endpoint_fp は NULL＝未タグ）。
    writeSql = setup +
      `CREATE SCHEMA IF NOT EXISTS ic."${ns}";\n` +
      `CREATE TABLE IF NOT EXISTS ic."${ns}"."${tbl}" AS SELECT * FROM ${src} LIMIT 0;\n` +
      `ALTER TABLE ic."${ns}"."${tbl}" ADD COLUMN IF NOT EXISTS endpoint_fp VARCHAR;\n` +
      `INSERT INTO ic."${ns}"."${tbl}" BY NAME SELECT * FROM ${src};`;
    verifySql = setup +
      `SELECT count(*) FROM ic."${ns}"."${tbl}" WHERE loaded_at = ${q(now)};`;
  } else {
    // ── Parquet: 出力ファイルを上書き（冪等） ─────────────────────────
    fs.mkdirSync(path.dirname(out), { recursive: true });
    writeSql = `COPY (SELECT * FROM ${src}) TO ${q(out)} (FORMAT parquet, COMPRESSION zstd);`;
    verifySql = `SELECT count(*) FROM read_parquet(${q(out)}) WHERE loaded_at = ${q(now)};`;
  }

  // ── write 相 ─────────────────────────────────────────────────────────
  const w = runDuckdb(writeSql);
  if (w.status !== 0) {
    console.error((w.stderr || w.stdout || "duckdb write failed").trim());
    receipt("write", rows.length, rows.length, false);
    cleanup();
    process.exit(1);
  }
  receipt("write", rows.length, 0, false);

  // ── verify 相: 読み戻して今回 jobId（loaded_at）の行数を照合 ──────────
  const v = runDuckdb(verifySql);
  let found = -1;
  if (v.status === 0) {
    const lastLine = (v.stdout || "").trim().split("\n").pop();
    found = parseInt(lastLine, 10);
  } else {
    console.error((v.stderr || "duckdb verify failed").trim());
  }
  const verified = found === rows.length;
  receipt("verify", rows.length, verified ? 0 : rows.length, verified, { verifiedRows: found });
  cleanup();
  process.exit(verified ? 0 : 1);
})().catch((e) => {
  console.error(`${PLUGIN}: ${e.message}`);
  receipt("write", 0, 0, false);
  process.exit(1);
});
