      //    新しい検索意味は足さない＝既に parseQueryArgs が受理する共通フラグを宣言するだけ。
      { name: "--since", type: "string", subcommand: "query", filter: true, label: "開始時刻（含む）",
        placeholder: "2026-06-01 00:00:00", description: "時刻範囲の下限（半開区間 [since, until)）" },
