#!/usr/bin/env node
/**
 * i-repo-parquet — sink plugin: write i-repo NDJSON records to Parquet / Apache Iceberg.
 *
 * 構想「i-Repo DataPipe」の Lakehouse Manager 相当。
 * 帳票データを列指向の Parquet に変換し、DuckDB・Spark・Athena・BigQuery 等の
 * 分析エンジンから直接読める形で蓄積する。Iceberg モードでは REST カタログ経由で
 * Apache Iceberg テーブルに追記し、スキーマ進化・タイムトラベル・ACID を得る。
 *
 * 設計: duckdb CLI を呼ぶ薄いアダプタ（mongo が mongosh を呼ぶのと同じ流儀）。
 *   npm 依存ゼロ。顧客が duckdb を持っていればそのまま動く（brew install duckdb）。
 *   install: copy to ~/.i-repo/plugins/i-repo-parquet && chmod +x
 *
 * Usage:
 *   # Parquet ファイル（再実行で同ファイルを上書き = 冪等）
 *   cat manifests/reports.ndjson | i-repo parquet --out ~/warehouse/reports.parquet
 *
 *   # Apache Iceberg テーブルへ追記（REST カタログ + S3/MinIO）
 *   cat manifests/reports.ndjson | i-repo parquet \
 *     --iceberg-endpoint http://localhost:8181 --warehouse warehouse \
 *     --iceberg-table irepo.reports \
 *     --s3-endpoint http://localhost:9000 --s3-key-id admin --s3-secret password
 *
 * Contract (PLUGINS.md / SCHEMA.md):
 *   - 予約フラグ --plugin-schema / --plugin-healthcheck
 *   - IREPO_PLUGIN_API 不一致は exit 11
 *   - stream-end トレーラ照合 (§2.6)
 *   - receipt: write → verify。verify は書いた先を読み戻して件数照合し、
 *     verified:true はそのときだけ立てる
 *   - 冪等: Parquet モードは出力ファイルを毎回上書き（ファイル単位で冪等）。
 *     Iceberg モードは追記（append）— 再実行は重複するため、重複排除は
 *     クエリ側 QUALIFY か定期 compaction で行う（マニュアル参照）
 */
"use strict";

const PLUGIN = "i-repo-parquet";
const VERSION = "0.3.0";
const { spawnSyncSpec } = require("./lib/spawn.js");
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");

const argv = process.argv.slice(2);

// ── 構造化集計 aggregate（gemba-adc/1.2）で参照する正準名→列/属性の唯一の宣言源
// （--plugin-schema の dataset.fields と一致）。aggregate の次元/指標はここに在るフィールドのみ
// 参照可（未宣言＝E_ARGS＝越境穴を宣言駆動で封鎖）。dispatch より前に初期化する（TDZ 回避）。
const FIELD_META = {
  idempotencyKey: { col: "idempotency_key" },
  recordType: { col: "record_type" },
  itemId: { col: "item_id" },
  revNo: { col: "rev_no" },
  name: { col: "name", pii: true },
  deleted: { col: "deleted" },
  registTime: { col: "regist_time", datetime: true, timezone: "local" },
  updateTime: { col: "update_time", datetime: true, timezone: "local" },
  loadedAt: { col: "loaded_at", datetime: true, timezone: "utc" },
  endpointFp: { col: "endpoint_fp" },
};

// ── 予約フラグ ───────────────────────────────────────────────────────
if (argv[0] === "--plugin-schema") {
  process.stdout.write(JSON.stringify({
    pluginApi: ["1"],
    schemaVersions: ["1.0"],
    recordTypes: ["*"],
    name: PLUGIN,
    version: VERSION,
    description: "Write NDJSON records to Parquet / Apache Iceberg (DuckDB経由・Lakehouse Ready)",
    phases: ["write", "verify"],
    platforms: ["macos", "linux", "windows"],
    roles: ["sink", "read", "analyze"],
    category: "lakehouse",   // 表示カテゴリ（GUI 種別グループ表示用・脱料理）
    input: ["stdin-ndjson"],
    // ── ADC-1（gemba-read/1.0）読み返し契約の宣言 ──────────────────────
    subcommands: [
      { name: "query", mode: "read", input: ["none"], output: ["ndjson"],
        description: "着地済みレコードを正準封筒形で読み出す（ページ付き・書込ゼロ）" },
      // gemba-adc/1.2: 構造化集計。生 SQL を渡さず group_by/measure で集計（エージェント面に公開可）。
      { name: "aggregate", mode: "read", input: ["none"], output: ["ndjson"],
        description: "次元(group_by)＋指標(measure)で集計する（読み取り専用・aggregate-row + query-end）" },
    ],
    params: [
      { name: "--out", type: "string",
        label: "Parquet出力ファイル", placeholder: "~/warehouse/reports.parquet",
